            shutil.rmtree(ALLRECORDS_CACHE_DIR)
        else:
            ALLRECORDS_CACHE_DIR.unlink(missing_ok=True)
    except OSError:
        pass

    try:
        ZONE_COMPLETION_CACHE_FILE.unlink()
    except FileNotFoundError:
        pass
    except OSError:
        pass


def zone_serial_cache_key(client: InfobloxClient) -> str:
