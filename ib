def format_record(record_type: str, item: dict[str, Any]) -> str:
    """Format one DNS record for completion help so candidates carry type, value, zone, and comment context."""
    value_keys = ("ipv4addr", "ipv6addr", "canonical", "text", "mail_exchanger", "ptrdname")
    value = next((str(item[key]) for key in value_keys if key in item), "")
    if record_type == "mx" and "preference" in item and value:
        value = f"{item['preference']} {value}"

    ttl = item.get("ttl", "")
    comment = item.get("comment", "")
    zone = item.get("zone", "")
    parts = [
        record_type.upper().ljust(5),
        str(item.get("name", "")).ljust(40),
        value.ljust(30),
        f"zone={zone}" if zone else "",
        f"ttl={ttl}" if ttl != "" else "",
        f"comment={comment}" if comment else "",
        f"ref={item.get('_ref')}" if item.get("_ref") else "",
    ]
    return "  ".join(part for part in parts if part)


def record_value(record_type: str, item: dict[str, Any]) -> str:
    """Return the display value for a record across direct and allrecords response shapes."""
    if item.get("type"):
        return allrecord_display_value(record_type, item)

    normalized_type = str(record_type).strip().lower()
    if normalized_type.startswith("shared-"):
        normalized_type = normalized_type.removeprefix("shared-")
    if normalized_type == "ptr":
        ptr_target = first_record_value(item, ("ptrdname",))
        if ptr_target:
            return ptr_target

    if item.get("address"):
        return str(item["address"])
    if item.get("record"):
        return str(item["record"])

    if record_type == "host":
        values = []
        for key, nested_key in (("ipv4addrs", "ipv4addr"), ("ipv6addrs", "ipv6addr")):
            for address in item.get(key, []) or []:
                if isinstance(address, dict) and address.get(nested_key):
                    values.append(str(address[nested_key]))
                elif isinstance(address, str):
                    values.append(address)
        return ", ".join(values)

    value_keys = ("ipv4addr", "ipv6addr", "canonical", "text", "mail_exchanger", "ptrdname")
    value = next((str(item[key]) for key in value_keys if key in item), "")
    if record_type == "mx" and "preference" in item and value:
        return f"{item['preference']} {value}"
    if record_type == "srv":
        values = [
            str(item.get("priority", "")),
            str(item.get("weight", "")),
            str(item.get("port", "")),
            str(item.get("target", "")),
        ]
        return " ".join(value for value in values if value)
    return value


def record_name(item: dict[str, Any], record_type: str | None = None) -> str:
    """Return the display name for a record across direct and allrecords response shapes."""
    normalized_type = str(record_type or "").strip().lower()
    if not normalized_type and item.get("type"):
        normalized_type = allrecord_type(item)
    if normalized_type.startswith("shared-"):
        normalized_type = normalized_type.removeprefix("shared-")

    if normalized_type == "ptr":
        return ptr_display_name(item)
    if item.get("type"):
        return allrecord_display_name(item)
    return str(item.get("name", ""))


