def main() -> int:
    try:
        cli.main(prog_name="ib", standalone_mode=False)
        return 0
    except (KeyboardInterrupt, EOFError, click.Abort):
        return 130
    except click.ClickException as exc:
        print_click_exception(exc)
        print_dns_create_click_error_help(exc)
        print_dns_delete_click_error_hint(exc)
        print_click_error_dns_context(exc)
        return exc.exit_code
    except DnsCreateError as exc:
        print_error(str(exc))
        print_dns_create_error_context(exc.context)
        return 1
    except CliError as exc:
        print_error(str(exc))
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
