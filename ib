    """Build delete completion help text that explains what each candidate would remove."""
    parts = [record_type.upper()]
    value = record_value(record_type, item)
    zone = str(item.get("zone", ""))
    comment = str(item.get("comment", ""))
    if value:
        parts.append(value)
    if zone:
        parts.append(f"zone={zone}")
    if comment:
        parts.append(comment)
    return " | ".join(parts)


def dns_delete_ptr_completion(incomplete: str) -> list[CompletionItem]:
    """Return the PTR delete keyword completion so reverse deletion is discoverable."""
    if "ptr".startswith(incomplete.lower()):
        return [CompletionItem("ptr", help="Delete PTR record by full IP address")]
    return []


def dns_delete_completion_supported_record_type(record_type: str, item: dict[str, Any]) -> bool:
    """Return whether a cached record type is safe for forward delete completion."""
    candidates = {record_type.lower(), allrecord_type(item).lower()}
    return bool(candidates & DNS_DELETE_COMPLETION_RECORD_TYPES)


def dns_delete_completion_excluded_record(record_type: str, item: dict[str, Any]) -> bool:
    """Exclude reverse or unsupported records from forward delete completions."""
    if not dns_delete_completion_supported_record_type(record_type, item):
        return True
    return is_reverse_zone_name(str(item.get("zone", ""))) or is_reverse_zone_name(
        record_name(item)
    )


def completion_record_name_matches(item: dict[str, Any], incomplete: str) -> bool:
    """Match completion candidates by record name only, using the normal case-insensitive substring rule."""
    keyword = incomplete.strip()
    return not keyword or search_value_exact_match(record_name(item), keyword, case_sensitive=False)


def cached_record_completion_records(
    client: InfobloxClient,
    keyword: str,
    limit: int,
    zone_filter: Callable[[dict[str, Any]], bool] | None = None,
    *,
    name_only: bool = False,
) -> list[tuple[str, dict[str, Any]]]:
    """Read cached search rows for shell completion when live cache validation cannot run."""
    keyword = keyword.strip()
    params: list[Any] = [client.server, client.wapi_version, client.view]
    condition_sql = ""
    if keyword:
        if name_only:
            condition_sql = " AND instr(lower(s.name), ?) > 0"
            params.append(keyword.lower())
        else:
            condition, search_params = sqlite_exact_search_condition(keyword, case_sensitive=False)
            condition_sql = f" AND ({condition})"
            params.extend(search_params)

    try:
        with connect_search_cache_db_readonly() as conn:
            rows = conn.execute(
                f"""
                SELECT s.type, s.zone, s.name, s.value, s.comment, s.record_json
                FROM search_entries s
                JOIN zone_record_cache z ON z.cache_key = s.cache_key
                WHERE z.server = ? AND z.wapi_version = ? AND z.view = ?
                {condition_sql}
                ORDER BY lower(s.zone), lower(s.name), lower(s.type), lower(s.value), s.record_key
                """,
                tuple(params),
            ).fetchall()
    except (OSError, sqlite3.Error):
        return []

    entries = sqlite_search_entries_from_rows(rows)
    if entries is None:
        return []

    records: list[tuple[str, dict[str, Any]]] = []
    seen: set[str] = set()
    for entry in entries:
        zone_name = str(entry.get("zone", ""))
        if zone_filter is not None and not zone_filter({"fqdn": zone_name}):
            continue
        record = dict(allrecord_search_entry_record(entry))
        if not record:
            continue
        record.setdefault("zone", zone_name)
        record.setdefault("name", str(entry.get("name", "")))
        record.setdefault("comment", str(entry.get("comment", "")))
        record_type = allrecord_search_entry_type(entry)
        if dns_delete_completion_excluded_record(record_type, record):
            continue
        if name_only and not completion_record_name_matches(record, keyword):
            continue
        record_key = str(record.get("_ref") or json.dumps(record, sort_keys=True))
        if record_key in seen:
            continue
        seen.add(record_key)
        records.append((record_type, record))
        if len(records) >= limit:
            break
    return records


def collect_record_completion_records(
    client: InfobloxClient,
    keyword: str,
    limit: int,
    *,
    name_only: bool = False,
) -> list[tuple[str, dict[str, Any]]]:
    """Collect forward records for completion, falling back to cached rows when live validation fails."""
    try:
        records = collect_dns_search_results(
            client,
            keyword.strip(),
            False,
            None,
            fuzzy_search=False,
            zone_filter=is_forward_zone,
        )
        if name_only:
            records = [
                (record_type, item)
                for record_type, item in records
                if completion_record_name_matches(item, keyword)
            ]
        return records
    except (CliError, OSError, ValueError, sqlite3.Error):
        return cached_record_completion_records(
            client,
            keyword,
            limit,
            zone_filter=is_forward_zone,
            name_only=name_only,
        )


def complete_dns_delete_records(
    ctx: click.Context,
    param: click.Parameter,
    incomplete: str,
) -> list[CompletionItem]:
    """Return delete record completions from cached DNS search data while failing quietly."""
    items = dns_delete_ptr_completion(incomplete)
    try:
        config = load_config(required=False)
        if not config:
            return items
        client = InfobloxClient(config)
        records = collect_record_completion_records(
            client,
            incomplete,
            DNS_DELETE_COMPLETION_LIMIT,
            name_only=True,
        )
    except (CliError, OSError, ValueError, sqlite3.Error):
        return items

    seen: set[str] = {str(item.value) for item in items}
    for record_type, item in records:
        if dns_delete_completion_excluded_record(record_type, item):
            continue
        name = record_name(item).strip().rstrip(".")
        if not name or name in seen:
            continue
        if not completion_record_name_matches(item, incomplete):
            continue
        seen.add(name)
        items.append(CompletionItem(name, help=dns_delete_completion_help(record_type, item)))
        if len(items) >= DNS_DELETE_COMPLETION_LIMIT:
            break
    return items


