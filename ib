    include_source: bool = True,
) -> Text:
    context = status or dns_context_status()
    view_name = context["view"]
    view_style = (
        "bold magenta on #0f172a" if view_name != "not configured" else "bold yellow on #0f172a"
    )
    return dns_context_value_text(view_name, context["view_source"], view_style, include_source)


def active_zone_context_text(
    status: dict[str, Any] | None = None,
    include_source: bool = True,
) -> Text:
