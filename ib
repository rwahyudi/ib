def zone_network_association_unavailable(exc: WapiError) -> str:
    """Format a non-fatal network-association lookup failure for zone view output."""
    status = f" {exc.status}" if exc.status else ""
    return f"Unavailable: Infoblox WAPI{status} failed while reading network associations."


def add_zone_network_association_details(
    client: InfobloxClient,
    target: str,
    zone_info: dict[str, Any],
) -> None:
    """Augment zone detail with network associations when WAPI supports the extra lookup."""
    params = zone_query_params(
        client,
        {"fqdn": target},
        return_fields=ZONE_NETWORK_ASSOCIATION_RETURN_FIELDS,
    )
    try:
        result = client.request("GET", ZONE_OBJECT, params=params)
    except WapiError as exc:
        zone_info.setdefault("network_associations", zone_network_association_unavailable(exc))
        return

    matches = result if isinstance(result, list) else []
    if len(matches) != 1:
        return

    association_info = matches[0]
    for key in ("network_view", "network_associations"):
        if key in association_info:
            zone_info[key] = association_info[key]


def run_dns_zone_view(zone_name: str) -> None:
