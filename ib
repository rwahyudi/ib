def parse_dns_create_name_value(
    args: tuple[str, ...],
    name_option: str | None,
) -> tuple[str, str]:
    """Parse create positional and legacy -n forms into one name/value pair."""
    ctx = click.get_current_context(silent=True)
    usage_hint = "Use: ib dns create <type> <name> <value>"

    if name_option:
        if len(args) != 1:
            raise click.UsageError(
                f"Expected VALUE when using -n/--name. {usage_hint}",
                ctx=ctx,
            )
        return name_option, args[0]

    if len(args) != 2:
        raise click.UsageError(
            f"Expected NAME and VALUE after the record type. {usage_hint}",
            ctx=ctx,
        )
    return args[0], args[1]


