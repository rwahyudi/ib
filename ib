    ALLRECORDS_CACHE_DIR.parent.mkdir(mode=0o700, exist_ok=True)
    ALLRECORDS_CACHE_DIR.mkdir(mode=0o700, exist_ok=True)
    try:
        os.chmod(ALLRECORDS_CACHE_DIR.parent, 0o700)
        os.chmod(ALLRECORDS_CACHE_DIR, 0o700)
    except OSError:
        pass


def initialize_search_cache_db(conn: sqlite3.Connection) -> None:
    """Create or migrate SQLite cache tables so current and older cache layouts both work."""
    conn.executescript(
        """
        CREATE TABLE IF NOT EXISTS zone_serial_cache (
            cache_key TEXT PRIMARY KEY,
            server TEXT NOT NULL,
            wapi_version TEXT NOT NULL,
            view TEXT NOT NULL,
            created_at REAL NOT NULL,
            zones_json TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS zone_record_cache (
            cache_key TEXT PRIMARY KEY,
            server TEXT NOT NULL,
            wapi_version TEXT NOT NULL,
            view TEXT NOT NULL,
            zone TEXT NOT NULL,
            serial_number TEXT NOT NULL,
            updated_at REAL NOT NULL
        );

        CREATE TABLE IF NOT EXISTS search_entries (
            cache_key TEXT NOT NULL,
            record_key TEXT NOT NULL,
            type TEXT NOT NULL,
            zone TEXT NOT NULL,
            name TEXT NOT NULL,
            value TEXT NOT NULL,
            comment TEXT NOT NULL,
            record_json TEXT NOT NULL,
            PRIMARY KEY (cache_key, record_key)
        );

        CREATE INDEX IF NOT EXISTS idx_search_entries_cache
            ON search_entries(cache_key);
        CREATE INDEX IF NOT EXISTS idx_search_entries_zone_name
            ON search_entries(cache_key, zone, name);
        """
    )


def connect_search_cache_db() -> sqlite3.Connection:
    """Open the SQLite cache with row access and initialized schema for callers."""
    ensure_allrecords_cache_dir()
    db_file = allrecords_cache_db_file()
    conn = sqlite3.connect(db_file, timeout=30)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA busy_timeout = 30000")
    try:
        conn.execute("PRAGMA journal_mode = WAL")
        conn.execute("PRAGMA synchronous = NORMAL")
    except sqlite3.Error:
        pass
    initialize_search_cache_db(conn)
    try:
        os.chmod(db_file, 0o600)
    except OSError:
        pass
    return conn


def normalize_zone_serial_cache(zones: Any) -> list[dict[str, Any]] | None:
    """Validate zone serial cache payloads so corrupt JSON can be ignored safely."""
    if not isinstance(zones, list) or not all(isinstance(zone, dict) for zone in zones):
        return None
    return zones


def read_zone_serial_cache(client: InfobloxClient) -> list[dict[str, Any]] | None:
    """Read cached zone serials so search can skip expensive zone queries when still fresh."""
    try:
        with connect_search_cache_db() as conn:
            row = conn.execute(
                "SELECT created_at, zones_json FROM zone_serial_cache WHERE cache_key = ?",
                (zone_serial_cache_key(client),),
            ).fetchone()
    except (OSError, sqlite3.Error):
        return None

    if row is None or time.time() - float(row["created_at"]) > ZONE_SERIAL_CACHE_TTL:
        return None

    try:
        zones = json.loads(str(row["zones_json"]))
    except json.JSONDecodeError:
        return None
    return normalize_zone_serial_cache(zones)


def write_zone_serial_cache(client: InfobloxClient, zones: list[dict[str, Any]]) -> None:
    """Persist zone serials for later cache validation and tolerate cache write failures."""
    try:
        with connect_search_cache_db() as conn:
            conn.execute(
                """
                INSERT OR REPLACE INTO zone_serial_cache
                    (cache_key, server, wapi_version, view, created_at, zones_json)
                VALUES (?, ?, ?, ?, ?, ?)
                """,
                (
                    zone_serial_cache_key(client),
                    client.server,
                    client.wapi_version,
                    client.view,
                    time.time(),
                    json.dumps(zones),
                ),
            )
    except (OSError, sqlite3.Error):
        return


def sqlite_zone_record_cache_is_valid(
    conn: sqlite3.Connection,
    cache_key: str,
    serial_number: str,
) -> bool:
    """Check whether cached entries match the current zone serial before using them."""
    row = conn.execute(
        "SELECT serial_number FROM zone_record_cache WHERE cache_key = ?",
        (cache_key,),
    ).fetchone()
    return row is not None and str(row["serial_number"]) == serial_number


def sqlite_search_entry_from_row(row: sqlite3.Row) -> dict[str, Any] | None:
    """Convert one SQLite row into a cached search entry while dropping corrupt JSON rows."""
    try:
        record = json.loads(str(row["record_json"]))
    except json.JSONDecodeError:
        return None
    if not isinstance(record, dict):
        return None

    return {
        "type": str(row["type"]),
        "zone": str(row["zone"]),
        "name": str(row["name"]),
        "value": str(row["value"]),
        "comment": str(row["comment"]),
        "record": record,
    }


def read_sqlite_allrecords_search_entries(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> list[dict[str, Any]] | None:
    """Read cached allrecords entries for one zone when the serial proves them current."""
    if serial_number is None:
        return None
    cache_key = allrecords_cache_key(client, zone_name)
    try:
        with connect_search_cache_db() as conn:
            if not sqlite_zone_record_cache_is_valid(conn, cache_key, serial_number):
                return None
            rows = conn.execute(
                """
                SELECT type, zone, name, value, comment, record_json
                FROM search_entries
                WHERE cache_key = ?
                ORDER BY lower(zone), lower(name), lower(type), lower(value), record_key
                """,
                (cache_key,),
            ).fetchall()
    except (OSError, sqlite3.Error):
        return None

    entries = []
    for row in rows:
        entry = sqlite_search_entry_from_row(row)
        if entry is None:
            return None
        entries.append(entry)
    return entries


def search_sqlite_allrecords_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
    keyword: str,
    case_sensitive: bool,
) -> list[dict[str, Any]] | None:
    """Search cached allrecords entries locally so repeated DNS searches avoid WAPI calls."""
    if serial_number is None:
        return None
    cache_key = allrecords_cache_key(client, zone_name)
    if not keyword:
        return read_sqlite_allrecords_search_entries(client, zone_name, serial_number)

    if case_sensitive:
        condition = "instr(name, ?) > 0 OR instr(value, ?) > 0 OR instr(comment, ?) > 0"
        params = (keyword, keyword, keyword)
    else:
        needle = keyword.lower()
        condition = (
            "instr(lower(name), ?) > 0 OR "
            "instr(lower(value), ?) > 0 OR "
            "instr(lower(comment), ?) > 0"
        )
        params = (needle, needle, needle)

    try:
        with connect_search_cache_db() as conn:
            if not sqlite_zone_record_cache_is_valid(conn, cache_key, serial_number):
                return None
            rows = conn.execute(
                f"""
                SELECT type, zone, name, value, comment, record_json
                FROM search_entries
                WHERE cache_key = ? AND ({condition})
                """,
                (cache_key, *params),
            ).fetchall()
    except (OSError, sqlite3.Error):
        return None

    entries = []
    for row in rows:
        entry = sqlite_search_entry_from_row(row)
        if entry is None:
            return None
        if allrecord_search_entry_matches_keyword(entry, keyword, case_sensitive):
            entries.append(entry)
    return entries


def read_legacy_allrecords_cache_payload(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> dict[str, Any] | None:
    """Read the older JSON cache format so users are not forced to rebuild immediately."""
    if serial_number is None:
        return None
    try:
        with allrecords_cache_file(client, zone_name).open("r", encoding="utf-8") as handle:
            cache = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(cache, dict):
        return None
    if cache.get("server") != client.server or cache.get("view") != client.view:
        return None
    if cache.get("zone") != normalize_zone_name(zone_name):
        return None
    if str(cache.get("soa_serial_number", "")) != serial_number:
        return None
    return cache


def read_allrecords_cache_payload(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> dict[str, Any] | None:
    """Read either current or legacy cache payloads so cache migration is transparent."""
    entries = read_sqlite_allrecords_search_entries(client, zone_name, serial_number)
    if entries is not None:
        return {
            "server": client.server,
            "wapi_version": client.wapi_version,
            "view": client.view,
            "zone": normalize_zone_name(zone_name),
            "soa_serial_number": serial_number,
            "records": [entry["record"] for entry in entries],
            "search_entries": entries,
        }

    return read_legacy_allrecords_cache_payload(client, zone_name, serial_number)


def cached_records(cache: dict[str, Any]) -> list[dict[str, Any]] | None:
    """Extract records from a cache payload only when the payload shape is usable."""
    records = cache.get("records")
    if not isinstance(records, list) or not all(isinstance(item, dict) for item in records):
        return None
    return records


def read_allrecords_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> list[dict[str, Any]] | None:
    """Read legacy allrecords cache data when still valid for compatibility paths."""
    cache = read_allrecords_cache_payload(client, zone_name, serial_number)
    return cached_records(cache) if cache else None


def allrecord_search_entry(item: dict[str, Any], zone_name: str | None = None) -> dict[str, Any]:
    """Normalize one allrecords item into the cache/search entry shape."""
    record_type = allrecord_type(item)
    return {
        "type": record_type,
        "zone": str(item.get("zone", "") or zone_name or ""),
        "name": allrecord_display_name(item),
        "value": allrecord_display_value(record_type, item),
        "comment": str(item.get("comment", "")),
        "record": item,
    }


def allrecord_search_entries(
    records: list[dict[str, Any]],
    zone_name: str | None = None,
) -> list[dict[str, Any]]:
    """Normalize all allrecords items for one zone so search and list consume the same shape."""
    return [allrecord_search_entry(item, zone_name) for item in records]


def normalize_cached_search_entry(entry: Any) -> dict[str, Any] | None:
    """Validate one cached search entry so corrupt cache rows are skipped safely."""
    if not isinstance(entry, dict):
        return None
    record = entry.get("record")
    if not isinstance(record, dict):
        return None

    return {
        "type": str(entry.get("type", "")),
        "zone": str(entry.get("zone", "")),
        "name": str(entry.get("name", "")),
        "value": str(entry.get("value", "")),
        "comment": str(entry.get("comment", "")),
        "record": record,
    }


def normalize_cached_search_entries(entries: Any) -> list[dict[str, Any]] | None:
    """Validate cached search entries as a list so callers get clean record data."""
    if not isinstance(entries, list):
        return None

    normalized = []
    for entry in entries:
        normalized_entry = normalize_cached_search_entry(entry)
        if normalized_entry is None:
            return None
        normalized.append(normalized_entry)
    return normalized


def read_allrecords_search_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> list[dict[str, Any]] | None:
    """Read all cached search entries for a zone, preferring SQLite and falling back to legacy cache."""
    cached_entries = read_sqlite_allrecords_search_entries(client, zone_name, serial_number)
    if cached_entries is not None:
        return cached_entries

    cache = read_legacy_allrecords_cache_payload(client, zone_name, serial_number)
    if not cache:
        return None

    search_entries = normalize_cached_search_entries(cache.get("search_entries"))
    if search_entries is not None:
        records = cached_records(cache)
        if records is not None:
            write_allrecords_cache(client, zone_name, serial_number, records, search_entries)
        return search_entries

    records = cached_records(cache)
    if records is None:
        return None

    search_entries = allrecord_search_entries(records, zone_name)
    write_allrecords_cache(client, zone_name, serial_number, records, search_entries)
    return search_entries


def write_allrecords_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
    records: list[dict[str, Any]],
    search_entries: list[dict[str, Any]] | None = None,
) -> None:
    """Persist allrecords entries to SQLite so search and completion can reuse them quickly."""
    if serial_number is None:
        return
    if search_entries is None:
        search_entries = allrecord_search_entries(records, zone_name)
    cache_key = allrecords_cache_key(client, zone_name)
    normalized_zone = normalize_zone_name(zone_name)
    now = time.time()
    rows = []
    for entry in search_entries:
        record = allrecord_search_entry_record(entry)
        if not record:
            continue
        try:
            record_json = json.dumps(record, sort_keys=True)
        except (TypeError, ValueError):
            continue
        rows.append(
            (
                cache_key,
                record_result_key(record),
                str(entry.get("type", "")),
                str(entry.get("zone", "") or normalized_zone),
                str(entry.get("name", "")),
                str(entry.get("value", "")),
                str(entry.get("comment", "")),
                record_json,
            )
        )

    try:
        with connect_search_cache_db() as conn:
            conn.execute(
                """
                INSERT OR REPLACE INTO zone_record_cache
                    (cache_key, server, wapi_version, view, zone, serial_number, updated_at)
                VALUES (?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    cache_key,
                    client.server,
                    client.wapi_version,
                    client.view,
                    normalized_zone,
                    str(serial_number),
                    now,
                ),
            )
            conn.execute("DELETE FROM search_entries WHERE cache_key = ?", (cache_key,))
            conn.executemany(
                """
                INSERT OR REPLACE INTO search_entries
                    (cache_key, record_key, type, zone, name, value, comment, record_json)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                """,
                rows,
            )
    except (OSError, sqlite3.Error):
        return


def query_zone_serials(client: InfobloxClient) -> list[dict[str, Any]]:
    """Query zone serials with paging so cache validation sees every authoritative zone."""
    cached_zones = read_zone_serial_cache(client)
    if cached_zones is not None:
        return cached_zones

    zones = paged_query(
        client,
        ZONE_OBJECT,
        zone_query_params(client, return_fields=ZONE_SERIAL_RETURN_FIELDS),
    )
    write_zone_serial_cache(client, zones)
    return zones


def search_zones(client: InfobloxClient, root_zone: str | None) -> list[dict[str, Any]]:
    """Select zones within the requested search scope so normal search stays zone-limited."""
    zones = query_zone_serials(client)
    if not root_zone:
        return sorted(
            [zone for zone in zones if not is_secondary_zone(zone)],
            key=lambda zone: str(zone.get("fqdn", "")).lower(),
        )

    filtered = []
    seen_names: set[str] = set()
    for zone in zones:
        zone_name = str(zone.get("fqdn", "")).strip()
        if not zone_name:
            continue
        try:
            normalized = normalize_zone_name(zone_name)
        except CliError:
            continue
        if is_zone_or_child(normalized, root_zone):
            seen_names.add(normalized)
            if is_secondary_zone(zone):
                continue
            filtered.append(zone)

    normalized_root = normalize_zone_name(root_zone)
    if normalized_root not in seen_names:
        filtered.append({"fqdn": normalized_root, "view": client.view})
    return sorted(filtered, key=lambda zone: str(zone.get("fqdn", "")).lower())


def allrecords_for_zone(client: InfobloxClient, zone_info: dict[str, Any]) -> list[dict[str, Any]]:
    """Fetch allrecords for one zone while skipping zones that cannot provide reliable records."""
    zone_name = normalize_zone_name(str(zone_info.get("fqdn", "")))
    serial_number = zone_serial(zone_info)
    cached_records = read_allrecords_cache(client, zone_name, serial_number)
    if cached_records is not None:
        return cached_records

    records = paged_query(client, ALLRECORDS_OBJECT, allrecords_query_params(client, zone_name))
    write_allrecords_cache(client, zone_name, serial_number, records)
    return records


def allrecords_search_entries_for_zone(
    client: InfobloxClient,
    zone_info: dict[str, Any],
) -> list[dict[str, Any]]:
    """Return cached or freshly queried search entries for a zone based on SOA serial checks."""
    zone_name = normalize_zone_name(str(zone_info.get("fqdn", "")))
    serial_number = zone_serial(zone_info)
    cached_entries = read_allrecords_search_cache(client, zone_name, serial_number)
    if cached_entries is not None:
        return cached_entries

    records = paged_query(client, ALLRECORDS_OBJECT, allrecords_query_params(client, zone_name))
    search_entries = allrecord_search_entries(records, zone_name)
    write_allrecords_cache(client, zone_name, serial_number, records, search_entries)
    return search_entries


def record_in_zone_scope(item: dict[str, Any], root_zone: str) -> bool:
    """Return whether a record belongs to a search root so cached global data can be filtered locally."""
    zone_name = str(item.get("zone", "")).strip()
    if zone_name:
        return is_zone_or_child(zone_name, root_zone)

    record_name = str(item.get("name", "")).strip()
    return bool(record_name) and is_zone_or_child(record_name, root_zone)


def decoded_allrecords_ref(item: dict[str, Any]) -> str:
    """Decode allrecords references so unsupported synthetic record types can be identified."""
    ref = str(item.get("_ref", ""))
    prefix = f"{ALLRECORDS_OBJECT}/"
    if not ref.startswith(prefix):
        return ""

    token = ref[len(prefix) :].split(":", 1)[0]
    if not token:
        return ""

    padding = "=" * (-len(token) % 4)
    try:
        return base64.urlsafe_b64decode(f"{token}{padding}".encode("ascii")).decode(
            "utf-8",
            errors="ignore",
        )
    except (binascii.Error, UnicodeEncodeError, ValueError):
        return ""


def unsupported_allrecord_type(item: dict[str, Any]) -> str:
    """Infer display labels for known unsupported allrecords records so search output is clearer."""
    decoded_ref = decoded_allrecords_ref(item)
    if "fake_bind_ns" in decoded_ref:
        return "ns"
    if "bind_soa" in decoded_ref:
        return "soa"
    return "unsupported"


def allrecord_type(item: dict[str, Any]) -> str:
    """Return the normalized record type from allrecords data, including unsupported inferred types."""
    raw_type = str(item.get("type", "")).lower()
    if raw_type == "unsupported":
        return unsupported_allrecord_type(item)
    if raw_type.startswith("record:"):
        record_type = raw_type.split(":", 1)[1]
        if record_type in {"host_ipv4addr", "host_ipv6addr"}:
            return "host"
        return record_type
    if raw_type.startswith("sharedrecord:"):
        return raw_type.replace("sharedrecord:", "shared-", 1)
    return raw_type or "record"


def nested_record(item: dict[str, Any]) -> dict[str, Any]:
    """Return the nested concrete record payload when allrecords wraps typed record details."""
    record = item.get("record")
    return record if isinstance(record, dict) else {}


def first_record_value(item: dict[str, Any], keys: tuple[str, ...]) -> str:
    """Return the first populated value field from a record so display logic can stay generic."""
    record = nested_record(item)
    for key in keys:
        value = record.get(key, item.get(key))
        if value not in (None, ""):
            return str(value)
    return ""


def allrecord_display_name(item: dict[str, Any]) -> str:
    """Return the best record name from allrecords data, including nested record payloads."""
    return first_record_value(item, ("name",)) or str(item.get("name", ""))


def allrecord_display_value(record_type: str, item: dict[str, Any]) -> str:
    """Return the best display value for an allrecords entry based on its record type."""
    if record_type in {"cname", "shared-cname"}:
        return first_record_value(item, ("canonical",))
    if record_type in {"txt", "shared-txt"}:
        return first_record_value(item, ("text",))
    if record_type in {"mx", "shared-mx"}:
        exchanger = first_record_value(item, ("mail_exchanger",))
        preference = first_record_value(item, ("preference",))
        return f"{preference} {exchanger}".strip() if exchanger else ""
    if record_type == "ptr":
        return first_record_value(item, ("ptrdname", "ipv4addr", "ipv6addr"))
    if record_type == "host":
        values = []
        record = nested_record(item)
        for key, nested_key in (("ipv4addrs", "ipv4addr"), ("ipv6addrs", "ipv6addr")):
            for address in record.get(key, item.get(key, [])) or []:
                if isinstance(address, dict) and address.get(nested_key):
                    values.append(str(address[nested_key]))
                elif isinstance(address, str):
                    values.append(address)
        if values:
            return ", ".join(values)
    if record_type in {"a", "shared-a"}:
        return first_record_value(item, ("ipv4addr", "address"))
    if record_type in {"aaaa", "shared-aaaa"}:
        return first_record_value(item, ("ipv6addr", "address"))
    if item.get("address"):
        return str(item["address"])
    record = item.get("record")
    return str(record) if record not in (None, "") else ""


def allrecord_search_values(record_type: str, item: dict[str, Any]) -> list[str]:
    """Collect searchable text for one allrecords entry so search covers name, value, and comment."""
    return [
        allrecord_display_name(item),
        allrecord_display_value(record_type, item),
        str(item.get("comment", "")),
    ]


def allrecord_matches_keyword(
    item: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
) -> bool:
    """Return whether one allrecords entry matches the keyword using local case handling."""
    needle = keyword if case_sensitive else keyword.lower()
    record_type = allrecord_type(item)
    for value in allrecord_search_values(record_type, item):
        haystack = value if case_sensitive else value.lower()
        if needle in haystack:
            return True
    return False


def allrecord_search_entry_matches_keyword(
    entry: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
) -> bool:
    """Apply keyword matching to cached search entries so SQLite and live paths agree."""
    needle = keyword if case_sensitive else keyword.lower()
    for key in ("name", "value", "comment"):
        value = str(entry.get(key, ""))
        haystack = value if case_sensitive else value.lower()
        if needle in haystack:
            return True
    return False


def allrecord_search_entry_record(entry: dict[str, Any]) -> dict[str, Any]:
    """Return the record payload from a cached search entry for table/output rendering."""
    record = entry.get("record")
    return record if isinstance(record, dict) else {}


def allrecord_search_entry_type(entry: dict[str, Any]) -> str:
    """Return the cached record type in normalized form for display and sorting."""
    record = allrecord_search_entry_record(entry)
    entry_type = str(entry.get("type") or "")
    if entry_type.lower() == "unsupported":
        return allrecord_type(record)
    return entry_type or allrecord_type(record)


def allrecord_search_entry_sort_key(entry: dict[str, Any]) -> tuple[str, str, str, str, str]:
    """Build a stable sort key so DNS search and list output are predictable."""
    record = allrecord_search_entry_record(entry)
    record_type = allrecord_search_entry_type(entry)
    zone_name = str(entry.get("zone") or record.get("zone", ""))
    name = str(entry.get("name") or record_name(record))
    value = str(entry.get("value") or record_value(record_type, record))
    return (
        zone_name.lower(),
        name.lower(),
        record_type.lower(),
        value.lower(),
        record_result_key(record),
    )


def clone_infoblox_client(client: InfobloxClient) -> InfobloxClient:
    """Create a per-thread client so concurrent zone queries do not share HTTPS connections."""
    attrs = ("server", "wapi_version", "username", "password", "view", "timeout", "verify_ssl")
    if not all(hasattr(client, attr) for attr in attrs):
        return client

    return InfobloxClient(
        {
            "server": client.server,
            "wapi_version": client.wapi_version,
            "username": client.username,
            "password": client.password,
            "dns_view": client.view,
            "timeout": str(client.timeout),
            "verify_ssl": "true" if client.verify_ssl else "false",
        }
    )


def matching_search_entries_for_zone(
    client: InfobloxClient,
    zone_info: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
    root_zone: str | None,
) -> list[dict[str, Any]]:
    """Return matching entries for one zone using cache first, then local keyword filtering."""
    zone_name = normalize_zone_name(str(zone_info.get("fqdn", "")))
    serial_number = zone_serial(zone_info)
    entries = search_sqlite_allrecords_cache(
        client,
        zone_name,
        serial_number,
        keyword,
        case_sensitive,
    )
    if entries is None:
        entries = read_allrecords_search_cache(client, zone_name, serial_number)
    if entries is None:
        records = paged_query(client, ALLRECORDS_OBJECT, allrecords_query_params(client, zone_name))
        entries = allrecord_search_entries(records, zone_name)
        write_allrecords_cache(client, zone_name, serial_number, records, entries)

    matches = []
    for entry in entries:
        if not allrecord_search_entry_matches_keyword(entry, keyword, case_sensitive):
            continue
        record = allrecord_search_entry_record(entry)
        if root_zone and not record_in_zone_scope(record, root_zone):
            continue
        matches.append(entry)
    return matches


def collect_dns_search_results(
    client: InfobloxClient,
    keyword: str,
    case_sensitive: bool,
    root_zone: str | None,
    *,
    zone_filter: Callable[[dict[str, Any]], bool] | None = None,
) -> list[tuple[str, dict[str, Any]]]:
    """Collect search results across scoped zones concurrently while deduplicating records."""
    seen: set[str] = set()
    records: list[tuple[str, dict[str, Any]]] = []
    zones = search_zones(client, root_zone)
    if zone_filter is not None:
        zones = [zone for zone in zones if zone_filter(zone)]

    def collect_zone_entries(zone_info: dict[str, Any]) -> list[dict[str, Any]]:
        """Collect search entries for one zone inside the worker pool so failures stay local to that zone."""
        worker_client = clone_infoblox_client(client)
        return matching_search_entries_for_zone(
            worker_client,
            zone_info,
            keyword,
            case_sensitive,
            root_zone,
        )

    search_entries: list[dict[str, Any]] = []
    if len(zones) > 1:
        worker_count = min(DNS_SEARCH_WORKERS, len(zones))
        with ThreadPoolExecutor(max_workers=worker_count) as executor:
            for zone_entries in executor.map(collect_zone_entries, zones):
                search_entries.extend(zone_entries)
    elif zones:
        search_entries.extend(collect_zone_entries(zones[0]))

    for entry in sorted(search_entries, key=allrecord_search_entry_sort_key):
        record = allrecord_search_entry_record(entry)
        if not record:
            continue
        key = record_result_key(record)
        if key in seen:
            continue
        seen.add(key)
        records.append((allrecord_search_entry_type(entry), record))
    return records


def search_cache_prewarm_lock_is_stale(lock_file: Path) -> bool:
    """Detect stale prewarm locks so abandoned background jobs do not block future warming."""
    try:
        return time.time() - lock_file.stat().st_mtime > PREWARM_LOCK_STALE_SECONDS
    except OSError:
        return True


def write_search_cache_prewarm_lock(lock_file: Path) -> tuple[int, str]:
    """Write a lock file with process identity so cache warmers coordinate without a daemon."""
    token = f"{os.getpid()}:{time.time()}"
    fd = os.open(lock_file, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o600)
    try:
        os.write(fd, f"{token}\n".encode("ascii"))
    except OSError:
        os.close(fd)
        raise
    return fd, token


def acquire_search_cache_prewarm_lock() -> tuple[int, str] | None:
    """Acquire the background prewarm lock, removing stale locks when safe."""
    try:
        ensure_allrecords_cache_dir()
        lock_file = search_cache_prewarm_lock_file()
        try:
            return write_search_cache_prewarm_lock(lock_file)
        except FileExistsError:
            if not search_cache_prewarm_lock_is_stale(lock_file):
                return None
            try:
                lock_file.unlink()
            except FileNotFoundError:
                pass
            except OSError:
                return None
            try:
                return write_search_cache_prewarm_lock(lock_file)
            except FileExistsError:
                return None
    except OSError:
        return None


def release_search_cache_prewarm_lock(lock: tuple[int, str]) -> None:
    """Release the prewarm lock only when this process still owns it."""
    lock_fd, token = lock
    try:
        os.close(lock_fd)
    except OSError:
        pass

    lock_file = search_cache_prewarm_lock_file()
    try:
        if lock_file.read_text(encoding="utf-8").strip() == token:
            lock_file.unlink()
    except (FileNotFoundError, OSError):
        pass


def warm_global_search_cache(client: InfobloxClient) -> None:
    """Warm search cache for all zones so later search and completion are responsive."""
    zones = search_zones(client, None)

    def warm_zone(zone_info: dict[str, Any]) -> None:
        """Warm cache for one zone in the background prewarm pool so later completions/searches are faster."""
        try:
            allrecords_search_entries_for_zone(clone_infoblox_client(client), zone_info)
        except (CliError, WapiError, OSError, sqlite3.Error, ValueError):
            return

    if len(zones) > 1:
        worker_count = min(DNS_SEARCH_WORKERS, len(zones))
        with ThreadPoolExecutor(max_workers=worker_count) as executor:
            list(executor.map(warm_zone, zones))
    elif zones:
        warm_zone(zones[0])


def run_search_cache_prewarm() -> None:
    """Run the background prewarm entrypoint with lock handling and best-effort config loading."""
    lock: tuple[int, str] | None = None
    try:
        config = load_config(required=False)
        if not config:
            return
        client = InfobloxClient(config)
        lock = acquire_search_cache_prewarm_lock()
        if lock is None:
            return
        warm_global_search_cache(client)
    except (CliError, WapiError, OSError, sqlite3.Error, ValueError):
        return
    finally:
        if lock is not None:
            release_search_cache_prewarm_lock(lock)


def start_search_cache_prewarm() -> None:
    """Start a detached cache warmer so foreground DNS writes are not delayed."""
    env = os.environ.copy()
    env.pop("_IB_COMPLETE", None)
    try:
        subprocess.Popen(
            [sys.executable, str(Path(__file__).resolve()), "_prewarm-search-cache"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            close_fds=True,
            env=env,
        )
    except (OSError, ValueError):
        return


def refresh_dns_cache_after_update() -> None:
    """Clear and prewarm DNS caches after mutations so subsequent reads see fresh data."""
    clear_dns_cache()
    start_search_cache_prewarm()


