def run_dns_create(
    record_type: str,
    value: str,
    name: str,
    zone: str | None,
    ttl: int | None,
    noptr: bool,
    comment: str | None,
) -> None:
    resolved_zone = None
    view = None
    object_type = None
    try:
        config = load_config()
        client = InfobloxClient(config)
        view = getattr(client, "view", config.get("dns_view", "default"))
        resolved_zone = resolve_dns_create_zone(config, client, record_type, name, zone)
        object_type, payload = create_payload(record_type, value, name, resolved_zone, ttl, comment, client)
        ref = client.request("POST", object_type, payload=payload)
    except CliError as exc:
        error_message = str(exc)
        context = dns_create_error_context(
            record_type,
            value,
            name,
            zone,
            ttl,
            noptr,
            comment,
            resolved_zone=resolved_zone,
            view=view,
            object_type=object_type,
            error_message=error_message,
        )
        raise DnsCreateError(error_message, context) from exc
    if noptr and record_type.lower() not in {"a", "aaaa"}:
        print_warning("WARNING: --noptr only applies to A/AAAA workflows and was ignored.")
    print_success(f"SUCCESS: created {record_type.upper()} record")
    print_note(f"Reference: {ref}")


