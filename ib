def is_bash_completion() -> bool:
    return os.environ.get("_IB_COMPLETE", "").startswith("bash_")


def append_active_zone_help(item_help: str | None, active_zone_help: str) -> str:
    if not item_help:
        return active_zone_help
    return f"{item_help} {active_zone_help}."


class DnsGroup(UsageContextGroup):
    def shell_complete(self, ctx: click.Context, incomplete: str) -> list[CompletionItem]:
        items = super().shell_complete(ctx, incomplete)

        zone_help = active_zone_completion_help()
        if is_bash_completion():
            if incomplete:
                return items
            return [CompletionItem(active_zone_completion_value(), help=zone_help), *items]

        for item in items:
            if item.type == "plain" and str(item.value) in self.commands:
                item.help = append_active_zone_help(item.help, zone_help)
        return items


class RootGroup(UsageContextGroup):
    def shell_complete(self, ctx: click.Context, incomplete: str) -> list[CompletionItem]:
        items = super().shell_complete(ctx, incomplete)
        if not incomplete:
            start_search_cache_prewarm()
        return items


def normalize_ttl(ttl: int | None) -> int | None:
    if ttl is None:
        return None
    if isinstance(ttl, bool) or not isinstance(ttl, int):
        raise CliError("ERROR: ttl must be an integer.")
    if ttl < 0:
        raise CliError("ERROR: ttl must be 0 or greater.")
    return ttl


def ttl_payload(ttl: int | None) -> dict[str, Any]:
    normalized = normalize_ttl(ttl)
    if normalized is None:
        return {}
    return {"ttl": normalized, "use_ttl": True}


def normalize_record_comment(comment: str | None) -> str | None:
    if comment is None:
        return None
    normalized = comment.strip()
    if not normalized:
        return None
    if not COMMENT_ALLOWED_RE.fullmatch(normalized):
        raise CliError(
            "ERROR: comment may only contain letters, numbers, spaces, and common punctuation "
            ".,_-:;@#%+=/()[]'&"
        )
    return normalized


def click_error_text(error: CliError) -> str:
    message = str(error)
    return message[7:] if message.startswith("ERROR: ") else message


def validate_ttl_option(
    ctx: click.Context,
    param: click.Parameter,
    value: int | None,
) -> int | None:
    try:
        return normalize_ttl(value)
    except CliError as exc:
        raise click.BadParameter(click_error_text(exc), ctx=ctx, param=param) from exc


def validate_record_comment_option(
    ctx: click.Context,
    param: click.Parameter,
    value: str | None,
) -> str | None:
    try:
        return normalize_record_comment(value)
    except CliError as exc:
        raise click.BadParameter(click_error_text(exc), ctx=ctx, param=param) from exc


def mx_payload(value: str) -> dict[str, Any]:
    parts = value.split()
    if len(parts) != 2 or not parts[0].isdigit():
        raise CliError("ERROR: MX value must be quoted as '<preference> <mail_exchanger>'.")
    return {"preference": int(parts[0]), "mail_exchanger": parts[1].rstrip(".")}


def ptr_payload(name: str, value: str) -> dict[str, Any]:
    field = "ipv6addr" if ":" in name else "ipv4addr"
    return {field: name, "ptrdname": value.rstrip(".")}


def host_payload(value: str) -> dict[str, Any]:
    try:
        address = ipaddress.ip_address(value)
    except ValueError:
        raise CliError("ERROR: host value must be an IPv4 or IPv6 address.")

    if address.version == 4:
        return {"ipv4addrs": [{"ipv4addr": str(address)}]}
    return {"ipv6addrs": [{"ipv6addr": str(address)}]}


def create_payload(
    record_type: str,
    value: str,
    name: str,
    zone: str,
    ttl: int | None,
    comment: str | None,
    client: InfobloxClient,
) -> tuple[str, dict[str, Any]]:
    record_type = record_type.lower()
    spec = RECORD_TYPES.get(record_type)
    if not spec:
        supported = ", ".join(sorted(RECORD_TYPES))
        raise CliError(f"ERROR: unsupported record type '{record_type}'. Supported: {supported}")

    object_type = spec["object"]
    fqdn_name = fqdn(name, zone)
    record_comment = normalize_record_comment(comment)
    payload: dict[str, Any] = {
        "name": fqdn_name,
        "view": client.view,
        **ttl_payload(ttl),
    }
    if record_comment:
        payload["comment"] = record_comment

    if record_type == "mx":
        payload.update(mx_payload(value))
    elif record_type == "host":
        payload.update(host_payload(value))
    elif record_type == "ptr":
        payload = {
            **ptr_payload(name, value),
            "view": client.view,
            **ttl_payload(ttl),
        }
        if record_comment:
            payload["comment"] = record_comment
    else:
        value_field = spec["value_field"]
        payload[value_field] = value.rstrip(".") if record_type == "cname" else value

    return object_type, payload


def dns_create_target_name(name: str, resolved_zone: str | None) -> str | None:
    if not resolved_zone:
        return None
    try:
        return fqdn(name, resolved_zone)
    except CliError:
        return None


def dns_create_error_hint(error_message: str | None, context: dict[str, Any]) -> str | None:
    if not error_message:
        return None

    network_match = re.search(
        r"The IP address (?P<ip>\S+) cannot be used for the zone (?P<zone>.+?)\. "
        r"Verify the network association",
        error_message,
        flags=re.IGNORECASE,
    )
    if network_match:
        ip_address = network_match.group("ip")
        zone_name = network_match.group("zone")
        record_type = str(context.get("record_type") or "record").upper()
        return (
            f"Infoblox rejected the {record_type} record because IP address {ip_address} is not "
            f"allowed for DNS zone {zone_name}. Use an IP associated with that zone, choose the "
            "correct zone with --zone or a fully qualified -n name, or update the zone network "
            "association in Infoblox."
        )

    return None


def dns_create_error_context(
    record_type: str,
    value: str,
    name: str,
    zone: str | None,
    ttl: int | None,
    noptr: bool,
    comment: str | None,
    resolved_zone: str | None = None,
    view: str | None = None,
    object_type: str | None = None,
    error_message: str | None = None,
) -> dict[str, Any]:
    context_status = dns_context_status()
    if view:
        context_status["view"] = view
        context_status["view_source"] = "configured"
    context = {
        "record_type": record_type,
        "value": value,
        "--name": name,
        "--zone": zone,
        "target_record": dns_create_target_name(name, resolved_zone),
        "view": context_status["view"],
        "view_source": context_status["view_source"],
        "active_zone": context_status["active_zone"],
        "active_zone_source": context_status["active_zone_source"],
        "has_active_zone": context_status["has_active_zone"],
        "resolved_zone": resolved_zone,
        "-t/--ttl": ttl,
        "--noptr": noptr,
        "-c/--comment": comment,
        "wapi_object": object_type,
    }
    hint = dns_create_error_hint(error_message, context)
    if hint:
        context["hint"] = hint
    return context


def dns_create_error_value(value: Any) -> Text:
    if value is None or value == "":
        return Text("not set", style="yellow")
    if isinstance(value, bool):
        return Text("true" if value else "false", style="green" if value else "dim")
    return Text(str(value).replace("\n", "\\n"), style="white")


