def read_zone_completion_cache(view: str) -> ZoneCompletionCacheRead | None:
    """Read zone completion cache and flag stale entries for background refresh."""
    try:
        with ZONE_COMPLETION_CACHE_FILE.open("r", encoding="utf-8") as handle:
            cache = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(cache, dict) or cache.get("view") != view:
        return None

    created_at = cache.get("created_at")
    if not isinstance(created_at, (int, float)):
        return None
    max_age = ZONE_COMPLETION_CACHE_TTL + ZONE_COMPLETION_CACHE_STALE_WHILE_REVALIDATE_SECONDS
    age = time.time() - created_at
    if age > max_age:
        return None

    zones = cache.get("zones")
    if not isinstance(zones, list):
        return None
    names = sorted({zone for zone in zones if isinstance(zone, str) and zone}, key=str.lower)
    return ZoneCompletionCacheRead(
        names=names,
        should_revalidate=age > ZONE_COMPLETION_CACHE_TTL,
    )


def write_zone_completion_cache(view: str, names: list[str]) -> None:
    """Write zone completion cache best-effort so completion remains non-blocking on failures."""
    try:
        ensure_config_dir()
        with ZONE_COMPLETION_CACHE_FILE.open("w", encoding="utf-8") as handle:
            json.dump(
                {
                    "created_at": time.time(),
                    "view": view,
                    "zones": names,
                },
                handle,
            )
        os.chmod(ZONE_COMPLETION_CACHE_FILE, 0o600)
    except OSError:
        return


def cached_or_live_zone_completion_names(client: InfobloxClient) -> list[str]:
    """Return zone completion names, serving stale cache while refreshing in the background."""
    cached = read_zone_completion_cache(client.view)
    if cached is not None:
        if cached.should_revalidate:
            start_zone_completion_cache_revalidation(client.view)
        return cached.names
    return refresh_zone_completion_names(client)


