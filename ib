def zone_names_from_results(zones: list[dict[str, Any]]) -> list[str]:
    return sorted({str(zone.get("fqdn", "")) for zone in zones if zone.get("fqdn")}, key=str.lower)


def filter_zone_names(names: list[str], incomplete: str) -> list[str]:
    normalized_incomplete = incomplete.lower()
    if not normalized_incomplete:
        return names
    return [name for name in names if name.lower().startswith(normalized_incomplete)]


def read_zone_completion_cache(view: str) -> list[str] | None:
    try:
        with ZONE_COMPLETION_CACHE_FILE.open("r", encoding="utf-8") as handle:
            cache = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(cache, dict) or cache.get("view") != view:
        return None

    created_at = cache.get("created_at")
    if not isinstance(created_at, (int, float)):
        return None
    if time.time() - created_at > ZONE_COMPLETION_CACHE_TTL:
        return None

    zones = cache.get("zones")
    if not isinstance(zones, list):
        return None
    return sorted({zone for zone in zones if isinstance(zone, str) and zone}, key=str.lower)


def write_zone_completion_cache(view: str, names: list[str]) -> None:
    try:
        CONFIG_DIR.mkdir(mode=0o700, exist_ok=True)
        os.chmod(CONFIG_DIR, 0o700)
        with ZONE_COMPLETION_CACHE_FILE.open("w", encoding="utf-8") as handle:
            json.dump(
                {
                    "created_at": time.time(),
                    "view": view,
                    "zones": names,
                },
                handle,
            )
        os.chmod(ZONE_COMPLETION_CACHE_FILE, 0o600)
    except OSError:
        return


def complete_zone_names(
    ctx: click.Context,
    param: click.Parameter,
    incomplete: str,
) -> list[str]:
    try:
        config = load_config(required=False)
        if not config:
            return []
        client = InfobloxClient(config)
        names = read_zone_completion_cache(client.view)
        if names is None:
            zones = paged_query(
                client,
                ZONE_OBJECT,
                zone_query_params(client),
                warn_on_skip=False,
            )
            names = zone_names_from_results(zones)
            write_zone_completion_cache(client.view, names)
    except (CliError, OSError, ValueError):
        return []

    return filter_zone_names(names, incomplete)


def format_record(record_type: str, item: dict[str, Any]) -> str:
    value_keys = ("ipv4addr", "ipv6addr", "canonical", "text", "mail_exchanger", "ptrdname")
    value = next((str(item[key]) for key in value_keys if key in item), "")
    if record_type == "mx" and "preference" in item and value:
        value = f"{item['preference']} {value}"

    ttl = item.get("ttl", "")
    comment = item.get("comment", "")
    zone = item.get("zone", "")
    parts = [
        record_type.upper().ljust(5),
        str(item.get("name", "")).ljust(40),
        value.ljust(30),
        f"zone={zone}" if zone else "",
        f"ttl={ttl}" if ttl != "" else "",
        f"comment={comment}" if comment else "",
        f"ref={item.get('_ref')}" if item.get("_ref") else "",
    ]
    return "  ".join(part for part in parts if part)


def record_value(record_type: str, item: dict[str, Any]) -> str:
    if item.get("type"):
        return allrecord_display_value(record_type, item)

    if item.get("address"):
        return str(item["address"])
    if item.get("record"):
        return str(item["record"])

    if record_type == "host":
        values = []
        for key, nested_key in (("ipv4addrs", "ipv4addr"), ("ipv6addrs", "ipv6addr")):
            for address in item.get(key, []) or []:
                if isinstance(address, dict) and address.get(nested_key):
                    values.append(str(address[nested_key]))
                elif isinstance(address, str):
                    values.append(address)
        return ", ".join(values)

    value_keys = ("ipv4addr", "ipv6addr", "canonical", "text", "mail_exchanger", "ptrdname")
    value = next((str(item[key]) for key in value_keys if key in item), "")
    if record_type == "mx" and "preference" in item and value:
        return f"{item['preference']} {value}"
    return value


def record_name(item: dict[str, Any]) -> str:
    if item.get("type"):
        return allrecord_display_name(item)
    return str(item.get("name", ""))


def record_table(records: list[tuple[str, dict[str, Any]]], include_ref: bool = False) -> Table:
    table = Table(title=f"DNS Records ({len(records)})", header_style="bold cyan")
    table.add_column("Type", style="bold", no_wrap=True)
    table.add_column("Name", overflow="fold")
    table.add_column("Value", overflow="fold")
    table.add_column("Zone", overflow="fold")
    table.add_column("TTL", justify="right", no_wrap=True)
    table.add_column("Comment", overflow="fold")
    if include_ref:
        table.add_column("Ref", overflow="fold")

    for record_type, item in records:
        row = [
            record_type.upper(),
            record_name(item),
            record_value(record_type, item),
            str(item.get("zone", "")),
            str(item.get("ttl", "")),
            str(item.get("comment", "")),
        ]
        if include_ref:
            row.append(str(item.get("_ref", "")))
        table.add_row(*row)
    return table


def zone_table(zones: list[dict[str, Any]], include_ref: bool = False) -> Table:
    table = Table(title=f"DNS Zones ({len(zones)})", header_style="bold cyan")
    table.add_column("Zone", overflow="fold")
    table.add_column("View", overflow="fold")
    table.add_column("Format", no_wrap=True)
    table.add_column("NS Group", overflow="fold")
    table.add_column("Comment", overflow="fold")
    if include_ref:
        table.add_column("Ref", overflow="fold")

    for item in zones:
        row = [
            str(item.get("fqdn", "")),
            str(item.get("view", "")),
            str(item.get("zone_format", "")),
            str(item.get("ns_group", "")),
            str(item.get("comment", "")),
        ]
        if include_ref:
            row.append(str(item.get("_ref", "")))
        table.add_row(*row)
    return table


def format_zone_detail_value(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, list):
        return "\n".join(
            formatted for item in value if (formatted := format_zone_detail_value(item))
        )
    if isinstance(value, dict):
        mname = value.get("mname") or value.get("soa_mname") or value.get("host_name")
        member = value.get("member") or value.get("name")
        if mname:
            return f"{mname} ({member})" if member else str(mname)

        parts = []
        for key, item in sorted(value.items()):
            formatted = format_zone_detail_value(item)
            if formatted:
                parts.append(f"{key.replace('_', ' ')}: {formatted}")
        return ", ".join(parts)
    return str(value)


def zone_detail_table(zone_info: dict[str, Any]) -> Table:
    zone_name = str(zone_info.get("fqdn", ""))
    table = Table(title=f"DNS Zone: {zone_name}", header_style="bold cyan")
    table.add_column("Field", style="bold cyan", no_wrap=True)
    table.add_column("Value", overflow="fold")

    fields = [
        ("Zone", "fqdn"),
        ("View", "view"),
        ("Format", "zone_format"),
        ("NS Group", "ns_group"),
        ("Serial Number", "soa_serial_number"),
        ("SOA MNAME", "member_soa_mnames"),
        ("SOA RNAME", "soa_email"),
        ("Refresh", "soa_refresh"),
        ("Retry", "soa_retry"),
        ("Expiry", "soa_expire"),
        ("Negative Caching TTL", "soa_negative_ttl"),
        ("Comment", "comment"),
        ("Ref", "_ref"),
    ]
    for label, key in fields:
        table.add_row(label, format_zone_detail_value(zone_info.get(key)))
    return table


@click.group(cls=UsageContextGroup, context_settings={"help_option_names": ["-h", "--help"]})
def cli() -> None:
    """Infoblox command line client."""


@cli.command()
def configure() -> None:
    """Create or update ~/.ib/config."""
    save_config_interactive()


@cli.command()
@click.argument("shell", required=False, type=click.Choice(COMPLETION_SHELLS))
def completion(shell: str | None) -> None:
    """Print shell completion setup instructions."""
    shells = (shell,) if shell else COMPLETION_SHELLS
    console.print(
        Panel.fit(
            "Enable tab completion for ib commands, options, DNS record types, and active zone hints.",
            title="ib shell completion setup",
            border_style="cyan",
        )
    )
    console.print("[bold]Prerequisite[/bold]")
    console.print("Make sure the ib executable is on your PATH.")
    print_command_block(
        [
            "mkdir -p ~/.local/bin",
            "install -m 755 ./ib ~/.local/bin/ib",
            "export PATH=\"$HOME/.local/bin:$PATH\"",
        ]
    )
    for item in shells:
        if item == "bash":
            console.rule("[bold cyan]Bash[/bold cyan]")
            console.print("[bold]Current shell only[/bold]")
            print_command_block(['eval "$(_IB_COMPLETE=bash_source ib)"'])
            console.print("[bold]Persistent setup[/bold]")
            print_command_block(
                [
                    "_IB_COMPLETE=bash_source ib > ~/.ib-complete.bash",
                    "printf '\\n# ib completion\\n. ~/.ib-complete.bash\\n' >> ~/.bashrc",
                    "exec bash",
                ]
            )
        elif item == "zsh":
            console.rule("[bold cyan]Zsh[/bold cyan]")
            console.print("[bold]Current shell only[/bold]")
            print_command_block(['eval "$(_IB_COMPLETE=zsh_source ib)"'])
            console.print("[bold]Persistent setup[/bold]")
            print_command_block(
                [
                    "_IB_COMPLETE=zsh_source ib > ~/.ib-complete.zsh",
                    "printf '\\n# ib completion\\n. ~/.ib-complete.zsh\\n' >> ~/.zshrc",
                    "exec zsh",
                ]
            )
        elif item == "fish":
            console.rule("[bold cyan]Fish[/bold cyan]")
            console.print("[bold]Current shell only[/bold]")
            print_command_block(["_IB_COMPLETE=fish_source ib | source"])
            console.print("[bold]Persistent setup[/bold]")
            print_command_block(
                [
                    "mkdir -p ~/.config/fish/completions",
                    "_IB_COMPLETE=fish_source ib > ~/.config/fish/completions/ib.fish",
                    "exec fish",
                ]
            )
    console.rule("[bold cyan]Verify[/bold cyan]")
    print_command_block(["ib <TAB><TAB>", "ib dns create <TAB><TAB>"])


