def dns_delete_completion_help(record_type: str, item: dict[str, Any]) -> str:
    """Build delete completion help text that explains what each candidate would remove."""
    parts = [record_type.upper()]
    value = record_value(record_type, item)
    zone = str(item.get("zone", ""))
    comment = str(item.get("comment", ""))
    if value:
        parts.append(value)
    if zone:
        parts.append(f"zone={zone}")
    if comment:
        parts.append(comment)
    return " | ".join(parts)


