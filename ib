def complete_dns_edit_record_types(
    ctx: click.Context,
    param: click.Parameter,
    incomplete: str,
) -> list[CompletionItem]:
    """Complete only existing record types for the selected name because Infoblox cannot change type."""
    record_name_value = str(ctx.params.get("record_name", "")).strip()
    if not record_name_value:
        return []

    try:
        config = load_config(required=False)
        if not config:
            return []
        client = InfobloxClient(config)
        _target, matches, _all_matches = dns_edit_matches(
            config,
            client,
            None,
            record_name_value,
            None,
        )
    except (CliError, OSError, ValueError, sqlite3.Error):
        return []

    items: list[CompletionItem] = []
    seen: set[str] = set()
    normalized_incomplete = incomplete.lower()
    for record_type, item in matches:
        if record_type in seen or not record_type.startswith(normalized_incomplete):
            continue
        seen.add(record_type)
        items.append(
            CompletionItem(
                record_type,
                help=f"Existing {record_type.upper()} record: {record_value(record_type, item)}",
            )
        )
    return items


def zone_table(zones: list[dict[str, Any]], include_ref: bool = False) -> Table:
    """Build the Rich zone table, showing refs only when ambiguity resolution requires them."""
    table = Table(title=f"DNS Zones ({len(zones)})", header_style="bold cyan")
    table.add_column("Zone", overflow="fold")
    table.add_column("View", overflow="fold")
    table.add_column("Format", no_wrap=True)
    table.add_column("NS Group", overflow="fold")
    table.add_column("Comment", overflow="fold")
    if include_ref:
        table.add_column("Ref", overflow="fold")

    for item in zones:
        row = [
            str(item.get("fqdn", "")),
            str(item.get("view", "")),
            str(item.get("zone_format", "")),
            str(item.get("ns_group", "")),
            str(item.get("comment", "")),
        ]
        if include_ref:
            row.append(str(item.get("_ref", "")))
        table.add_row(*row)
    return table


def format_zone_detail_value(value: Any) -> str:
    """Format nested zone detail values into readable table text."""
    if value is None:
        return ""
    if isinstance(value, list):
        return "\n".join(
            formatted for item in value if (formatted := format_zone_detail_value(item))
        )
    if isinstance(value, dict):
        mname = value.get("mname") or value.get("soa_mname") or value.get("host_name")
        member = value.get("member") or value.get("name")
        if mname:
            return f"{mname} ({member})" if member else str(mname)

        parts = []
        for key, item in sorted(value.items()):
            formatted = format_zone_detail_value(item)
            if formatted:
                parts.append(f"{key.replace('_', ' ')}: {formatted}")
        return ", ".join(parts)
    return str(value)


def format_network_association(value: Any) -> str:
    """Format network association details with useful fallbacks for incomplete WAPI data."""
    if value is None:
        return ""
    if isinstance(value, list):
        return "\n".join(
            formatted for item in value if (formatted := format_network_association(item))
        )
    if isinstance(value, dict):
        network = value.get("network") or value.get("address") or value.get("_ref")
        if not network:
            return format_zone_detail_value(value)

        details = []
        if value.get("network_view"):
            details.append(f"view: {value['network_view']}")
        if value.get("comment"):
            details.append(f"comment: {value['comment']}")
        if details:
            return f"{network} ({', '.join(details)})"
        return str(network)
    return str(value)


def zone_detail_output_row(zone_info: dict[str, Any]) -> dict[str, Any]:
    """Convert zone detail into the structured output schema used by JSON and CSV modes."""
    return {
        "zone": zone_info.get("fqdn", ""),
        "view": zone_info.get("view", ""),
        "format": zone_info.get("zone_format", ""),
        "ns_group": zone_info.get("ns_group", ""),
        "network_view": zone_info.get("network_view", ""),
        "network_associations": zone_info.get("network_associations", ""),
        "serial_number": zone_info.get("soa_serial_number", ""),
        "soa_mname": zone_info.get("member_soa_mnames", ""),
        "soa_rname": zone_info.get("soa_email", ""),
        "refresh": zone_info.get("soa_refresh", ""),
        "retry": zone_info.get("soa_retry", ""),
        "expiry": zone_info.get("soa_expire", ""),
        "negative_caching_ttl": zone_info.get("soa_negative_ttl", ""),
        "comment": zone_info.get("comment", ""),
    }


def emit_zone_detail(zone_info: dict[str, Any]) -> None:
    """Emit zone detail through the structured output helper so filtering and field order stay shared."""
    emit_structured(zone_detail_output_row(zone_info), ZONE_DETAIL_OUTPUT_FIELDS)


def zone_detail_table(zone_info: dict[str, Any]) -> Table:
    """Build the Rich zone-detail table with SOA, association, comment, and reference data."""
    zone_name = str(zone_info.get("fqdn", ""))
    table = Table(title=f"DNS Zone: {zone_name}", header_style="bold cyan")
    table.add_column("Field", style="bold cyan", no_wrap=True)
    table.add_column("Value", overflow="fold")

    fields = [
        ("Zone", "fqdn"),
        ("View", "view"),
        ("Format", "zone_format"),
        ("NS Group", "ns_group"),
        ("Network View", "network_view"),
        ("Network Associations", "network_associations"),
        ("Serial Number", "soa_serial_number"),
        ("SOA MNAME", "member_soa_mnames"),
        ("SOA RNAME", "soa_email"),
        ("Refresh", "soa_refresh"),
        ("Retry", "soa_retry"),
        ("Expiry", "soa_expire"),
        ("Negative Caching TTL", "soa_negative_ttl"),
        ("Comment", "comment"),
        ("Ref", "_ref"),
    ]
    for label, key in fields:
        formatter = format_network_association if key == "network_associations" else format_zone_detail_value
        table.add_row(label, formatter(zone_info.get(key)))
    return table


