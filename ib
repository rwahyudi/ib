def format_zone_detail_value(value: Any) -> str:
    """Format nested zone detail values into readable table text."""
    if value is None:
        return ""
    if isinstance(value, list):
        return "\n".join(
            formatted for item in value if (formatted := format_zone_detail_value(item))
        )
    if isinstance(value, dict):
        mname = value.get("mname") or value.get("soa_mname") or value.get("host_name")
        member = value.get("member") or value.get("name")
        if mname:
            return f"{mname} ({member})" if member else str(mname)

        parts = []
        for key, item in sorted(value.items()):
            formatted = format_zone_detail_value(item)
            if formatted:
                parts.append(f"{key.replace('_', ' ')}: {formatted}")
        return ", ".join(parts)
    return str(value)


def format_network_association(value: Any) -> str:
    """Format network association details with useful fallbacks for incomplete WAPI data."""
    if value is None:
        return ""
    if isinstance(value, list):
        return "\n".join(
            formatted for item in value if (formatted := format_network_association(item))
        )
    if isinstance(value, dict):
        network = value.get("network") or value.get("address") or value.get("_ref")
        if not network:
            return format_zone_detail_value(value)

        details = []
        if value.get("network_view"):
            details.append(f"view: {value['network_view']}")
        if value.get("comment"):
            details.append(f"comment: {value['comment']}")
        if details:
            return f"{network} ({', '.join(details)})"
        return str(network)
    return str(value)


