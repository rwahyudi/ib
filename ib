    source: str | None,
    value_style: str,
    include_source: bool = True,
) -> Text:
    display_value = value or "not set"
    text = Text()
    text.append(display_value, style=value_style)
    if include_source and source:
        text.append(f" ({source})", style=DNS_CONTEXT_SOURCE_STYLE)
    return text


