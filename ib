    matches = safe_query(
        client,
        ZONE_OBJECT,
        zone_query_params(client, {"fqdn": target}, return_fields=ZONE_DETAIL_RETURN_FIELDS),
    )

    if not matches:
        raise CliError(f"ERROR: no DNS zone found for {target} in view {client.view}")
    if len(matches) > 1:
        print_error(f"ERROR: multiple zones found for {target}:")
        err_console.print(zone_table(matches, include_ref=True))
        raise CliError("ERROR: view target is ambiguous.")

    zone_info = dict(matches[0])
    add_zone_network_association_details(client, target, zone_info)
    if output_is_table():
        console.print(zone_detail_table(zone_info))
    else:
        emit_zone_detail(zone_info)


def run_dns_zone_delete(zone_name: str) -> None:
    """Run zone deletion only after resolving an unambiguous zone reference."""
    client = InfobloxClient(load_config())
    target = normalize_zone_name(zone_name)
    matches = safe_query(client, ZONE_OBJECT, zone_query_params(client, {"fqdn": target}))

    if not matches:
        raise CliError(f"ERROR: no DNS zone found for {target} in view {client.view}")
    if len(matches) > 1:
        print_error(f"ERROR: multiple zones found for {target}. Delete one of these _ref values manually:")
        err_console.print(zone_table(matches, include_ref=True))
        raise CliError("ERROR: delete target is ambiguous.")

    ref = matches[0].get("_ref")
    if not ref:
        raise CliError("ERROR: matched zone does not include an _ref.")
    client.request("DELETE", ref)
    refresh_dns_cache_after_update()
    if not output_is_table():
        emit_action_result(
            status="success",
            action="delete",
            type="ZONE",
            name=target,
            zone=target,
            view=client.view,
            ref=ref,
            message=f"deleted DNS zone {target}",
        )
        return
    print_success(f"SUCCESS: deleted DNS zone {target}")


