def prompt_manual_default_zone(default_zone: str = "") -> str:
    """Prompt for a default zone manually and normalize it only when the user entered a value."""
    value = Prompt.ask("Default DNS zone (optional)", default=default_zone).strip()
    return normalize_zone_name(value) if value else ""


def default_zone_name(zone: dict[str, Any]) -> str:
    """Return the zone fqdn as normalized display text for filtering, sorting, and saving."""
    return str(zone.get("fqdn", "")).strip()


def default_zone_sort_key(zone: dict[str, Any], search: str = "") -> tuple[int, str]:
    """Sort zone matches by starts-with priority first, then alphabetically by zone name."""
    name = default_zone_name(zone).lower()
    terms = [term for term in search.strip().lower().split() if term]
    prefix = terms[0] if terms else ""
    starts_with_rank = 0 if prefix and name.startswith(prefix) else 1
    if not prefix:
        starts_with_rank = 0
    return starts_with_rank, name


def selectable_zone_records(zones: list[dict[str, Any]]) -> list[dict[str, Any]]:
    """Return only forward zones with names, sorted so subdomains stay visible in stable order."""
    candidates = [
        zone
        for zone in zones
        if default_zone_name(zone) and is_forward_zone(zone)
    ]
    return sorted(candidates, key=default_zone_sort_key)


def filter_default_zone_candidates(
    zones: list[dict[str, Any]],
    search: str,
) -> list[dict[str, Any]]:
    """Filter already-fetched forward zones locally so live search avoids WAPI calls per keystroke."""
    terms = [term for term in search.strip().lower().split() if term]
    if not terms:
        return zones

    matches = []
    for zone in zones:
        searchable = " ".join(
            [
                str(zone.get("fqdn", "")),
                str(zone.get("comment", "")),
            ]
        ).lower()
        if all(term in searchable for term in terms):
            matches.append(zone)
    return sorted(matches, key=lambda zone: default_zone_sort_key(zone, search))


def default_zone_selection_index(zones: list[dict[str, Any]], default_zone: str = "") -> int:
    """Return the index of the current default zone so edit prompts can highlight it."""
    if not default_zone:
        return 0
    try:
        normalized_default = normalize_zone_name(default_zone)
    except CliError:
        normalized_default = default_zone.strip().rstrip(".")
    if not normalized_default:
        return 0

    for index, zone in enumerate(zones):
        try:
            zone_name = normalize_zone_name(default_zone_name(zone))
        except CliError:
            continue
        if zone_name == normalized_default:
            return index
    return 0


def query_default_zone_candidates_for_config(config_values: dict[str, str]) -> list[dict[str, Any]]:
    """Connect with unsaved profile values and fetch forward authoritative zones for local live filtering."""
    client = InfobloxClient(config_values)
    try:
        return selectable_zone_records(query_zones(client))
    finally:
        client.close()


def render_default_zone_choices(zones: list[dict[str, Any]]) -> None:
    """Show default-zone candidates with numeric selectors so long zone names stay readable."""
    table = Table(title="Available DNS Zones", header_style="bold cyan")
    table.add_column("#", justify="right", no_wrap=True)
    table.add_column("Zone", overflow="fold")
    table.add_column("Format", no_wrap=True)
    table.add_column("Comment", overflow="fold")
    for index, zone in enumerate(zones, start=1):
        table.add_row(
            str(index),
            default_zone_name(zone),
