def ensure_config_dir() -> None:
    CONFIG_DIR.mkdir(mode=0o700, exist_ok=True)
    os.chmod(CONFIG_DIR, 0o700)


def read_config_key() -> bytes:
    if not CONFIG_KEY_FILE.exists():
        raise CliError(f"ERROR: missing encryption key file at {CONFIG_KEY_FILE}. Run: ib configure")
    try:
        key = CONFIG_KEY_FILE.read_bytes().strip()
        Fernet(key)
        os.chmod(CONFIG_KEY_FILE, 0o600)
        return key
    except (OSError, ValueError):
        raise CliError(f"ERROR: invalid encryption key file at {CONFIG_KEY_FILE}. Run: ib configure")


def get_or_create_config_key() -> bytes:
    ensure_config_dir()
    if CONFIG_KEY_FILE.exists():
        return read_config_key()

    key = Fernet.generate_key()
    try:
        with CONFIG_KEY_FILE.open("xb") as handle:
            handle.write(key)
            handle.write(b"\n")
        os.chmod(CONFIG_KEY_FILE, 0o600)
    except FileExistsError:
        return read_config_key()
    except OSError:
        raise CliError(f"ERROR: cannot write encryption key file at {CONFIG_KEY_FILE}. Run: ib configure")
    return key


def encrypt_password(password: str) -> str:
    token = Fernet(get_or_create_config_key()).encrypt(password.encode("utf-8")).decode("ascii")
    return f"{ENCRYPTED_PASSWORD_PREFIX}{token}"


def decrypt_password(password: str) -> str:
    if not password.startswith(ENCRYPTED_PASSWORD_PREFIX):
        return password

    token = password[len(ENCRYPTED_PASSWORD_PREFIX) :].encode("ascii")
    try:
        return Fernet(read_config_key()).decrypt(token).decode("utf-8")
    except (InvalidToken, OSError, UnicodeEncodeError, UnicodeDecodeError, ValueError):
        raise CliError(f"ERROR: cannot decrypt password in {CONFIG_FILE}. Run: ib configure")


def is_encrypted_password(password: str) -> bool:
    return password.startswith(ENCRYPTED_PASSWORD_PREFIX)


def write_config_values(config_values: dict[str, str]) -> None:
    ensure_config_dir()
    config = configparser.ConfigParser()
    config["default"] = {
        **config_values,
        "password": encrypt_password(config_values["password"]),
    }
    with CONFIG_FILE.open("w", encoding="utf-8") as handle:
        config.write(handle)
    os.chmod(CONFIG_FILE, 0o600)


def load_config_for_prompt() -> dict[str, str]:
    if not CONFIG_FILE.exists():
        return {}

    parser = configparser.ConfigParser()
    parser.read(CONFIG_FILE)
    if "default" not in parser:
        raise CliError(f"ERROR: missing [default] section in {CONFIG_FILE}")

    cfg = dict(parser["default"])
    if cfg.get("server"):
        cfg["server"] = normalize_server(cfg["server"])
    if cfg.get("password"):
        try:
            cfg["password"] = decrypt_password(cfg["password"])
        except CliError as exc:
            print_warning(str(exc))
            cfg.pop("password", None)
    return cfg


def save_config_interactive() -> None:
    current = load_config_for_prompt()
    console.print(
        Panel.fit(
            f"Configuration will be saved to [bold]{CONFIG_FILE}[/bold].\n"
            "You can run this multiple times; existing values are shown as defaults.\n"
            "Press Enter to keep a value, or leave the password blank to keep it unchanged.",
            title="Infoblox Configuration",
            border_style="cyan",
        )
    )

    server = normalize_server(prompt_text("Infoblox server", current.get("server")))
    username = prompt_text("Username", current.get("username"))
    if current.get("password"):
        password = Prompt.ask(
            "Password (leave blank to keep current)",
            default="",
            password=True,
            show_default=False,
        ) or current["password"]
    else:
        password = Prompt.ask("Password", password=True)
    if not username or not password:
        raise CliError("ERROR: username and password are required.")

    wapi_version = Prompt.ask(
        "WAPI version", default=current.get("wapi_version", DEFAULT_WAPI_VERSION)
    )
    dns_view = Prompt.ask("DNS view", default=current.get("dns_view", "default"))
    default_zone = Prompt.ask(
        "Default DNS zone (optional)",
        default=current.get("default_zone", ""),
    ).strip()
    if default_zone:
        default_zone = normalize_zone_name(default_zone)
    verify_ssl = Confirm.ask(
        "Verify SSL certificates",
        default=parse_bool(current.get("verify_ssl", "true")),
    )

    default_config = {
        "server": server,
        "username": username,
        "password": password,
        "wapi_version": wapi_version,
        "dns_view": dns_view,
        "default_zone": default_zone,
        "verify_ssl": "true" if verify_ssl else "false",
        "timeout": str(current.get("timeout", DEFAULT_TIMEOUT)),
    }
    write_config_values(default_config)

    print_success("SUCCESS: configuration saved.")


def maybe_prompt_configure() -> None:
    if not sys.stdin.isatty():
        raise CliError("ERROR: no configuration file found. Run: ib configure")
    print_warning(f"No configuration file found at {CONFIG_FILE}.")
    if not Confirm.ask("Run 'ib configure' now?", default=False):
        raise CliError("ERROR: no configuration file found. Run: ib configure")
    save_config_interactive()


def load_config(required: bool = True) -> dict[str, str] | None:
    if not CONFIG_FILE.exists():
        if required:
            maybe_prompt_configure()
        else:
            return None

    parser = configparser.ConfigParser()
    parser.read(CONFIG_FILE)
    if "default" not in parser:
        raise CliError(f"ERROR: missing [default] section in {CONFIG_FILE}")

    cfg = dict(parser["default"])
    for key in ("server", "username", "password"):
        if not cfg.get(key):
            raise CliError(f"ERROR: missing '{key}' in {CONFIG_FILE}")

    raw_password = cfg["password"]
    cfg["password"] = decrypt_password(raw_password)
    cfg["server"] = normalize_server(cfg["server"])
    cfg.setdefault("wapi_version", DEFAULT_WAPI_VERSION)
    cfg.setdefault("dns_view", "default")
    cfg.setdefault("default_zone", "")
    cfg.setdefault("verify_ssl", "true")
    cfg.setdefault("timeout", str(DEFAULT_TIMEOUT))
    if not is_encrypted_password(raw_password):
        write_config_values(cfg)
    return cfg


class InfobloxClient:
    def __init__(self, config: dict[str, str]) -> None:
        self.server = normalize_server(config["server"])
        self.wapi_version = config.get("wapi_version", DEFAULT_WAPI_VERSION).strip().lstrip("/")
        self.username = config["username"]
        self.password = config["password"]
        self.view = config.get("dns_view", "default")
        self.timeout = int(config.get("timeout", DEFAULT_TIMEOUT))
        self.verify_ssl = parse_bool(config.get("verify_ssl", "true"))

    def request(
        self,
        method: str,
        path: str,
        params: dict[str, Any] | None = None,
        payload: dict[str, Any] | None = None,
    ) -> Any:
        query = f"?{urllib.parse.urlencode(params)}" if params else ""
        quoted_path = urllib.parse.quote(path.lstrip("/"), safe="/:")
        url = f"{self.server}/wapi/{self.wapi_version}/{quoted_path}{query}"
        body = None
        headers = {
            "Accept": "application/json",
            "Authorization": "Basic "
            + base64.b64encode(f"{self.username}:{self.password}".encode()).decode(),
        }
        if payload is not None:
            body = json.dumps(payload).encode("utf-8")
            headers["Content-Type"] = "application/json"

        context = None if self.verify_ssl else ssl._create_unverified_context()
        request = urllib.request.Request(url, data=body, headers=headers, method=method)
        try:
            with urllib.request.urlopen(request, timeout=self.timeout, context=context) as response:
                raw = response.read().decode("utf-8")
        except urllib.error.HTTPError as exc:
            raw_error = exc.read().decode("utf-8", errors="replace")
            raise WapiError(
                f"ERROR: Infoblox WAPI {exc.code}: {format_wapi_error(raw_error)}",
                status=exc.code,
            ) from exc
        except urllib.error.URLError as exc:
            raise WapiError(f"ERROR: cannot reach Infoblox: {exc.reason}") from exc

        if not raw:
            return None
        return json.loads(raw)


def format_wapi_error(raw: str) -> str:
    try:
        parsed = json.loads(raw)
    except json.JSONDecodeError:
        return raw.strip() or "empty error response"
    return parsed.get("text") or parsed.get("Error") or json.dumps(parsed)


def fqdn(record_name: str, zone: str) -> str:
    name = record_name.strip().rstrip(".")
    zone_name = zone.strip().rstrip(".")
    if not name:
        raise CliError("ERROR: record name is required.")
    if not zone_name:
        raise CliError("ERROR: zone is required.")
    if name == "@":
        return zone_name
    if name == zone_name or name.endswith(f".{zone_name}"):
        return name
    return f"{name}.{zone_name}"


def normalize_zone_name(zone_name: str) -> str:
    normalized = zone_name.strip().rstrip(".")
    if not normalized:
        raise CliError("ERROR: zone is required.")
    return normalized


def default_zone_from_env() -> str | None:
    zone_name = os.environ.get(DEFAULT_ZONE_ENV, "").strip()
