def remember_output_format(
    ctx: click.Context,
    param: click.Parameter,
    value: str | None,
) -> None:
    """Copy command-local -o values to the root context so any placement affects the final output."""
    if not value:
        return None
    root = ctx.find_root()
    root.params["output_format"] = value.lower()
    root.ensure_object(dict)
    root.obj["output_format"] = value.lower()
    return None


def output_option_is_registered(command: click.Command) -> bool:
    """Check whether a Click command already has --output so recursive registration stays idempotent."""
    for param in command.params:
        if isinstance(param, click.Option) and "--output" in param.opts:
            return True
    return False


def command_output_option() -> click.Option:
    """Create the shared output option used on every command to preserve one global contract."""
    return click.Option(
        ["-o", "--output", "output_format"],
        type=click.Choice(STRUCTURED_OUTPUTS, case_sensitive=False),
        expose_value=False,
        callback=remember_output_format,
        help=OUTPUT_OPTION_HELP,
    )


def register_output_option_everywhere(command: click.Command) -> None:
    """Attach -o/--output recursively so users can place the global option at any command level."""
    if not output_option_is_registered(command):
        command.params.append(command_output_option())
    if isinstance(command, click.Group):
        for subcommand in command.commands.values():
            register_output_option_everywhere(subcommand)


