            str(zone.get("comment", "")),
        )
    console.print(table)


def default_zone_picker_renderable(
    zones: list[dict[str, Any]],
    search: str,
    selected_index: int,
) -> Group:
    """Build the live search box and filtered zone list shown by the terminal picker."""
    matches = filter_default_zone_candidates(zones, search)
    selected_index = max(0, min(selected_index, max(len(matches) - 1, 0)))
    start = max(0, selected_index - DEFAULT_ZONE_PICKER_LIMIT + 1)
    visible = matches[start : start + DEFAULT_ZONE_PICKER_LIMIT]

    search_text = Text()
    search_text.append("Search DNS zone: ", style="bold cyan")
    search_text.append(search or "<type to filter>", style=None if search else "dim")
    search_panel = Panel(search_text, title="Default DNS Zone")

    table = Table(
        title=f"Forward DNS Zones ({len(matches)} match{'es' if len(matches) != 1 else ''})",
        header_style="bold cyan",
    )
    table.add_column("", no_wrap=True)
    table.add_column("#", justify="right", no_wrap=True)
    table.add_column("Zone", overflow="fold")
    table.add_column("Comment", overflow="fold")

    if visible:
        for offset, zone in enumerate(visible, start=start):
            marker = ">" if offset == selected_index else ""
            table.add_row(
                marker,
                str(offset + 1),
                default_zone_name(zone),
                str(zone.get("comment", "")),
            )
    else:
        table.add_row("", "", "No matching forward zones", "")

    help_text = Text(
        "Type to filter; Up/Down selects; Enter saves the highlighted zone; Ctrl-D skips default zone.",
        style="dim",
    )
    return Group(search_panel, table, help_text)


def read_zone_picker_key() -> str:
    """Read one terminal key, folding arrow-key escape sequences into single logical values."""
    stdin_fd = sys.stdin.fileno()
    first = os.read(stdin_fd, 1)
    if not first:
        return ""
    char = first.decode(errors="ignore")
    if char != "\x1b":
        return char

    sequence = char
    deadline = time.monotonic() + 0.20
    while len(sequence) < 16:
        timeout = max(0.0, deadline - time.monotonic())
        if timeout <= 0 or not select.select([stdin_fd], [], [], timeout)[0]:
            break
        chunk = os.read(stdin_fd, 1)
        if not chunk:
            break
        sequence += chunk.decode(errors="ignore")
        if len(sequence) >= 3 and (sequence[-1].isalpha() or sequence.endswith("~")):
            break
    return normalize_zone_picker_key(sequence)


def normalize_zone_picker_key(sequence: str) -> str:
    """Normalize common terminal arrow-key variants so selection works across shells and emulators."""
    if not sequence.startswith("\x1b") or sequence == "\x1b":
        return sequence
    if sequence.endswith("A"):
        return "\x1b[A"
    if sequence.endswith("B"):
        return "\x1b[B"
    return sequence


def prompt_default_zone_realtime(zones: list[dict[str, Any]], default_zone: str = "") -> str:
    """Let users type-filter the forward-zone list with immediate updates before selecting a zone."""
    import termios
    import tty

    search = ""
    selected_index = default_zone_selection_index(zones, default_zone)
    stdin_fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(stdin_fd)
    try:
        tty.setcbreak(stdin_fd)
        with Live(
            default_zone_picker_renderable(zones, search, selected_index),
            console=console,
            refresh_per_second=12,
            transient=False,
        ) as live:
            while True:
                key = read_zone_picker_key()
                matches = filter_default_zone_candidates(zones, search)
                if key in {"\r", "\n"}:
                    if matches:
                        zone_name = default_zone_name(matches[selected_index])
                        return normalize_zone_name(zone_name)
                    continue
                if key == "\x03":
                    raise KeyboardInterrupt
                if key == "\x04":
                    return ""
                if key == "" or key == "\x1b":
                    pass
                elif key in {"\x7f", "\b"}:
                    search = search[:-1]
                    selected_index = 0
                elif key == "\x1b[A":
                    selected_index = max(0, selected_index - 1)
                elif key == "\x1b[B":
                    selected_index = min(max(len(matches) - 1, 0), selected_index + 1)
                elif key.startswith("\x1b"):
                    pass
                elif len(key) == 1 and key.isprintable():
                    search += key
                    selected_index = 0

                matches = filter_default_zone_candidates(zones, search)
                if selected_index >= len(matches):
                    selected_index = max(len(matches) - 1, 0)
                live.update(default_zone_picker_renderable(zones, search, selected_index))
    finally:
        termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_settings)
        console.print()


def terminal_supports_realtime_zone_picker() -> bool:
    """Return whether raw terminal input is available for the live default-zone picker."""
    if not sys.stdin.isatty() or not console.is_terminal:
        return False
    try:
        import termios  # noqa: F401
        import tty  # noqa: F401
    except ImportError:
        return False
    return True


def prompt_default_zone_from_list(zones: list[dict[str, Any]], default_zone: str = "") -> str:
    """Fallback zone selector for non-terminal sessions where live key handling is unavailable."""
    search = Prompt.ask("Search DNS zone (leave blank to list all)", default="").strip()
    matches = filter_default_zone_candidates(zones, search)
    if not matches:
        print_warning("WARNING: no matching forward DNS zones. Enter the default zone manually.")
        return prompt_manual_default_zone()

    render_default_zone_choices(matches)
    choices = [str(index) for index in range(1, len(matches) + 1)]
    default_index = default_zone_selection_index(matches, default_zone)
    selected = Prompt.ask("Select default DNS zone", choices=choices, default=choices[default_index])
    zone_name = default_zone_name(matches[int(selected) - 1])
    return normalize_zone_name(zone_name)


def prompt_default_zone_from_infoblox(config_values: dict[str, str], default_zone: str = "") -> str:
    """Optionally fetch forward zones and select one as the profile's default zone."""
    if not Confirm.ask("Configure a default DNS zone for this profile", default=True):
        return normalize_zone_name(default_zone) if default_zone else ""

    try:
        with infoblox_wait_spinner():
            zones = query_default_zone_candidates_for_config(config_values)
    except (CliError, OSError, ValueError) as exc:
        print_warning(f"WARNING: could not load DNS zones from Infoblox: {exc}")
        return prompt_manual_default_zone(default_zone)

    if not zones:
        print_warning("WARNING: Infoblox returned no forward DNS zones. Enter the default zone manually.")
        return prompt_manual_default_zone(default_zone)

    if terminal_supports_realtime_zone_picker():
        return prompt_default_zone_realtime(zones, default_zone)
    return prompt_default_zone_from_list(zones, default_zone)


def save_config_interactive(
    profile_name: str | None = None,
    create: bool = False,
    make_default: bool = False,
) -> None:
    """Collect and save one profile, probing views and optional zones for new profiles."""
    if CONFIG_FILE.exists():
        default_profile, profiles, _legacy = read_config_profiles()
    else:
        default_profile, profiles = DEFAULT_PROFILE_NAME, {}

    selected_profile = normalize_profile_name(profile_name or default_profile)
    is_new_profile = create or selected_profile not in profiles
    if create and selected_profile in profiles:
        raise CliError(f"ERROR: profile '{selected_profile}' already exists.")
    if not create and selected_profile not in profiles and (profiles or profile_name is not None):
        raise CliError(f"ERROR: profile '{selected_profile}' does not exist.")

    had_profiles = bool(profiles)
    current = {} if create else dict(profiles.get(selected_profile, {}))
    if current.get("password"):
        try:
            current["password"] = decrypt_password(current["password"])
        except CliError as exc:
            print_warning(str(exc))
            current.pop("password", None)
    profile_action = "Create" if is_new_profile else "Edit"
    console.print(
        Panel.fit(
            f"{profile_action} profile [bold]{selected_profile}[/bold] in [bold]{CONFIG_FILE}[/bold].\n"
            "You can run this multiple times; existing values are shown as defaults.\n"
            "Press Enter to keep a value, or leave the password blank to keep it unchanged.",
            title="Infoblox Configuration",
            border_style="cyan",
        )
    )

    server = normalize_server(prompt_text("Infoblox server", current.get("server")))
    username = prompt_text("Username", current.get("username"))
    if current.get("password"):
        password = (
            prompt_password("Password (leave blank to keep current)", allow_blank=True)
            or current["password"]
        )
    else:
        password = prompt_password("Password")
    if not username or not password:
        raise CliError("ERROR: username and password are required.")

    wapi_version = Prompt.ask(
        "WAPI version", default=current.get("wapi_version", DEFAULT_WAPI_VERSION)
    )
    verify_ssl = Confirm.ask(
        "Verify SSL certificates",
        default=parse_bool(current.get("verify_ssl", "true")),
    )
    probe_config = {
        "server": server,
        "username": username,
        "password": password,
        "wapi_version": wapi_version,
        "dns_view": current.get("dns_view", "default"),
        "verify_ssl": "true" if verify_ssl else "false",
        "timeout": str(current.get("timeout", DEFAULT_TIMEOUT)),
    }
    if is_new_profile:
        dns_view = prompt_dns_view_from_infoblox(
            probe_config,
            current.get("dns_view", "default"),
        )
    else:
        dns_view = Prompt.ask("DNS view", default=current.get("dns_view", "default"))
    probe_config["dns_view"] = dns_view
    default_zone = prompt_default_zone_from_infoblox(
        probe_config,
        current.get("default_zone", ""),
    )

    default_config = {
        "server": server,
        "username": username,
        "password": password,
        "wapi_version": wapi_version,
        "dns_view": dns_view,
        "default_zone": default_zone,
        "verify_ssl": "true" if verify_ssl else "false",
        "timeout": str(current.get("timeout", DEFAULT_TIMEOUT)),
    }
    profiles[selected_profile] = default_config
    if make_default or not had_profiles:
        default_profile = selected_profile
    write_config_profiles(default_profile, profiles)

    if default_profile == selected_profile:
        print_success(f"SUCCESS: profile '{selected_profile}' saved and set as default.")
    else:
        print_success(f"SUCCESS: profile '{selected_profile}' saved.")


def set_default_profile(profile_name: str) -> None:
    """Set the default profile without editing profile values."""
    selected_profile = normalize_profile_name(profile_name)
    default_profile, profiles, _legacy = read_config_profiles()
    if selected_profile not in profiles:
        raise CliError(f"ERROR: profile '{selected_profile}' does not exist.")
    write_config_profiles(selected_profile, profiles)
    message = f"default profile set to '{selected_profile}'"
    if output_is_table():
        print_success(f"SUCCESS: {message}.")
    else:
        emit_structured(
            {
                "status": "success",
                "action": "use",
                "profile": selected_profile,
                "default": True,
                "message": message,
            },
            ["status", "action", "profile", "default", "message"],
        )


def delete_config_profile(profile_name: str) -> None:
    """Delete a non-default profile while refusing to leave config without a default."""
    selected_profile = normalize_profile_name(profile_name)
    default_profile, profiles, _legacy = read_config_profiles()
    if selected_profile not in profiles:
        raise CliError(f"ERROR: profile '{selected_profile}' does not exist.")
    if selected_profile == default_profile:
        raise CliError(
            f"ERROR: cannot delete default profile '{selected_profile}'. "
            "Run: ib configure use OTHER_PROFILE"
        )
    del profiles[selected_profile]
    write_config_profiles(default_profile, profiles)
    message = f"profile '{selected_profile}' deleted"
    if output_is_table():
        print_success(f"SUCCESS: {message}.")
    else:
        emit_structured(
            {
                "status": "success",
                "action": "delete",
                "profile": selected_profile,
                "default": False,
                "message": message,
            },
            ["status", "action", "profile", "default", "message"],
        )


def profile_table(default_profile: str, profiles: dict[str, dict[str, str]]) -> Table:
    """Build the profile list table without exposing passwords."""
    table = Table(title=f"Infoblox Profiles ({len(profiles)})", header_style="bold cyan")
    table.add_column("Profile", style="bold")
    table.add_column("Default", no_wrap=True)
    table.add_column("Server", overflow="fold")
    table.add_column("DNS View", overflow="fold")
    table.add_column("Default Zone", overflow="fold")
    for profile_name in sorted(profiles):
        values = profiles[profile_name]
        table.add_row(
            profile_name,
            "yes" if profile_name == default_profile else "",
            str(values.get("server", "")),
            str(values.get("dns_view", "default")),
            str(values.get("default_zone", "")),
        )
    return table


def emit_profile_list(default_profile: str, profiles: dict[str, dict[str, str]]) -> None:
    """Emit configured profiles as a table or structured output without password fields."""
    if output_is_table():
        console.print(profile_table(default_profile, profiles))
        return
    rows = [
        {
            "profile": profile_name,
            "default": profile_name == default_profile,
            "server": str(values.get("server", "")),
            "dns_view": str(values.get("dns_view", "default")),
            "default_zone": str(values.get("default_zone", "")),
        }
        for profile_name, values in sorted(profiles.items())
    ]
    emit_structured(rows, ["profile", "default", "server", "dns_view", "default_zone"])


def list_config_profiles() -> None:
    """List configured profiles and mark the default profile."""
    if not CONFIG_FILE.exists():
        if output_is_table():
            print_warning("No profiles configured. Run: ib configure")
        else:
            emit_structured([], ["profile", "default", "server", "dns_view", "default_zone"])
        return
    default_profile, profiles, _legacy = read_config_profiles()
    emit_profile_list(default_profile, profiles)


def maybe_prompt_configure() -> None:
    """Offer configuration setup when required config is missing so users get a clear next step."""
    if not sys.stdin.isatty():
        raise CliError("ERROR: no configuration file found. Run: ib configure")
    print_warning(f"No configuration file found at {CONFIG_FILE}.")
    if not Confirm.ask("Run 'ib configure' now?", default=False):
        raise CliError("ERROR: no configuration file found. Run: ib configure")
    save_config_interactive()


def load_config(required: bool = True) -> dict[str, str] | None:
    """Load the default profile and decrypt credentials so commands start with usable settings."""
    if not CONFIG_FILE.exists():
        if required:
            maybe_prompt_configure()
        else:
            return None

    default_profile, profiles, legacy = read_config_profiles()
    cfg = dict(profiles[default_profile])
    cfg["profile"] = default_profile

    for key in ("server", "username", "password"):
        if not cfg.get(key):
            raise CliError(f"ERROR: missing '{key}' in profile '{default_profile}' in {CONFIG_FILE}")

    raw_password = cfg["password"]
    cfg["password"] = decrypt_password(raw_password)
    cfg["server"] = normalize_server(cfg["server"])
    cfg.setdefault("wapi_version", DEFAULT_WAPI_VERSION)
    cfg.setdefault("dns_view", "default")
    cfg.setdefault("default_zone", "")
    cfg.setdefault("verify_ssl", "true")
    cfg.setdefault("timeout", str(DEFAULT_TIMEOUT))
    cfg["dns_view"] = resolve_dns_view(cfg)
    if legacy or any(
        values.get("password") and not is_encrypted_password(values["password"])
        for values in profiles.values()
    ):
        write_config_profiles(default_profile, profiles)
    return cfg


class PooledWapiConnection(NamedTuple):
    """One borrowed WAPI connection plus whether it came from the idle pool."""

    connection: http.client.HTTPConnection
    reused: bool


class WapiConnectionPool:
    """Small thread-safe keep-alive pool for WAPI HTTP connections."""

    def __init__(
        self,
        server_url: urllib.parse.SplitResult,
        server_port: int | None,
        timeout: int,
        verify_ssl: bool,
        max_size: int = WAPI_CONNECTION_POOL_SIZE,
    ) -> None:
        self.server_url = server_url
        self.server_port = server_port
        self.timeout = timeout
        self.verify_ssl = verify_ssl
        self.max_size = max(1, max_size)
        self._idle: deque[http.client.HTTPConnection] = deque()
        self._active_count = 0
        self._condition = threading.Condition()

    def create_connection(self) -> http.client.HTTPConnection:
        """Create one HTTP(S) connection configured for the target Infoblox server."""
        if self.server_url.scheme == "https":
            context = None if self.verify_ssl else ssl._create_unverified_context()
            return http.client.HTTPSConnection(
                self.server_url.hostname,
                port=self.server_port,
                timeout=self.timeout,
                context=context,
            )
        return http.client.HTTPConnection(
            self.server_url.hostname,
            port=self.server_port,
            timeout=self.timeout,
        )

    def acquire(self) -> PooledWapiConnection:
        """Borrow an idle keep-alive connection or create one when the pool has capacity."""
        while True:
            with self._condition:
                if self._idle:
                    return PooledWapiConnection(self._idle.pop(), True)
                if self._active_count < self.max_size:
                    self._active_count += 1
                    break
                self._condition.wait()

        try:
            return PooledWapiConnection(self.create_connection(), False)
        except Exception:
            with self._condition:
                self._active_count -= 1
                self._condition.notify()
            raise

    def release(self, conn: http.client.HTTPConnection) -> None:
        """Return a healthy keep-alive connection to the idle pool."""
        with self._condition:
            self._idle.append(conn)
            self._condition.notify()

    def discard(self, conn: http.client.HTTPConnection) -> None:
        """Close a broken or non-reusable connection and free its pool slot."""
        try:
            conn.close()
        finally:
            with self._condition:
                self._active_count = max(0, self._active_count - 1)
                self._condition.notify()

    def close_idle(self) -> None:
        """Close idle pooled sockets without interrupting requests already in flight."""
        with self._condition:
            idle_connections = list(self._idle)
            self._idle.clear()
            self._active_count = max(0, self._active_count - len(idle_connections))
            self._condition.notify_all()

        for conn in idle_connections:
            try:
                conn.close()
            except OSError:
                pass


def response_allows_keepalive(response: http.client.HTTPResponse) -> bool:
    """Return whether an HTTP response left the socket reusable for another request."""
    connection_header = ""
    getheader = getattr(response, "getheader", None)
    if callable(getheader):
        connection_header = str(getheader("Connection", "") or "")
    if connection_header.lower() == "close":
        return False
    return not bool(getattr(response, "will_close", False))


class InfobloxClient:
    """Wrap Infoblox WAPI HTTPS calls so command logic stays focused on DNS behavior."""

    def __init__(
        self,
        config: dict[str, str],
        connection_pool: WapiConnectionPool | None = None,
    ) -> None:
        """Initialize the instance with state used by the surrounding class methods."""
        self.server = normalize_server(config["server"])
        self.wapi_version = config.get("wapi_version", DEFAULT_WAPI_VERSION).strip().lstrip("/")
        self.username = config["username"]
        self.password = config["password"]
        self.view = config.get("dns_view", "default")
        self.timeout = int(config.get("timeout", DEFAULT_TIMEOUT))
        self.verify_ssl = parse_bool(config.get("verify_ssl", "true"))
        self._server_url = urllib.parse.urlsplit(self.server)
        if self._server_url.scheme not in {"http", "https"} or not self._server_url.hostname:
            raise CliError(f"ERROR: invalid Infoblox server URL: {self.server}")
        try:
            self._server_port = self._server_url.port
        except ValueError as exc:
            raise CliError(f"ERROR: invalid Infoblox server URL: {self.server}") from exc
        self._server_path = self._server_url.path.rstrip("/")
        self._connection_pool = connection_pool or WapiConnectionPool(
            self._server_url,
            self._server_port,
            self.timeout,
            self.verify_ssl,
        )

    def close(self) -> None:
        """Close idle pooled HTTPS connections so callers can release network resources explicitly."""
        self._connection_pool.close_idle()

    def request_path(self, path: str, params: dict[str, Any] | None = None) -> str:
        """Build the WAPI request path with query parameters encoded once for consistent requests."""
        query = f"?{urllib.parse.urlencode(params)}" if params else ""
        quoted_path = urllib.parse.quote(path.lstrip("/"), safe="/:")
        return f"{self._server_path}/wapi/{self.wapi_version}/{quoted_path}{query}"

    def connection_error(self, exc: BaseException) -> WapiError:
        """Convert low-level connection failures into CLI errors with operator-facing context."""
        reason = getattr(exc, "reason", None) or getattr(exc, "strerror", None) or str(exc)
        return WapiError(f"ERROR: cannot reach Infoblox: {reason or exc.__class__.__name__}")

    def request(
        self,
        method: str,
        path: str,
        params: dict[str, Any] | None = None,
        payload: dict[str, Any] | None = None,
    ) -> Any:
        """Execute one WAPI request and retry once after a pooled GET socket goes stale."""
        try:
            return self.request_once(method, path, params, payload)
        except (OSError, http.client.HTTPException) as exc:
            if method.upper() != "GET" or not getattr(exc, "_ib_reused_connection", False):
                raise self.connection_error(exc) from exc
            try:
                return self.request_once(method, path, params, payload)
            except (OSError, http.client.HTTPException) as retry_exc:
                raise self.connection_error(retry_exc) from retry_exc

    def request_once(
        self,
        method: str,
        path: str,
        params: dict[str, Any] | None = None,
        payload: dict[str, Any] | None = None,
    ) -> Any:
        """Perform a single WAPI HTTP exchange and translate the response into Python data or WAPI errors."""
        body = None
        headers = {
            "Accept": "application/json",
            "Connection": "keep-alive",
            "Authorization": "Basic "
            + base64.b64encode(f"{self.username}:{self.password}".encode()).decode(),
        }
        if payload is not None:
            body = json.dumps(payload).encode("utf-8")
            headers["Content-Type"] = "application/json"

        pooled = self._connection_pool.acquire()
        conn = pooled.connection
        keep_connection = False
        try:
            conn.request(method, self.request_path(path, params), body=body, headers=headers)
            response = conn.getresponse()
            raw_bytes = response.read()
            keep_connection = response_allows_keepalive(response)
            if response.status >= 400:
                raw_error = raw_bytes.decode("utf-8", errors="replace")
                raise WapiError(
                    f"ERROR: Infoblox WAPI {response.status}: {format_wapi_error(raw_error)}",
                    status=response.status,
                )

            raw = raw_bytes.decode("utf-8")
            result = None if not raw else json.loads(raw)
        except (OSError, http.client.HTTPException) as exc:
            setattr(exc, "_ib_reused_connection", pooled.reused)
            self._connection_pool.discard(conn)
            raise
        except Exception:
            if keep_connection:
                self._connection_pool.release(conn)
            else:
                self._connection_pool.discard(conn)
            raise

        if keep_connection:
            self._connection_pool.release(conn)
        else:
            self._connection_pool.discard(conn)
        return result


def format_wapi_error(raw: str) -> str:
    """Extract useful WAPI error text so operators see the Infoblox reason instead of raw JSON."""
    try:
        parsed = json.loads(raw)
    except json.JSONDecodeError:
        return raw.strip() or "empty error response"
    return parsed.get("text") or parsed.get("Error") or json.dumps(parsed)


def fqdn(record_name: str, zone: str) -> str:
    """Combine a record name and zone into a fully qualified name while preserving already-qualified names."""
    name = record_name.strip().rstrip(".")
    zone_name = zone.strip().rstrip(".")
    if not name:
        raise CliError("ERROR: record name is required.")
    if not zone_name:
        raise CliError("ERROR: zone is required.")
    if name == "@":
        return zone_name
    if name == zone_name or name.endswith(f".{zone_name}"):
        return name
    return f"{name}.{zone_name}"


def normalize_zone_name(zone_name: str) -> str:
    """Normalize zone names for comparison and WAPI payloads so trailing dots/case do not diverge."""
    normalized = zone_name.strip().rstrip(".")
    if not normalized:
        raise CliError("ERROR: zone is required.")
    return normalized


def normalize_dns_view(view_name: str) -> str:
    """Normalize DNS view names while preserving spaces because Infoblox views can contain them."""
    normalized = view_name.strip()
    if not normalized:
        raise CliError("ERROR: DNS view is required.")
    return normalized


