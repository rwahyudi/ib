def format_zone_detail_value(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, list):
        return "\n".join(
            formatted for item in value if (formatted := format_zone_detail_value(item))
        )
    if isinstance(value, dict):
        mname = value.get("mname") or value.get("soa_mname") or value.get("host_name")
        member = value.get("member") or value.get("name")
        if mname:
            return f"{mname} ({member})" if member else str(mname)

        parts = []
        for key, item in sorted(value.items()):
            formatted = format_zone_detail_value(item)
            if formatted:
                parts.append(f"{key.replace('_', ' ')}: {formatted}")
        return ", ".join(parts)
    return str(value)


def format_network_association(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, list):
        return "\n".join(
            formatted for item in value if (formatted := format_network_association(item))
        )
    if isinstance(value, dict):
        network = value.get("network") or value.get("address") or value.get("_ref")
        if not network:
            return format_zone_detail_value(value)

        details = []
        if value.get("network_view"):
            details.append(f"view: {value['network_view']}")
        if value.get("comment"):
            details.append(f"comment: {value['comment']}")
        if details:
            return f"{network} ({', '.join(details)})"
        return str(network)
    return str(value)


def zone_detail_table(zone_info: dict[str, Any]) -> Table:
    zone_name = str(zone_info.get("fqdn", ""))
    table = Table(title=f"DNS Zone: {zone_name}", header_style="bold cyan")
    table.add_column("Field", style="bold cyan", no_wrap=True)
    table.add_column("Value", overflow="fold")

    fields = [
        ("Zone", "fqdn"),
        ("View", "view"),
        ("Format", "zone_format"),
        ("NS Group", "ns_group"),
        ("Network View", "network_view"),
        ("Network Associations", "network_associations"),
        ("Serial Number", "soa_serial_number"),
        ("SOA MNAME", "member_soa_mnames"),
        ("SOA RNAME", "soa_email"),
        ("Refresh", "soa_refresh"),
        ("Retry", "soa_retry"),
        ("Expiry", "soa_expire"),
        ("Negative Caching TTL", "soa_negative_ttl"),
        ("Comment", "comment"),
        ("Ref", "_ref"),
    ]
    for label, key in fields:
        formatter = format_network_association if key == "network_associations" else format_zone_detail_value
        table.add_row(label, formatter(zone_info.get(key)))
    return table


@click.group(cls=RootGroup, context_settings={"help_option_names": ["-h", "--help"]})
