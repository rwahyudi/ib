    return []


def dns_delete_completion_supported_record_type(record_type: str, item: dict[str, Any]) -> bool:
    """Return whether a cached record type is safe for forward delete completion."""
    candidates = {record_type.lower(), allrecord_type(item).lower()}
    return bool(candidates & DNS_DELETE_COMPLETION_RECORD_TYPES)


def dns_delete_completion_excluded_record(record_type: str, item: dict[str, Any]) -> bool:
    """Exclude reverse or unsupported records from forward delete completions."""
    if not dns_delete_completion_supported_record_type(record_type, item):
        return True
    return is_reverse_zone_name(str(item.get("zone", ""))) or is_reverse_zone_name(
        record_name(item)
    )


def complete_dns_delete_records(
    ctx: click.Context,
    param: click.Parameter,
    incomplete: str,
) -> list[CompletionItem]:
    """Return delete record completions from cached DNS search data while failing quietly."""
    items = dns_delete_ptr_completion(incomplete)
    try:
        config = load_config(required=False)
        if not config:
            return items
        client = InfobloxClient(config)
        records = collect_dns_search_results(
            client,
            incomplete.strip(),
            False,
            None,
            zone_filter=is_forward_zone,
        )
    except (CliError, OSError, ValueError, sqlite3.Error):
        return items

    seen: set[str] = {str(item.value) for item in items}
    for record_type, item in records:
        if dns_delete_completion_excluded_record(record_type, item):
            continue
        name = record_name(item).strip().rstrip(".")
        if not name or name in seen:
            continue
        seen.add(name)
        items.append(CompletionItem(name, help=dns_delete_completion_help(record_type, item)))
        if len(items) >= DNS_DELETE_COMPLETION_LIMIT:
            break
    return items


