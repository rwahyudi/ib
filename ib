def record_table(records: list[tuple[str, dict[str, Any]]], include_ref: bool = False) -> Table:
    """Build the Rich DNS record table with color-coded types and optional ambiguity refs."""
    table = Table(title=f"DNS Records ({len(records)})", header_style="bold cyan")
    table.add_column("Type", no_wrap=True)
    table.add_column("Name", overflow="fold")
    table.add_column("Value", overflow="fold")
    table.add_column("Zone", overflow="fold")
    table.add_column("TTL", justify="right", no_wrap=True)
    table.add_column("Comment", overflow="fold")
    if include_ref:
        table.add_column("Ref", overflow="fold")

    for record_type, item in records:
        row = [
            Text(record_type.upper(), style=record_type_style(record_type)),
            record_name(item, record_type),
            record_value(record_type, item),
            str(item.get("zone", "")),
            str(item.get("ttl", "")),
            str(item.get("comment", "")),
        ]
        if include_ref:
            row.append(str(item.get("_ref", "")))
        table.add_row(*row)
    return table


