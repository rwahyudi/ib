def session_profile_name() -> str | None:
    """Return the selected profile name for scoping transient session state when config exists."""
    profile_name = str(default_config_values().get("profile", "")).strip()
    return normalize_profile_name(profile_name) if profile_name else None


def read_session_zone(profile_name: str | None = None) -> str | None:
    """Read the active session zone, accepting only zones saved for the current profile."""
    expected_profile = normalize_profile_name(profile_name) if profile_name else None
    try:
        with session_zone_file().open("r", encoding="utf-8") as handle:
            payload = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(payload, dict) or payload.get("parent_pid") != os.getppid():
        return None
    stored_profile = str(payload.get("profile", "")).strip()
    if expected_profile and stored_profile != expected_profile:
        return None
    zone_name = str(payload.get("zone", "")).strip()
    if not zone_name:
        return None
    try:
        return normalize_zone_name(zone_name)
    except CliError:
        return None


def write_session_zone(zone_name: str, profile_name: str | None = None) -> None:
    """Write the active zone to profile-scoped session state so zone use remains transient."""
    path = session_zone_file()
    payload = {
        "zone": normalize_zone_name(zone_name),
        "parent_pid": os.getppid(),
        "created_at": time.time(),
    }
    if profile_name:
        payload["profile"] = normalize_profile_name(profile_name)
    try:
        path.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
        os.chmod(path.parent, 0o700)
        with path.open("w", encoding="utf-8") as handle:
            json.dump(payload, handle)
        os.chmod(path, 0o600)
    except OSError:
        raise CliError(f"ERROR: cannot write session active zone at {path}")


def read_session_view() -> str | None:
    """Read the active session view when present so commands can honor ib dns view use."""
    try:
        with session_view_file().open("r", encoding="utf-8") as handle:
            payload = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(payload, dict) or payload.get("parent_pid") != os.getppid():
        return None
    view_name = str(payload.get("view", "")).strip()
    if not view_name:
        return None
    try:
        return normalize_dns_view(view_name)
    except CliError:
        return None


def write_session_view(view_name: str) -> None:
    """Write the active DNS view to session state instead of changing the saved profile."""
    path = session_view_file()
    payload = {
        "view": normalize_dns_view(view_name),
        "parent_pid": os.getppid(),
        "created_at": time.time(),
    }
    try:
        path.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
        os.chmod(path.parent, 0o700)
        with path.open("w", encoding="utf-8") as handle:
            json.dump(payload, handle)
        os.chmod(path, 0o600)
    except OSError:
        raise CliError(f"ERROR: cannot write session active DNS view at {path}")


def resolve_dns_view(config: dict[str, str]) -> str:
    """Resolve active DNS view through session, environment, then configured profile values."""
    session_view = read_session_view()
    if session_view:
        return session_view

    env_view = default_view_from_env()
    if env_view:
        return env_view

    configured_view = str(config.get("dns_view", "")).strip()
    return normalize_dns_view(configured_view) if configured_view else "default"


def config_with_dns_view_override(
    config: dict[str, str],
    view_name: str | None,
) -> dict[str, str]:
    """Return config with a one-command DNS view override applied when requested."""
    if not view_name:
        return config
    overridden_config = dict(config)
    overridden_config["dns_view"] = normalize_dns_view(view_name)
    return overridden_config


def resolve_dns_zone(config: dict[str, str], zone_name: str | None = None) -> str:
    """Resolve the target zone through CLI, profile session, environment, then config."""
    if zone_name:
        return normalize_zone_name(zone_name)

    session_zone = read_session_zone(config.get("profile"))
    if session_zone:
        return session_zone

    env_zone = default_zone_from_env()
    if env_zone:
        return env_zone

    if config.get("default_zone"):
        return normalize_zone_name(config["default_zone"])

    raise CliError(
        f"ERROR: DNS zone is required. Use --zone, ib dns zone use, export {DEFAULT_ZONE_ENV}, "
        "or set a default zone with: ib configure"
    )


def forward_zone_candidates_from_record_name(record_name: str) -> list[str]:
    """Build candidate parent zones from an FQDN so create can infer the most specific zone."""
    normalized = record_name.strip().rstrip(".")
    if not normalized or normalized == "@" or "." not in normalized:
        return []
    labels = [label for label in normalized.split(".") if label]
    if len(labels) != len(normalized.split(".")):
        return []
    return [".".join(labels[index:]) for index in range(len(labels))]


def matching_forward_zone_for_record_name(client: InfobloxClient, record_name: str) -> str | None:
    """Find an existing forward zone for an FQDN so create can avoid requiring --zone."""
    for candidate in forward_zone_candidates_from_record_name(record_name):
        matches = safe_query(
            client,
            ZONE_OBJECT,
            zone_query_params(client, {"fqdn": candidate}, return_fields=ZONE_RETURN_FIELDS),
        )
        for zone_info in matches:
            zone_format = str(zone_info.get("zone_format", "FORWARD")).upper()
            if zone_format != "FORWARD":
                continue
            return normalize_zone_name(str(zone_info.get("fqdn") or candidate))
    return None


def resolve_dns_create_zone(
    config: dict[str, str],
    client: InfobloxClient,
    record_type: str,
    record_name: str,
    zone_name: str | None = None,
) -> str:
    """Resolve create target zones with FQDN inference before falling back to the active/default zone."""
    if zone_name:
        return resolve_dns_zone(config, zone_name)

    if record_type.lower() in FORWARD_RECORD_TYPES:
        matched_zone = matching_forward_zone_for_record_name(client, record_name)
        if matched_zone:
            return matched_zone

    return resolve_dns_zone(config)


