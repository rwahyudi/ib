def render_help_text(ctx: click.Context, renderable: Any, force_color: bool = False) -> str:
    """Render Rich help panels into Click help text so colors and wrapping remain controlled."""
    width = min(ctx.terminal_width or console.width or 80, 100)
    force_terminal = ctx.color if ctx.color is not None else console.is_terminal
    help_console = Console(
        color_system=console.color_system or ("standard" if force_terminal else None),
        force_terminal=force_terminal,
        no_color=False if force_color and force_terminal else None,
        width=width,
    )
    with help_console.capture() as capture:
        help_console.print(renderable)
    return capture.get()


