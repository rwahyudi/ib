@dns.command(cls=DnsCreateCommand)
@click.argument("record_type", type=click.Choice(sorted(RECORD_TYPES), case_sensitive=False))
@click.option("-n", "--name", required=True, help="Record name, relative to --zone unless already FQDN.")
@click.argument("value", shell_complete=complete_dns_create_value)
@click.option(
    "--zone",
    help=f"DNS zone. Defaults to the session active zone, ${DEFAULT_ZONE_ENV}, then the configured default zone.",
)
@click.option("-t", "--ttl", type=int, callback=validate_ttl_option, help="Record TTL in seconds.")
@click.option("--noptr", is_flag=True, help="Do not manage PTR records for A/AAAA workflows.")
@click.option("-c", "--comment", callback=validate_record_comment_option, help="Record comment.")
def create(
    record_type: str,
    value: str,
    name: str,
    zone: str | None,
    ttl: int | None,
    noptr: bool,
    comment: str | None,
) -> None:
    """Create a DNS record.

    Record names are relative to the active zone unless already fully qualified.
    Use `@` as the name for the zone apex. Supported record types are A, AAAA,
    CNAME, TXT, MX, PTR, and HOST.

    \b
    Examples:
      Command: ib dns create a -n app 192.0.2.10 -t 300 -c "Application VIP"
      Creates: A app.<active-zone> -> 192.0.2.10 with TTL 300 and comment "Application VIP"
      Command: ib dns create a -n host1.example-dns.com 192.0.2.10
      Creates: A host1.example-dns.com -> 192.0.2.10 in zone example-dns.com when that forward zone exists
      Command: ib dns create host -n app 192.0.2.10 -t 300 -c "Application host"
      Creates: HOST app.<active-zone> with IPv4 address 192.0.2.10, TTL 300, and comment "Application host"
      Command: ib dns create cname -n www app.example.com
      Creates: CNAME www.<active-zone> -> app.example.com
      Command: ib dns create txt -n _spf "v=spf1 include:example.net -all"
      Creates: TXT _spf.<active-zone> = "v=spf1 include:example.net -all"
      Command: ib dns create mx -n @ "10 mail.example.com"
      Creates: MX <active-zone> -> mail.example.com with preference 10
      Command: ib dns create ptr -n 192.0.2.10 host.example.com
      Creates: PTR 192.0.2.10 -> host.example.com
    """
    run_dns_create(record_type, value, name, zone, ttl, noptr, comment)


