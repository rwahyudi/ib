def styled_click_usage_text(usage_text: str) -> Text:
    """Style Click usage text while keeping the command syntax itself unmodified."""
    text = Text()
    if usage_text.startswith("Usage: "):
        text.append("Usage: ", style="cyan")
        text.append(usage_text[len("Usage: ") :], style="white")
    else:
        text.append(usage_text, style="white")
    return text


def styled_error_keyword_text(message: str) -> Text:
    """Highlight the ERROR prefix consistently without rewriting the actual error message."""
    keyword = "Error:"
    text = Text()
    start = 0
    while True:
        index = message.find(keyword, start)
        if index == -1:
            text.append(message[start:], style="white")
            break
        if index > start:
            text.append(message[start:index], style="white")
        text.append(keyword, style="bold red")
        start = index + len(keyword)
    return text


def print_click_exception(exc: click.ClickException) -> None:
    """Render Click exceptions with context and hints so expected failures stay traceback-free."""
    usage_text = click_error_usage_text(exc)
    if usage_text:
        err_console.print(styled_click_usage_text(usage_text))
        err_console.print()
    err_console.print(styled_error_keyword_text(f"Error: {exc.format_message()}"))


