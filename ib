def dns_edit_forward_targets(config: dict[str, str], record_name: str, zone: str | None) -> list[str]:
    stripped_name = record_name.strip().rstrip(".")
    if not stripped_name:
        raise CliError("ERROR: record name is required.")

    if zone:
        return [fqdn(stripped_name, resolve_dns_zone(config, zone))]

    targets = [stripped_name] if "." in stripped_name else []
    try:
        active_target = fqdn(stripped_name, resolve_dns_zone(config))
    except CliError:
        if targets:
            return targets
        raise

    if active_target not in targets:
        targets.append(active_target)
    return targets


def dns_edit_forward_records(
    config: dict[str, str],
    client: InfobloxClient,
    record_name: str,
    zone: str | None,
) -> tuple[str, list[tuple[str, dict[str, Any]]]]:
    targets = dns_edit_forward_targets(config, record_name, zone)
    target = targets[0]

    for candidate in targets:
        matches: list[tuple[str, dict[str, Any]]] = []
        for candidate_type in FORWARD_RECORD_TYPES:
            spec = RECORD_TYPES[candidate_type]
            params = object_query_params(spec, client, {"name": candidate})
            matches.extend(
                (candidate_type, item) for item in safe_query(client, spec["object"], params)
            )
        if matches:
            return candidate, matches
    return target, []


def dns_edit_ptr_matches(
    client: InfobloxClient,
    record_name: str,
) -> tuple[str, list[tuple[str, dict[str, Any]]]]:
    address = ptr_delete_ip_address(record_name)
    reverse_zone = reverse_zone_for_ip(client, address)
    spec = RECORD_TYPES["ptr"]
    params = object_query_params(spec, client, {ptr_address_query_field(address): str(address)})
    matches = [
        ("ptr", item)
        for item in safe_query(client, spec["object"], params)
        if ptr_record_matches_reverse_zone(item, reverse_zone)
    ]
    return str(address), matches


def record_name_is_ip_address(record_name: str) -> bool:
    try:
        ipaddress.ip_address(record_name.strip())
    except ValueError:
        return False
    return True


def dns_edit_matches(
    config: dict[str, str],
    client: InfobloxClient,
    record_type: str | None,
    record_name: str,
    zone: str | None,
) -> tuple[
    str,
    list[tuple[str, dict[str, Any]]],
    list[tuple[str, dict[str, Any]]],
]:
    if record_type == "ptr":
        if not record_name_is_ip_address(record_name):
            target, forward_matches = dns_edit_forward_records(config, client, record_name, zone)
            if forward_matches:
                return target, [], forward_matches
        target, matches = dns_edit_ptr_matches(client, record_name)
        return target, matches, matches

    target, matches = dns_edit_forward_records(config, client, record_name, zone)
    if record_type:
        typed_matches = [
            (item_type, item) for item_type, item in matches if item_type == record_type
        ]
        if not typed_matches and zone is None and record_name_is_ip_address(record_name):
            try:
                ptr_target, ptr_matches = dns_edit_ptr_matches(client, record_name)
            except CliError:
                pass
            else:
                if ptr_matches:
                    return ptr_target, [], ptr_matches
        return target, typed_matches, matches
    if matches:
        return target, matches, matches

    if zone is None and record_name_is_ip_address(record_name):
        try:
            target, ptr_matches = dns_edit_ptr_matches(client, record_name)
        except CliError:
            pass
        else:
            if ptr_matches:
                return target, ptr_matches, ptr_matches

    return target, [], []


def normalize_optional_record_type(record_type: str | None) -> str | None:
    if record_type is None:
        return None
    normalized = record_type.lower()
    if normalized not in RECORD_TYPES:
        supported = ", ".join(sorted(RECORD_TYPES))
        raise CliError(f"ERROR: unsupported record type '{record_type}'. Supported: {supported}")
    return normalized


def dns_edit_record_types(matches: list[tuple[str, dict[str, Any]]]) -> list[str]:
    return sorted({record_type.upper() for record_type, _item in matches})


def raise_dns_edit_type_mismatch(
    target: str,
    requested_type: str,
    matches: list[tuple[str, dict[str, Any]]],
) -> None:
    if len(matches) == 1:
        actual_type = matches[0][0].upper()
        raise CliError(
            f"ERROR: {target} is a {actual_type} record, so edit type must be {actual_type}."
        )

    actual_types = ", ".join(dns_edit_record_types(matches)) or "unknown"
    print_error(
        f"ERROR: {target} has existing record types {actual_types}; "
        f"requested edit type was {requested_type.upper()}."
    )
    err_console.print(record_table(matches, include_ref=True))
    raise CliError("ERROR: edit type does not match the selected record.")


def run_dns_edit(
    record_name: str,
    record_type: str | None,
    value: str | None,
    zone: str | None,
    ttl: int | None,
    noptr: bool,
    comment: str | None,
) -> None:
    requested_type = normalize_optional_record_type(record_type)
    if value is not None and requested_type is None:
        raise CliError("ERROR: record type is required when updating the record value.")
    config = load_config()
    client = InfobloxClient(config)
    target, matches, all_matches = dns_edit_matches(config, client, requested_type, record_name, zone)

    if not matches:
        if requested_type and all_matches:
            raise_dns_edit_type_mismatch(target, requested_type, all_matches)
        type_label = f" {requested_type.upper()}" if requested_type else ""
        raise CliError(f"ERROR: no{type_label} DNS record found for {target} in view {client.view}")
    if len(matches) > 1:
        print_error(f"ERROR: multiple records found for {target}. Edit one _ref manually:")
        err_console.print(record_table(matches, include_ref=True))
        raise CliError("ERROR: edit target is ambiguous.")

    actual_type, item = matches[0]
    ref = item.get("_ref")
    if not ref:
        raise CliError("ERROR: matched record does not include an _ref.")

    if value is not None:
        warn_if_cname_target_unresolved(actual_type, value)
    payload = update_payload(actual_type, value, ttl, comment)
    updated_ref = client.request("PUT", ref, payload=payload)

    if noptr and actual_type not in {"a", "aaaa"}:
        print_warning("WARNING: --noptr only applies to A/AAAA workflows and was ignored.")
    refresh_dns_cache_after_update()
    print_success(f"SUCCESS: updated {actual_type.upper()} record {target}")
    print_note(f"Reference: {updated_ref or ref}")


def ptr_delete_ip_address(ip_value: str | None) -> ipaddress.IPv4Address | ipaddress.IPv6Address:
    if not ip_value:
        raise CliError("ERROR: full IP address is required. Use: ib dns delete ptr <ip-address>")
    try:
        return ipaddress.ip_address(ip_value.strip())
    except ValueError:
        raise CliError("ERROR: full IP address is required. Use: ib dns delete ptr <ip-address>")


def reverse_zone_format_for_ip(address: ipaddress.IPv4Address | ipaddress.IPv6Address) -> str:
    return "IPV4" if address.version == 4 else "IPV6"


def reverse_zone_for_ip(
    client: InfobloxClient,
    address: ipaddress.IPv4Address | ipaddress.IPv6Address,
) -> str:
    reverse_pointer = address.reverse_pointer.rstrip(".")
    expected_format = reverse_zone_format_for_ip(address)
    matches: set[str] = set()

    for zone in query_zones(client):
        zone_name = str(zone.get("fqdn", "")).strip()
        if not zone_name:
            continue
        zone_format = str(zone.get("zone_format", "")).strip().upper()
        if zone_format and zone_format != expected_format:
            continue
        try:
            normalized_zone = normalize_zone_name(zone_name)
        except CliError:
            continue
        if is_zone_or_child(reverse_pointer, normalized_zone):
            matches.add(normalized_zone)

    if not matches:
        raise CliError(
            f"ERROR: no {expected_format} reverse DNS zone found for {address} in view {client.view}"
        )
    return sorted(matches, key=lambda zone_name: (-len(zone_name), zone_name.lower()))[0]


def ptr_address_query_field(address: ipaddress.IPv4Address | ipaddress.IPv6Address) -> str:
    return "ipv4addr" if address.version == 4 else "ipv6addr"


def ptr_record_matches_reverse_zone(item: dict[str, Any], reverse_zone: str) -> bool:
    item_zone = str(item.get("zone", "")).strip()
    if not item_zone:
        return True
    try:
        return normalize_zone_name(item_zone) == reverse_zone
    except CliError:
        return False


def run_dns_delete_ptr(ip_value: str | None) -> None:
    address = ptr_delete_ip_address(ip_value)
    config = load_config()
    client = InfobloxClient(config)
    reverse_zone = reverse_zone_for_ip(client, address)
    spec = RECORD_TYPES["ptr"]
    params = object_query_params(spec, client, {ptr_address_query_field(address): str(address)})
    raw_matches = safe_query(client, spec["object"], params)
    matches = [
        ("ptr", item)
        for item in raw_matches
        if ptr_record_matches_reverse_zone(item, reverse_zone)
    ]

    if not matches:
        raise CliError(
            f"ERROR: no PTR record found for {address} in reverse zone {reverse_zone} "
            f"and view {client.view}"
        )
    if len(matches) > 1:
        print_error(
            f"ERROR: multiple PTR records found for {address} in reverse zone {reverse_zone}. "
            "Delete one of these _ref values manually:"
        )
        err_console.print(record_table(matches, include_ref=True))
        raise CliError("ERROR: delete target is ambiguous.")

    item = matches[0][1]
    ref = item.get("_ref")
    if not ref:
        raise CliError("ERROR: matched PTR record does not include an _ref.")
    client.request("DELETE", ref)
    refresh_dns_cache_after_update()
    print_success(f"SUCCESS: deleted PTR record {address} from reverse zone {reverse_zone}")


def dns_delete_reverse_entry_hint(record_name: str) -> str:
    try:
        address = ipaddress.ip_address(record_name.strip().rstrip("."))
    except ValueError:
        return "HINT: To delete a reverse DNS PTR entry, run: ib dns delete ptr <ip-address>"
    return f"HINT: To delete the reverse DNS PTR entry for {address}, run: ib dns delete ptr {address}"


def run_dns_delete(record_name: str, zone: str | None) -> None:
    if record_name.strip().lower() == "ptr":
        run_dns_delete_ptr(zone)
        return

    config = load_config()
    client = InfobloxClient(config)
    record_name = record_name.strip().rstrip(".")
    if zone:
        targets = [fqdn(record_name, resolve_dns_zone(config, zone))]
    else:
        targets = [record_name] if "." in record_name else []
    matches: list[tuple[str, dict[str, Any]]] = []
    target = targets[0] if targets else record_name

    for candidate in targets:
        candidate_matches: list[tuple[str, dict[str, Any]]] = []
        for record_type, spec in RECORD_TYPES.items():
            if record_type == "ptr":
                continue
            params = object_query_params(spec, client, {"name": candidate})
            candidate_matches.extend((record_type, item) for item in safe_query(client, spec["object"], params))
        if candidate_matches:
            target = candidate
            matches = candidate_matches
            break

    if not matches and not zone:
        active_target = fqdn(record_name, resolve_dns_zone(config))
        if active_target not in targets:
            targets.append(active_target)
            for record_type, spec in RECORD_TYPES.items():
                if record_type == "ptr":
                    continue
                params = object_query_params(spec, client, {"name": active_target})
                matches.extend((record_type, item) for item in safe_query(client, spec["object"], params))
            if matches:
                target = active_target

    if not matches:
        target_description = " or ".join(targets)
        raise CliError(
            f"ERROR: no forward DNS record found for {target_description} in view {client.view}\n"
            f"{dns_delete_reverse_entry_hint(record_name)}"
        )
    if len(matches) > 1:
        print_error(f"ERROR: multiple records found for {target}. Delete one of these _ref values manually:")
        err_console.print(record_table(matches, include_ref=True))
        raise CliError("ERROR: delete target is ambiguous.")

    record_type, item = matches[0]
    ref = item.get("_ref")
    if not ref:
        raise CliError("ERROR: matched record does not include an _ref.")
    client.request("DELETE", ref)
    refresh_dns_cache_after_update()
    print_success(f"SUCCESS: deleted {record_type.upper()} record {target}")


