class CliError(Exception):
    """Expected CLI failure with a user-facing message."""


class WapiError(CliError):
    """Infoblox WAPI request failure."""

    def __init__(self, message: str, status: int | None = None) -> None:
        """Initialize the instance with state used by the surrounding class methods."""
        super().__init__(message)
        self.status = status


class DnsCreateError(CliError):
    """DNS create failure with command context attached."""

    def __init__(self, message: str, context: dict[str, Any]) -> None:
        """Initialize the instance with state used by the surrounding class methods."""
        super().__init__(message)
        self.context = context


def current_output_format() -> str:
    """Return the selected output mode from the root Click context so nested commands honor -o anywhere."""
    ctx = click.get_current_context(silent=True)
    if ctx is None:
        return TABLE_OUTPUT
    root = ctx.find_root()
    output_format = root.params.get("output_format") if root else None
    return str(output_format or TABLE_OUTPUT).lower()


def output_is_table() -> bool:
    """Return whether output should use the default Rich table mode so callers can branch once."""
    return current_output_format() == TABLE_OUTPUT


def shell_completion_is_active() -> bool:
    """Return whether Click is running a shell-completion helper that must stay silent."""
    return bool(os.environ.get("_IB_COMPLETE"))


def current_command_is_hidden() -> bool:
    """Detect hidden maintenance commands so status UI does not leak into background helpers."""
    ctx = click.get_current_context(silent=True)
    while ctx is not None:
        if getattr(ctx.command, "hidden", False):
            return True
        ctx = ctx.parent
    return False


def infoblox_spinner_enabled() -> bool:
    """Show wait UI only for interactive Rich output where transient terminal status is safe."""
    return (
        output_is_table()
        and console.is_terminal
        and not shell_completion_is_active()
        and not current_command_is_hidden()
    )


def infoblox_wait_spinner(message: str = INFOBLOX_WAIT_MESSAGE) -> Any:
    """Return a transient Rich spinner context for foreground Infoblox waits."""
    if infoblox_spinner_enabled():
        return console.status(message, spinner="dots")
    return nullcontext()


def json_default(value: Any) -> str:
    """Convert non-JSON-native values to strings so structured output does not crash on Path-like data."""
    return str(value)


def emit_json(data: Any) -> None:
    """Print JSON output through Click so stdout handling stays consistent with the CLI framework."""
    click.echo(json.dumps(data, indent=2, default=json_default))


def csv_value(value: Any) -> Any:
    """Normalize one CSV cell so nested values remain readable and missing values become empty cells."""
    if value is None:
        return ""
    if isinstance(value, (dict, list, tuple)):
        return json.dumps(value, default=json_default)
    return value


def emit_csv(rows: list[dict[str, Any]], fieldnames: list[str]) -> None:
    """Write CSV rows with a stable header order so automation receives predictable columns."""
    writer = csv.DictWriter(sys.stdout, fieldnames=fieldnames, extrasaction="ignore")
    writer.writeheader()
    for row in rows:
        writer.writerow({field: csv_value(row.get(field)) for field in fieldnames})


def structured_output_data(data: Any) -> Any:
    """Remove structured-output-only fields recursively so JSON and CSV avoid exposing Infoblox refs."""
    if isinstance(data, list):
        return [structured_output_data(item) for item in data]
    if isinstance(data, dict):
        return {
            key: structured_output_data(value)
            for key, value in data.items()
            if str(key) not in STRUCTURED_EXCLUDED_FIELDS
        }
    return data


def structured_output_fields(fieldnames: list[str]) -> list[str]:
    """Filter CSV fieldnames with the same rules as JSON data so output modes stay aligned."""
    return [field for field in fieldnames if field not in STRUCTURED_EXCLUDED_FIELDS]


def emit_structured(data: Any, fieldnames: list[str] | None = None) -> None:
    """Route data to JSON or CSV after shared filtering so command handlers do not duplicate output logic."""
    data = structured_output_data(data)
    if current_output_format() == "jq":
        emit_json(data)
        return

    if isinstance(data, list):
        rows = data
    else:
        rows = [data]
    if fieldnames is None:
        fieldnames = sorted({key for row in rows for key in row})
    else:
        fieldnames = structured_output_fields(fieldnames)
    emit_csv(rows, fieldnames)


def emit_action_result(**fields: Any) -> None:
    """Emit a normalized success payload for mutating commands so automation receives one schema."""
    emit_structured(
        fields,
        [
            "status",
            "action",
            "type",
            "name",
            "zone",
            "view",
            "message",
        ],
    )


