RICH_BASH_SOURCE = """%(complete_func)s() {
    local IFS=$'\\n'
    local response

    response=$(env \\
        COMP_WORDS="${COMP_WORDS[*]}" \\
        COMP_CWORD=$COMP_CWORD \\
        COMP_TYPE="${COMP_TYPE:-9}" \\
        COLUMNS="${COLUMNS:-80}" \\
        %(complete_var)s=bash_complete \\
        IB_COMPLETION_RENDER=1 \\
        IB_COMPLETION_LAYOUT="${IB_COMPLETION_LAYOUT:-rich}" \\
        IB_COMPLETION_COLOR="${IB_COMPLETION_COLOR:-auto}" \\
        IB_COMPLETION_MAX_ROWS="${IB_COMPLETION_MAX_ROWS:-40}" \\
        "$1")

    for completion in $response; do
        IFS=',' read -r type value <<< "$completion"

        if [[ $type == 'dir' ]]; then
            COMPREPLY=()
            compopt -o dirnames
        elif [[ $type == 'file' ]]; then
            COMPREPLY=()
            compopt -o default
        elif [[ $type == 'plain' ]]; then
            COMPREPLY+=("$value")
        fi
    done

    return 0
}

%(complete_func)s_setup() {
    complete -o nosort -F %(complete_func)s %(prog_name)s
}

%(complete_func)s_setup;
"""


def completion_layout_mode() -> str:
    """Return the requested completion layout mode, defaulting to the Rich Bash view."""
    return os.environ.get(COMPLETION_LAYOUT_ENV, "rich").strip().lower()


def completion_color_mode() -> str:
    """Return the requested completion color mode so shell users can disable table rendering."""
    return os.environ.get(COMPLETION_COLOR_ENV, "auto").strip().lower()


def completion_max_rows() -> int:
    """Limit the Rich completion table so broad cached DNS completions do not flood the terminal."""
    raw_value = os.environ.get(COMPLETION_MAX_ROWS_ENV, "40")
    try:
        value = int(raw_value)
    except (TypeError, ValueError):
        return 40
    return max(1, value)


def bash_completion_is_listing_request() -> bool:
    """Detect Bash's explicit list-completions request so normal Tab insertion stays quiet."""
    completion_type = os.environ.get("COMP_TYPE", "9")
    return completion_type in {"33", "63", "64", "!", "?", "@"}


def completion_rich_layout_enabled(items: list[CompletionItem]) -> bool:
    """Decide whether Bash completion should render a separate Rich candidate table."""
    if os.environ.get(COMPLETION_RENDER_ENV) != "1":
        return False
    if not bash_completion_is_listing_request():
        return False
    if completion_layout_mode() != "rich":
        return False
    if completion_color_mode() == "never":
        return False
    plain_items = [item for item in items if item.type == "plain"]
    return len(plain_items) > 1


def completion_terminal_width() -> int | None:
    """Read shell width for completion tables without failing in unusual environments."""
    raw_columns = os.environ.get("COLUMNS")
    try:
        columns = int(raw_columns) if raw_columns else 0
    except (TypeError, ValueError):
        return None
    return columns if columns >= 40 else None


def command_completion_values() -> set[str]:
    """Collect command names so completion tables can label commands consistently."""
    root = globals().get("cli")
    if not isinstance(root, click.Group):
        return set()

    names: set[str] = set()
    pending = [root]
    while pending:
        command = pending.pop()
        for name, subcommand in command.commands.items():
            names.add(name)
            if isinstance(subcommand, click.Group):
                pending.append(subcommand)
    return names


def completion_record_type_from_help(help_text: str | None) -> str | None:
    """Extract record type hints from DNS record completion descriptions when present."""
    if not help_text or help_text == "_":
        return None
    token = help_text.split("|", 1)[0].strip().split(" ", 1)[0].lower()
    if token in RECORD_TYPE_STYLES:
        return token
    return None


def completion_item_kind_and_style(item: CompletionItem) -> tuple[str, str]:
    """Classify completion candidates so the Rich table can use stable colors."""
    value = str(item.value)
    normalized_value = value.lower()

    if value.startswith("active-zone="):
        return "Context", "bold yellow"
    if value.startswith("-"):
        return "Option", "bold cyan"
    if normalized_value in RECORD_TYPES:
        return "Record type", record_type_style(normalized_value)

    record_type = completion_record_type_from_help(item.help)
    if record_type:
        return f"{record_type.upper()} record", record_type_style(record_type)

    if value in command_completion_values():
        return "Command", LIGHT_GREEN_TEXT_STYLE
    if "." in value:
        return "Zone/name", "bold blue"
    return "Value", "white"


def completion_item_help(item: CompletionItem) -> str:
    """Normalize Click's no-description sentinel before rendering completion details."""
    help_text = item.help or ""
    return "" if help_text == "_" else str(help_text)


def grouped_completion_table_items(
    items: list[CompletionItem],
) -> list[list[CompletionItem]]:
    """Group option aliases with the same description so -o and --output share one row."""
    plain_items = [item for item in items if item.type == "plain"]
    groups: list[list[CompletionItem]] = []
    index = 0
    while index < len(plain_items):
        item = plain_items[index]
        group = [item]
        if str(item.value).startswith("-"):
            help_text = completion_item_help(item)
            next_index = index + 1
            while next_index < len(plain_items):
                next_item = plain_items[next_index]
                if not str(next_item.value).startswith("-"):
                    break
                if completion_item_help(next_item) != help_text:
                    break
                group.append(next_item)
                next_index += 1
            index = next_index
        else:
            index += 1
        groups.append(group)
    return groups


def render_bash_completion_table(
    items: list[CompletionItem],
    incomplete: str,
    output_console: Console,
    max_rows: int | None = None,
) -> bool:
    """Render a colored Bash completion table without changing the values Bash inserts."""
    grouped_items = grouped_completion_table_items(items)
    if len(grouped_items) <= 1:
        return False

    row_limit = max_rows if max_rows is not None else completion_max_rows()
    shown_groups = grouped_items[:row_limit]
    title = "ib completions"
    if incomplete:
        title = f"{title} for {incomplete}"

    table = Table(title=title, header_style="bold cyan")
    table.add_column("Kind", no_wrap=True)
    table.add_column("Complete", overflow="fold")
    table.add_column("Details", overflow="fold", style="dim")

    for group in shown_groups:
        item = group[0]
        kind, style = completion_item_kind_and_style(item)
        value = ", ".join(str(grouped_item.value) for grouped_item in group)
        table.add_row(
            Text(kind, style=style),
            Text(value, style=style),
            completion_item_help(item),
        )

    hidden_count = len(grouped_items) - len(shown_groups)
    if hidden_count > 0:
        table.caption = (
            f"Showing {len(shown_groups)} of {len(grouped_items)} matches. "
            "Keep typing to narrow results."
        )

    output_console.print()
    output_console.print(table)
    return True


def render_bash_completion_table_to_tty(
    items: list[CompletionItem],
    incomplete: str,
) -> bool:
    """Write the Rich completion table to the terminal while stdout stays reserved for Bash."""
    if not completion_rich_layout_enabled(items):
        return False

    color_mode = completion_color_mode()
    try:
        with open("/dev/tty", "w", encoding="utf-8", errors="replace") as tty:
            tty_console = Console(
                file=tty,
                force_terminal=color_mode == "always",
                color_system="standard" if color_mode == "always" else None,
                width=completion_terminal_width(),
            )
            return render_bash_completion_table(items, incomplete, tty_console)
    except OSError:
        return False


class RichBashComplete(BashComplete):
    """Bash completion that keeps protocol output plain and renders a Rich side table."""

    source_template = RICH_BASH_SOURCE

    def complete(self) -> str:
        """Return standard Bash completions after optionally drawing a colored table to the TTY."""
        args, incomplete = self.get_completion_args()
        completions = self.get_completions(args, incomplete)
        render_bash_completion_table_to_tty(completions, incomplete)
        return "\n".join(self.format_completion(item) for item in completions)


add_completion_class(RichBashComplete, "bash")


class DnsGroup(UsageContextGroup):
    """DNS command group that augments shell completion with active-zone context."""
    def shell_complete(self, ctx: click.Context, incomplete: str) -> list[CompletionItem]:
        """Customize shell completion while preserving Click default command suggestions."""
        items = super().shell_complete(ctx, incomplete)

        zone_help = active_zone_completion_help()
        if is_bash_completion():
            if incomplete:
                return items
            return [CompletionItem(active_zone_completion_value(), help=zone_help), *items]

        for item in items:
            if item.type == "plain" and str(item.value) in self.commands:
                item.help = append_active_zone_help(item.help, zone_help)
        return items


class RootGroup(UsageContextGroup):
    """Root command group that opportunistically warms completion/search cache during completion."""
    def shell_complete(self, ctx: click.Context, incomplete: str) -> list[CompletionItem]:
        """Customize shell completion while preserving Click default command suggestions."""
        items = super().shell_complete(ctx, incomplete)
        if not incomplete:
            start_search_cache_prewarm()
        return items


def normalize_ttl(ttl: int | None) -> int | None:
    """Validate TTL values locally so WAPI payloads only receive non-negative integers."""
    if ttl is None:
        return None
    if isinstance(ttl, bool) or not isinstance(ttl, int):
        raise CliError("ERROR: ttl must be an integer.")
    if ttl < 0:
        raise CliError("ERROR: ttl must be 0 or greater.")
    return ttl


def ttl_payload(ttl: int | None) -> dict[str, Any]:
    """Build the WAPI TTL fragment and use_ttl flag together so TTL updates are explicit."""
    normalized = normalize_ttl(ttl)
    if normalized is None:
        return {}
    return {"ttl": normalized, "use_ttl": True}


def normalize_record_comment(comment: str | None) -> str | None:
    """Validate comments before WAPI calls so invalid characters fail with local guidance."""
    if comment is None:
        return None
    normalized = comment.strip()
    if not normalized:
        return None
    if not COMMENT_ALLOWED_RE.fullmatch(normalized):
        raise CliError(
            "ERROR: comment may only contain letters, numbers, spaces, and common punctuation "
            ".,_-:;@#%+=/()[]'&"
        )
    return normalized


def click_error_text(error: CliError) -> str:
    """Strip the local ERROR prefix when converting CLI errors into Click exceptions."""
    message = str(error)
    return message[7:] if message.startswith("ERROR: ") else message


def validate_ttl_option(
    ctx: click.Context,
    param: click.Parameter,
    value: int | None,
) -> int | None:
    """Validate Click TTL options through the shared TTL rules so create and edit behave the same."""
    try:
        return normalize_ttl(value)
    except CliError as exc:
        raise click.BadParameter(click_error_text(exc), ctx=ctx, param=param) from exc


def validate_record_comment_option(
    ctx: click.Context,
    param: click.Parameter,
    value: str | None,
) -> str | None:
    """Validate Click comment options through the shared comment rules so commands stay consistent."""
    try:
        return normalize_record_comment(value)
    except CliError as exc:
        raise click.BadParameter(click_error_text(exc), ctx=ctx, param=param) from exc


def mx_payload(value: str) -> dict[str, Any]:
    """Parse MX value syntax into preference and exchanger fields required by Infoblox."""
    parts = value.split()
    if len(parts) != 2 or not parts[0].isdigit():
        raise CliError("ERROR: MX value must be quoted as '<preference> <mail_exchanger>'.")
    return {"preference": int(parts[0]), "mail_exchanger": parts[1].rstrip(".")}


def srv_int_field(label: str, value: str) -> int:
    """Parse one SRV integer field and keep WAPI range errors local and actionable."""
    try:
        parsed = int(value)
    except ValueError:
        raise CliError(f"ERROR: SRV {label} must be an integer.")
    if parsed < 0 or parsed > 65535:
        raise CliError(f"ERROR: SRV {label} must be between 0 and 65535.")
    return parsed


def srv_payload(value: str) -> dict[str, Any]:
    """Parse SRV value syntax into priority, weight, port, and target fields for Infoblox."""
    parts = value.split()
    if len(parts) != 4:
        raise CliError("ERROR: SRV value must be quoted as '<priority> <weight> <port> <target>'.")
    target = parts[3].rstrip(".")
    if not target:
        raise CliError("ERROR: SRV target is required.")
    return {
        "priority": srv_int_field("priority", parts[0]),
        "weight": srv_int_field("weight", parts[1]),
        "port": srv_int_field("port", parts[2]),
        "target": target,
    }


def ptr_payload(name: str, value: str) -> dict[str, Any]:
    """Build a PTR WAPI payload from address and target host so reverse records use the right field names."""
    field = "ipv6addr" if ":" in name else "ipv4addr"
    return {field: name, "ptrdname": value.rstrip(".")}


def host_payload(value: str) -> dict[str, Any]:
    """Build a HOST address payload and choose IPv4 or IPv6 fields from the supplied address."""
    try:
        address = ipaddress.ip_address(value)
    except ValueError:
        raise CliError("ERROR: host value must be an IPv4 or IPv6 address.")

    if address.version == 4:
        return {"ipv4addrs": [{"ipv4addr": str(address)}]}
    return {"ipv6addrs": [{"ipv6addr": str(address)}]}


def create_payload(
    record_type: str,
    value: str,
    name: str,
    zone: str,
    ttl: int | None,
    comment: str | None,
    client: InfobloxClient,
) -> tuple[str, dict[str, Any]]:
    """Build the WAPI create payload for each supported record type so command parsing stays type-neutral."""
    record_type = record_type.lower()
    spec = RECORD_TYPES.get(record_type)
    if not spec:
        supported = ", ".join(sorted(RECORD_TYPES))
        raise CliError(f"ERROR: unsupported record type '{record_type}'. Supported: {supported}")

    object_type = spec["object"]
    fqdn_name = fqdn(name, zone)
    record_comment = normalize_record_comment(comment)
    payload: dict[str, Any] = {
        "name": fqdn_name,
        "view": client.view,
        **ttl_payload(ttl),
    }
    if record_comment:
        payload["comment"] = record_comment

    if record_type == "mx":
        payload.update(mx_payload(value))
    elif record_type == "srv":
        payload.update(srv_payload(value))
    elif record_type == "host":
        payload.update(host_payload(value))
    elif record_type == "ptr":
        payload = {
            **ptr_payload(name, value),
            "view": client.view,
            **ttl_payload(ttl),
        }
        if record_comment:
            payload["comment"] = record_comment
    else:
        value_field = spec["value_field"]
        payload[value_field] = value.rstrip(".") if record_type == "cname" else value

    return object_type, payload


def cname_target_for_resolution(value: str) -> str:
    """Normalize CNAME targets before DNS lookup so warning checks query the intended hostname."""
    return value.strip().rstrip(".")


def warn_if_cname_target_unresolved(record_type: str, value: str) -> None:
    """Warn on unresolved CNAME targets without blocking create/edit because DNS may be staged."""
    if record_type.lower() != "cname":
        return

    target = cname_target_for_resolution(value)
    if not target:
        print_warning("WARNING: CNAME target is empty; DNS resolution check was skipped.")
        return

    try:
        socket.getaddrinfo(target, None)
    except socket.gaierror as exc:
        print_warning(
            f"WARNING: CNAME target {target} does not resolve from this system: {exc}. "
            "Record creation will continue."
        )
    except OSError as exc:
        print_warning(
            f"WARNING: CNAME target {target} could not be checked from this system: {exc}. "
            "Record creation will continue."
        )


def dns_create_target_name(name: str, resolved_zone: str | None) -> str | None:
    """Return the display name create attempted so error context can show the target record."""
    if not resolved_zone:
        return None
    try:
        return fqdn(name, resolved_zone)
    except CliError:
        return None


def dns_create_error_hints(error_message: str | None, context: dict[str, Any]) -> list[str]:
    """Choose local hints for common Infoblox create failures so errors include a next action."""
    if not error_message:
        return []

    network_match = re.search(
        r"The IP address (?P<ip>\S+) cannot be used for the zone (?P<zone>.+?)\. "
        r"Verify the network association",
        error_message,
        flags=re.IGNORECASE,
    )
    if network_match:
        ip_address = network_match.group("ip")
        zone_name = network_match.group("zone")
        selected_zone = str(context.get("resolved_zone") or zone_name)
        record_type = str(context.get("record_type") or "record").upper()
        return [
            f"Infoblox rejected the {record_type} record because IP address {ip_address} is not "
            f"allowed for DNS zone {zone_name}.",
            "Use an IP associated with that zone.",
            "Choose the correct zone with --zone or a fully qualified name.",
            "Update the zone network association in Infoblox.",
            f"Run `ib dns zone info {selected_zone}` to view the network association for this zone.",
        ]

    return []


def dns_create_error_hint(error_message: str | None, context: dict[str, Any]) -> str | None:
    """Join create hints into a single message for compact error panels."""
    hints = dns_create_error_hints(error_message, context)
    if not hints:
        return None
    return "\n".join(hints)


def dns_create_error_context(
    record_type: str,
    value: str,
    name: str,
    zone: str | None,
    ttl: int | None,
    noptr: bool,
    comment: str | None,
    resolved_zone: str | None = None,
    view: str | None = None,
    object_type: str | None = None,
    error_message: str | None = None,
) -> dict[str, Any]:
    """Collect create failure context so the error renderer can explain the attempted WAPI action."""
    context_status = dns_context_status()
    if view:
        context_status["view"] = view
        context_status["view_source"] = "configured"
    context = {
        "record_type": record_type,
        "value": value,
        "name": name,
        "--zone": zone,
        "target_record": dns_create_target_name(name, resolved_zone),
        "profile": context_status.get("profile", DEFAULT_PROFILE_NAME),
        "profile_source": context_status.get("profile_source", "default profile"),
        "view": context_status["view"],
        "view_source": context_status["view_source"],
        "active_zone": context_status["active_zone"],
        "active_zone_source": context_status["active_zone_source"],
        "has_active_zone": context_status["has_active_zone"],
        "resolved_zone": resolved_zone,
        "-t/--ttl": ttl,
        "--noptr": noptr,
        "-c/--comment": comment,
        "wapi_object": object_type,
    }
    hints = dns_create_error_hints(error_message, context)
    if hints:
        context["hints"] = hints
        context["hint"] = "\n".join(hints)
    return context


def dns_create_error_value(value: Any) -> Text:
    """Format one create error context value for a Rich table without losing structured details."""
    if value is None or value == "":
        return Text("not set", style="yellow")
    if isinstance(value, bool):
        return Text("true" if value else "false", style=LIGHT_GREEN_TEXT if value else "dim")
    return Text(str(value).replace("\n", "\\n"), style="white")


def dns_create_error_hint_lines(value: Any) -> list[str]:
    """Expand create hints into bullet lines so multi-step guidance is readable."""
    if not value:
        return []
    if isinstance(value, (list, tuple)):
        raw_lines = [str(item) for item in value]
    else:
        raw_lines = str(value).splitlines()

    lines = []
    for line in raw_lines:
        hint = line.strip()
        if not hint:
            continue
        if hint.startswith(("- ", "* ")):
            hint = hint[2:].strip()
        lines.append(hint)
    return lines


def dns_create_error_hint_value(value: Any) -> Text:
    """Format hint text for the create error panel with nested hint lines preserved."""
    text = Text()
    for index, hint in enumerate(dns_create_error_hint_lines(value)):
        if index:
            text.append("\n")
        text.append("- ", style="bold yellow")
        text.append(hint, style="white")
    return text


def dns_create_error_context_panel(context: dict[str, Any]) -> Panel:
    """Build the Rich panel that explains a failed create request and likely fixes."""
    table = Table(show_header=False, box=None, padding=(0, 2))
    table.add_column("Field", style="bold cyan", no_wrap=True)
    table.add_column("Value", overflow="fold")

    rows = (
        ("record type", "record_type"),
        ("value", "value"),
        ("name", "name"),
        ("--zone", "--zone"),
        ("target record", "target_record"),
        ("Context", "dns_context"),
        ("resolved zone", "resolved_zone"),
        ("-t/--ttl", "-t/--ttl"),
        ("--noptr", "--noptr"),
        ("-c/--comment", "-c/--comment"),
        ("WAPI object", "wapi_object"),
    )
    for label, key in rows:
        if key == "dns_context":
            table.add_row(label, dns_context_line_text(context))
        else:
            table.add_row(label, dns_create_error_value(context.get(key)))
    hints = context.get("hints") or context.get("hint")
    if hints:
        table.add_row("Hints", dns_create_error_hint_value(hints))

    return Panel(
        table,
        title="DNS Create Error Details",
        border_style="red",
        style="white on #0f172a",
        padding=(0, 1),
    )


def print_dns_create_error_context(context: dict[str, Any]) -> None:
    """Print create failure context to stderr so stdout remains usable for structured output."""
    err_console.print(dns_create_error_context_panel(context))


def run_dns_create(
    record_type: str,
    value: str,
    name: str,
    zone: str | None,
    ttl: int | None,
    noptr: bool,
    comment: str | None,
) -> None:
    """Run the DNS create workflow, centralizing validation, WAPI POST, cache refresh, and output."""
    resolved_zone = None
    view = None
    object_type = None
    try:
        config = load_config()
        client = InfobloxClient(config)
        view = getattr(client, "view", config.get("dns_view", "default"))
        with infoblox_wait_spinner():
            resolved_zone = resolve_dns_create_zone(config, client, record_type, name, zone)
            warn_if_cname_target_unresolved(record_type, value)
            object_type, payload = create_payload(
                record_type,
                value,
                name,
                resolved_zone,
                ttl,
                comment,
                client,
            )
            client.request("POST", object_type, payload=payload)
    except CliError as exc:
        error_message = str(exc)
        context = dns_create_error_context(
            record_type,
            value,
            name,
            zone,
            ttl,
            noptr,
            comment,
            resolved_zone=resolved_zone,
            view=view,
            object_type=object_type,
            error_message=error_message,
        )
        raise DnsCreateError(error_message, context) from exc
    if noptr and record_type.lower() not in {"a", "aaaa"}:
        print_warning("WARNING: --noptr only applies to A/AAAA workflows and was ignored.")
    refresh_dns_cache_after_update()
    if not output_is_table():
        emit_action_result(
            status="success",
            action="create",
            type=record_type.upper(),
            name=payload.get("name") or dns_create_target_name(name, resolved_zone),
            zone=resolved_zone,
            view=view,
            message=f"created {record_type.upper()} record",
        )
        return
    print_success(f"SUCCESS: created {record_type.upper()} record")


def update_value_payload(record_type: str, value: str) -> dict[str, Any]:
    """Build the value-changing part of an edit payload according to the selected record type."""
    record_type = record_type.lower()
    spec = RECORD_TYPES.get(record_type)
    if not spec:
        supported = ", ".join(sorted(RECORD_TYPES))
        raise CliError(f"ERROR: unsupported record type '{record_type}'. Supported: {supported}")

    if record_type == "mx":
        return mx_payload(value)
    if record_type == "srv":
        return srv_payload(value)
    if record_type == "host":
        return host_payload(value)
    if record_type == "ptr":
        return {"ptrdname": value.rstrip(".")}

    value_field = spec["value_field"]
    return {value_field: value.rstrip(".") if record_type == "cname" else value}


def update_payload(
    record_type: str,
    value: str | None,
    ttl: int | None,
    comment: str | None,
) -> dict[str, Any]:
    """Combine value, TTL, and comment updates so edit sends only requested WAPI fields."""
    payload = {
        **ttl_payload(ttl),
    }
    if value is not None:
        payload.update(update_value_payload(record_type, value))
    record_comment = normalize_record_comment(comment)
    if record_comment:
        payload["comment"] = record_comment
    if not payload:
        raise CliError("ERROR: nothing to update. Provide TYPE VALUE, -t/--ttl, or -c/--comment.")
    return payload


def object_query_params(
    spec: dict[str, Any],
    client: InfobloxClient,
    extra: dict[str, Any],
) -> dict[str, Any]:
    """Build record query parameters with view and return fields consistently for all record types."""
    return {
        "_return_fields": spec["return_fields"],
        "view": client.view,
        **extra,
    }


def zone_query_params(
    client: InfobloxClient,
    extra: dict[str, Any] | None = None,
    return_fields: str = ZONE_RETURN_FIELDS,
) -> dict[str, Any]:
    """Build zone query parameters with view and return fields consistently for zone workflows."""
    return {
        "_return_fields": return_fields,
        "view": client.view,
        **(extra or {}),
    }


def allrecords_query_params(client: InfobloxClient, zone_name: str) -> dict[str, Any]:
    """Build allrecords query parameters for a zone so list/search use the same WAPI fields."""
    return {
        "_return_fields": ALLRECORDS_RETURN_FIELDS,
        "view": client.view,
        "zone": normalize_zone_name(zone_name),
    }


def zone_search_params(
    client: InfobloxClient,
    field: str,
    search: str | None = None,
) -> dict[str, Any]:
    """Build zone search parameters for name or comment lookup while preserving view scoping."""
    extra = {}
    if search:
        extra[f"{field}~"] = search_pattern(search, case_sensitive=False)
    return zone_query_params(client, extra)


def zone_result_key(zone: dict[str, Any]) -> str:
    """Return a stable key for zone deduplication because WAPI searches can return overlaps."""
    if zone.get("_ref"):
        return str(zone["_ref"])
    return json.dumps(
        {
            "fqdn": zone.get("fqdn", ""),
            "view": zone.get("view", ""),
            "zone_format": zone.get("zone_format", ""),
        },
        sort_keys=True,
    )


def query_zones(client: InfobloxClient, search: str | None = None) -> list[dict[str, Any]]:
    """Query zones by name and comment separately, then merge results because WAPI filters are conjunctive."""
    if not search:
        return paged_query(client, ZONE_OBJECT, zone_query_params(client))

    zones: list[dict[str, Any]] = []
    seen: set[str] = set()
    for field in ("fqdn", "comment"):
        for zone in paged_query(client, ZONE_OBJECT, zone_search_params(client, field, search)):
            key = zone_result_key(zone)
            if key in seen:
                continue
            seen.add(key)
            zones.append(zone)
    return zones


def safe_query(client: InfobloxClient, object_type: str, params: dict[str, Any]) -> list[dict[str, Any]]:
    """Wrap list-returning WAPI queries so unexpected response shapes become controlled CLI errors."""
    try:
        result = client.request("GET", object_type, params=params)
    except WapiError as exc:
        if exc.status in {400, 404} and "field" in str(exc).lower():
            print_warning(f"WARNING: skipping {object_type}: {exc}")
            return []
        raise
    return result if isinstance(result, list) else []


def paged_query(
    client: InfobloxClient,
    object_type: str,
    params: dict[str, Any],
    warn_on_skip: bool = True,
) -> list[dict[str, Any]]:
    """Retrieve all WAPI pages so list/search commands are complete without using a terminal pager."""
    page_params: dict[str, Any] = {
        **params,
        "_paging": 1,
        "_return_as_object": 1,
        "_max_results": WAPI_PAGE_SIZE,
    }
    results: list[dict[str, Any]] = []
    page_id = ""

    while True:
        request_params = dict(page_params)
        if page_id:
            request_params["_page_id"] = page_id

        try:
            response = client.request("GET", object_type, params=request_params)
        except WapiError as exc:
            if exc.status in {400, 404} and "field" in str(exc).lower():
                if warn_on_skip:
                    print_warning(f"WARNING: skipping {object_type}: {exc}")
                return []
            raise

        if isinstance(response, list):
            results.extend(response)
            return results
        if not isinstance(response, dict):
            return results

        page_result = response.get("result", [])
        if not isinstance(page_result, list):
            raise CliError(f"ERROR: unexpected WAPI result shape for {object_type}.")
        results.extend(page_result)

        page_id = str(response.get("next_page_id", "") or "")
        if not page_id:
            return results


def search_fields(spec: dict[str, Any]) -> tuple[str, ...]:
    """Return searchable fields for a record type so search behavior stays data-driven."""
    return ("name", *spec.get("search_value_fields", ()), "comment")


def case_insensitive_literal_pattern(keyword: str) -> str:
    """Build a case-insensitive literal regex without inline flags because WAPI rejects (?i)."""
    parts = []
    for char in keyword:
        if char.isascii() and char.isalpha():
            parts.append(f"[{char.lower()}{char.upper()}]")
        else:
            parts.append(re.escape(char))
    return "".join(parts)


def search_pattern(keyword: str, case_sensitive: bool) -> str:
    """Choose the WAPI search pattern according to the case-sensitivity option."""
    return re.escape(keyword) if case_sensitive else case_insensitive_literal_pattern(keyword)


def is_zone_or_child(zone_name: str, parent_zone: str) -> bool:
    """Return whether a zone belongs under a parent so scoped searches include child zones."""
    zone = normalize_zone_name(zone_name)
    parent = normalize_zone_name(parent_zone)
    return zone == parent or zone.endswith(f".{parent}")


def zone_serial(zone_info: dict[str, Any]) -> str | None:
    """Extract a zone serial as text so cache validation can compare values safely."""
    serial = zone_info.get("soa_serial_number")
    return str(serial) if serial is not None else None


def is_secondary_zone(zone_info: dict[str, Any]) -> bool:
    """Detect secondary zones so refresh logic can avoid relying on unavailable primary data."""
    primary_type = str(zone_info.get("primary_type", "")).strip().lower()
    return primary_type in {"external", "microsoft", "secondary"}


def is_reverse_zone_name(zone_name: str) -> bool:
    """Detect reverse zones so forward-record commands can exclude PTR-oriented data."""
    try:
        normalized = normalize_zone_name(zone_name)
    except CliError:
        normalized = zone_name.strip().rstrip(".").lower()
    return normalized.endswith(REVERSE_ZONE_SUFFIXES)


def is_forward_zone(zone_info: dict[str, Any]) -> bool:
    """Return whether a zone is forward-looking so completions avoid reverse DNS targets."""
    zone_format = str(zone_info.get("zone_format", "")).strip().upper()
    if zone_format in {"IPV4", "IPV6"}:
        return False
    if zone_format and zone_format != "FORWARD":
        return False
    return not is_reverse_zone_name(str(zone_info.get("fqdn", "")))


def search_root_zone(config: dict[str, str]) -> str | None:
    """Resolve the default search root so normal search stays scoped unless -g is used."""
    try:
        return resolve_dns_zone(config)
    except CliError:
        return None


def record_result_key(item: dict[str, Any]) -> str:
    """Return a stable record key for deduplication because allrecords and typed records can overlap."""
    return str(item.get("_ref") or json.dumps(item, sort_keys=True))


def allrecords_cache_key(client: InfobloxClient, zone_name: str) -> str:
    """Build a per-server/view/zone cache key so cached DNS data does not cross contexts."""
    cache_key = json.dumps(
        {
            "server": client.server,
            "wapi_version": client.wapi_version,
            "view": client.view,
            "zone": normalize_zone_name(zone_name),
        },
        sort_keys=True,
    )
    return hashlib.sha256(cache_key.encode("utf-8")).hexdigest()


def allrecords_cache_file(client: InfobloxClient, zone_name: str) -> Path:
    """Return the legacy JSON cache path for compatibility with older cache files."""
    return ALLRECORDS_CACHE_DIR / f"{allrecords_cache_key(client, zone_name)}.json"


def allrecords_cache_db_file() -> Path:
    """Return the SQLite cache path used by current allrecords search caching."""
    return ALLRECORDS_CACHE_DIR / "cache.sqlite3"


def search_cache_prewarm_lock_file() -> Path:
    """Return the lock path that prevents duplicate background cache warmers."""
    return ALLRECORDS_CACHE_DIR / "prewarm.lock"


def clear_dns_cache() -> None:
    """Remove DNS cache files after writes so search and completion do not return stale data."""
    try:
        if ALLRECORDS_CACHE_DIR.is_dir():
            shutil.rmtree(ALLRECORDS_CACHE_DIR)
        else:
            ALLRECORDS_CACHE_DIR.unlink(missing_ok=True)
    except OSError:
        pass

    try:
        ZONE_COMPLETION_CACHE_FILE.unlink()
    except FileNotFoundError:
        pass
    except OSError:
        pass


def zone_serial_cache_key(client: InfobloxClient) -> str:
    """Build the zone-serial cache key so serial state is scoped to server and view."""
    cache_key = json.dumps(
        {
            "server": client.server,
            "wapi_version": client.wapi_version,
            "view": client.view,
        },
        sort_keys=True,
    )
    return hashlib.sha256(cache_key.encode("utf-8")).hexdigest()


def zone_serial_cache_revalidate_lock_file(client: InfobloxClient) -> Path:
    """Return the per-context lock path for hidden zone-serial refresh work."""
    return ALLRECORDS_CACHE_DIR / f"zone-serial-{zone_serial_cache_key(client)}.lock"


def zone_completion_cache_revalidate_lock_file(view: str) -> Path:
    """Return the per-view lock path for hidden zone-completion refresh work."""
    cache_key = hashlib.sha256(normalize_dns_view(view).encode("utf-8")).hexdigest()
    return CONFIG_DIR / f"zone-completion-{cache_key}.lock"


def ensure_allrecords_cache_dir() -> None:
    """Create the cache directory before cache reads or writes so callers stay simple."""
    ALLRECORDS_CACHE_DIR.parent.mkdir(mode=0o700, exist_ok=True)
    ALLRECORDS_CACHE_DIR.mkdir(mode=0o700, exist_ok=True)
    try:
        os.chmod(ALLRECORDS_CACHE_DIR.parent, 0o700)
        os.chmod(ALLRECORDS_CACHE_DIR, 0o700)
    except OSError:
        pass


def initialize_search_cache_db(conn: sqlite3.Connection) -> None:
    """Create or migrate SQLite cache tables so current and older cache layouts both work."""
    conn.executescript(
        """
        CREATE TABLE IF NOT EXISTS zone_serial_cache (
            cache_key TEXT PRIMARY KEY,
            server TEXT NOT NULL,
            wapi_version TEXT NOT NULL,
            view TEXT NOT NULL,
            created_at REAL NOT NULL,
            zones_json TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS zone_record_cache (
            cache_key TEXT PRIMARY KEY,
            server TEXT NOT NULL,
            wapi_version TEXT NOT NULL,
            view TEXT NOT NULL,
            zone TEXT NOT NULL,
            serial_number TEXT NOT NULL,
            updated_at REAL NOT NULL
        );

        CREATE TABLE IF NOT EXISTS search_entries (
            cache_key TEXT NOT NULL,
            record_key TEXT NOT NULL,
            type TEXT NOT NULL,
            zone TEXT NOT NULL,
            name TEXT NOT NULL,
            value TEXT NOT NULL,
            comment TEXT NOT NULL,
            record_json TEXT NOT NULL,
            PRIMARY KEY (cache_key, record_key)
        );

        CREATE INDEX IF NOT EXISTS idx_search_entries_cache
            ON search_entries(cache_key);
        CREATE INDEX IF NOT EXISTS idx_search_entries_zone_name
            ON search_entries(cache_key, zone, name);
        """
    )


def connect_search_cache_db() -> sqlite3.Connection:
    """Open the SQLite cache with row access and initialized schema for callers."""
    ensure_allrecords_cache_dir()
    db_file = allrecords_cache_db_file()
    conn = sqlite3.connect(db_file, timeout=30)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA busy_timeout = 30000")
    try:
        conn.execute("PRAGMA journal_mode = WAL")
        conn.execute("PRAGMA synchronous = NORMAL")
    except sqlite3.Error:
        pass
    initialize_search_cache_db(conn)
    try:
        os.chmod(db_file, 0o600)
    except OSError:
        pass
    return conn


def connect_search_cache_db_readonly() -> sqlite3.Connection:
    """Open the existing SQLite cache without schema writes for shell-completion fallbacks."""
    db_path = urllib.parse.quote(str(allrecords_cache_db_file()), safe="/")
    last_error: sqlite3.Error | None = None
    for query in ("mode=ro", "mode=ro&immutable=1"):
        conn: sqlite3.Connection | None = None
        try:
            conn = sqlite3.connect(f"file:{db_path}?{query}", uri=True, timeout=30)
            conn.row_factory = sqlite3.Row
            conn.execute("SELECT name FROM sqlite_master LIMIT 1").fetchone()
            return conn
        except sqlite3.Error as exc:
            last_error = exc
            if conn is not None:
                conn.close()
    raise last_error or sqlite3.OperationalError("unable to open search cache read-only")


def normalize_zone_serial_cache(zones: Any) -> list[dict[str, Any]] | None:
    """Validate zone serial cache payloads so corrupt JSON can be ignored safely."""
    if not isinstance(zones, list) or not all(isinstance(zone, dict) for zone in zones):
        return None
    return zones


def read_zone_serial_cache(client: InfobloxClient) -> ZoneSerialCacheRead | None:
    """Read zone serials and flag slightly stale entries for background refresh."""
    try:
        with connect_search_cache_db() as conn:
            row = conn.execute(
                "SELECT created_at, zones_json FROM zone_serial_cache WHERE cache_key = ?",
                (zone_serial_cache_key(client),),
            ).fetchone()
    except (OSError, sqlite3.Error):
        return None

    if row is None:
        return None

    try:
        age = time.time() - float(row["created_at"])
    except (TypeError, ValueError):
        return None
    max_age = ZONE_SERIAL_CACHE_TTL + ZONE_SERIAL_CACHE_STALE_WHILE_REVALIDATE_SECONDS
    if age > max_age:
        return None

    try:
        zones = json.loads(str(row["zones_json"]))
    except json.JSONDecodeError:
        return None
    normalized_zones = normalize_zone_serial_cache(zones)
    if normalized_zones is None:
        return None
    return ZoneSerialCacheRead(
        zones=normalized_zones,
        should_revalidate=age > ZONE_SERIAL_CACHE_TTL,
    )


def write_zone_serial_cache(client: InfobloxClient, zones: list[dict[str, Any]]) -> None:
    """Persist zone serials for later cache validation and tolerate cache write failures."""
    try:
        with connect_search_cache_db() as conn:
            conn.execute(
                """
                INSERT OR REPLACE INTO zone_serial_cache
                    (cache_key, server, wapi_version, view, created_at, zones_json)
                VALUES (?, ?, ?, ?, ?, ?)
                """,
                (
                    zone_serial_cache_key(client),
                    client.server,
                    client.wapi_version,
                    client.view,
                    time.time(),
                    json.dumps(zones),
                ),
            )
    except (OSError, sqlite3.Error):
        return


def sqlite_zone_record_cache_is_valid(
    conn: sqlite3.Connection,
    cache_key: str,
    serial_number: str,
) -> bool:
    """Check whether cached entries match the current zone serial before using them."""
    row = conn.execute(
        "SELECT serial_number FROM zone_record_cache WHERE cache_key = ?",
        (cache_key,),
    ).fetchone()
    return row is not None and str(row["serial_number"]) == serial_number


def sqlite_search_entry_from_row(row: sqlite3.Row) -> dict[str, Any] | None:
    """Convert one SQLite row into a cached search entry while dropping corrupt JSON rows."""
    try:
        record = json.loads(str(row["record_json"]))
    except json.JSONDecodeError:
        return None
    if not isinstance(record, dict):
        return None

    record_type = str(row["type"])
    value = str(row["value"])
    if record_type == "ptr":
        value = allrecord_search_value(record_type, record) or value

    return {
        "type": record_type,
        "zone": str(row["zone"]),
        "name": str(row["name"]),
        "value": value,
        "comment": str(row["comment"]),
        "record": record,
    }


def read_sqlite_allrecords_search_entries(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> list[dict[str, Any]] | None:
    """Read cached allrecords entries for one zone when the serial proves them current."""
    if serial_number is None:
        return None
    cache_key = allrecords_cache_key(client, zone_name)
    try:
        with connect_search_cache_db() as conn:
            if not sqlite_zone_record_cache_is_valid(conn, cache_key, serial_number):
                return None
            rows = conn.execute(
                """
                SELECT type, zone, name, value, comment, record_json
                FROM search_entries
                WHERE cache_key = ?
                ORDER BY lower(zone), lower(name), lower(type), lower(value), record_key
                """,
                (cache_key,),
            ).fetchall()
    except (OSError, sqlite3.Error):
        return None

    return sqlite_search_entries_from_rows(rows)


def sqlite_search_entries_from_rows(
    rows: list[sqlite3.Row],
) -> list[dict[str, Any]] | None:
    """Convert SQLite rows to entries, treating corrupt rows as cache misses."""
    entries: list[dict[str, Any]] = []
    for row in rows:
        entry = sqlite_search_entry_from_row(row)
        if entry is None:
            return None
        entries.append(entry)
    return entries


def sqlite_exact_search_condition(
    keyword: str,
    case_sensitive: bool,
) -> tuple[str, tuple[str, ...]]:
    """Build the SQL predicate for the normal exact search path."""
    if case_sensitive:
        condition = (
            "instr(name, ?) > 0 OR "
            "instr(value, ?) > 0 OR "
            "instr(comment, ?) > 0 OR "
            "(type = 'ptr' AND instr(record_json, ?) > 0)"
        )
        return condition, (keyword, keyword, keyword, keyword)

    needle = keyword.lower()
    condition = (
        "instr(lower(name), ?) > 0 OR "
        "instr(lower(value), ?) > 0 OR "
        "instr(lower(comment), ?) > 0 OR "
        "(type = 'ptr' AND instr(lower(record_json), ?) > 0)"
    )
    return condition, (needle, needle, needle, needle)


def matching_allrecord_search_entries(
    entries: list[dict[str, Any]],
    keyword: str,
    case_sensitive: bool,
    fuzzy_search: bool,
) -> list[dict[str, Any]]:
    """Filter cached entries with the same logic used after live fetches."""
    return [
        entry
        for entry in entries
        if allrecord_search_entry_matches_keyword(
            entry,
            keyword,
            case_sensitive,
            fuzzy_search,
        )
    ]


def search_sqlite_allrecords_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
    keyword: str,
    case_sensitive: bool,
    fuzzy_search: bool = False,
) -> list[dict[str, Any]] | None:
    """Search cached entries, scanning all valid rows when fuzzy matching is enabled."""
    if serial_number is None:
        return None
    cache_key = allrecords_cache_key(client, zone_name)
    if not keyword:
        return read_sqlite_allrecords_search_entries(client, zone_name, serial_number)

    if fuzzy_search:
        entries = read_sqlite_allrecords_search_entries(client, zone_name, serial_number)
        if entries is None:
            return None
        return matching_allrecord_search_entries(
            entries,
            keyword,
            case_sensitive,
            fuzzy_search=True,
        )

    condition, params = sqlite_exact_search_condition(keyword, case_sensitive)
    try:
        with connect_search_cache_db() as conn:
            if not sqlite_zone_record_cache_is_valid(conn, cache_key, serial_number):
                return None
            rows = conn.execute(
                f"""
                SELECT type, zone, name, value, comment, record_json
                FROM search_entries
                WHERE cache_key = ? AND ({condition})
                """,
                (cache_key, *params),
            ).fetchall()
    except (OSError, sqlite3.Error):
        return None

    entries = sqlite_search_entries_from_rows(rows)
    if entries is None:
        return None
    return matching_allrecord_search_entries(
        entries,
        keyword,
        case_sensitive,
        fuzzy_search=False,
    )


def read_legacy_allrecords_cache_payload(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> dict[str, Any] | None:
    """Read the older JSON cache format so users are not forced to rebuild immediately."""
    if serial_number is None:
        return None
    try:
        with allrecords_cache_file(client, zone_name).open("r", encoding="utf-8") as handle:
            cache = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(cache, dict):
        return None
    if cache.get("server") != client.server or cache.get("view") != client.view:
        return None
    if cache.get("zone") != normalize_zone_name(zone_name):
        return None
    if str(cache.get("soa_serial_number", "")) != serial_number:
        return None
    return cache


def read_allrecords_cache_payload(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> dict[str, Any] | None:
    """Read either current or legacy cache payloads so cache migration is transparent."""
    entries = read_sqlite_allrecords_search_entries(client, zone_name, serial_number)
    if entries is not None:
        return {
            "server": client.server,
            "wapi_version": client.wapi_version,
            "view": client.view,
            "zone": normalize_zone_name(zone_name),
            "soa_serial_number": serial_number,
            "records": [entry["record"] for entry in entries],
            "search_entries": entries,
        }

    return read_legacy_allrecords_cache_payload(client, zone_name, serial_number)


def cached_records(cache: dict[str, Any]) -> list[dict[str, Any]] | None:
    """Extract records from a cache payload only when the payload shape is usable."""
    records = cache.get("records")
    if not isinstance(records, list) or not all(isinstance(item, dict) for item in records):
        return None
    return records


def read_allrecords_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> list[dict[str, Any]] | None:
    """Read legacy allrecords cache data when still valid for compatibility paths."""
    cache = read_allrecords_cache_payload(client, zone_name, serial_number)
    return cached_records(cache) if cache else None


def allrecord_search_entry(item: dict[str, Any], zone_name: str | None = None) -> dict[str, Any]:
    """Normalize one allrecords item into the cache/search entry shape."""
    record_type = allrecord_type(item)
    return {
        "type": record_type,
        "zone": str(item.get("zone", "") or zone_name or ""),
        "name": allrecord_display_name(item),
        "value": allrecord_search_value(record_type, item),
        "comment": str(item.get("comment", "")),
        "record": item,
    }


def allrecord_search_entries(
    records: list[dict[str, Any]],
    zone_name: str | None = None,
) -> list[dict[str, Any]]:
    """Normalize all allrecords items for one zone so search and list consume the same shape."""
    return [allrecord_search_entry(item, zone_name) for item in records]


def normalize_cached_search_entry(entry: Any) -> dict[str, Any] | None:
    """Validate one cached search entry so corrupt cache rows are skipped safely."""
    if not isinstance(entry, dict):
        return None
    record = entry.get("record")
    if not isinstance(record, dict):
        return None

    return {
        "type": str(entry.get("type", "")),
        "zone": str(entry.get("zone", "")),
        "name": str(entry.get("name", "")),
        "value": str(entry.get("value", "")),
        "comment": str(entry.get("comment", "")),
        "record": record,
    }


def normalize_cached_search_entries(entries: Any) -> list[dict[str, Any]] | None:
    """Validate cached search entries as a list so callers get clean record data."""
    if not isinstance(entries, list):
        return None

    normalized = []
    for entry in entries:
        normalized_entry = normalize_cached_search_entry(entry)
        if normalized_entry is None:
            return None
        normalized.append(normalized_entry)
    return normalized


def read_allrecords_search_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> list[dict[str, Any]] | None:
    """Read all cached search entries for a zone, preferring SQLite and falling back to legacy cache."""
    cached_entries = read_sqlite_allrecords_search_entries(client, zone_name, serial_number)
    if cached_entries is not None:
        return cached_entries

    cache = read_legacy_allrecords_cache_payload(client, zone_name, serial_number)
    if not cache:
        return None

    search_entries = normalize_cached_search_entries(cache.get("search_entries"))
    if search_entries is not None:
        records = cached_records(cache)
        if records is not None:
            write_allrecords_cache(client, zone_name, serial_number, records, search_entries)
        return search_entries

    records = cached_records(cache)
    if records is None:
        return None

    search_entries = allrecord_search_entries(records, zone_name)
    write_allrecords_cache(client, zone_name, serial_number, records, search_entries)
    return search_entries


def write_allrecords_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
    records: list[dict[str, Any]],
    search_entries: list[dict[str, Any]] | None = None,
) -> None:
    """Persist allrecords entries to SQLite so search and completion can reuse them quickly."""
    if serial_number is None:
        return
    if search_entries is None:
        search_entries = allrecord_search_entries(records, zone_name)
    cache_key = allrecords_cache_key(client, zone_name)
    normalized_zone = normalize_zone_name(zone_name)
    now = time.time()
    rows = []
    for entry in search_entries:
        record = allrecord_search_entry_record(entry)
        if not record:
            continue
        try:
            record_json = json.dumps(record, sort_keys=True)
        except (TypeError, ValueError):
            continue
        rows.append(
            (
                cache_key,
                record_result_key(record),
                str(entry.get("type", "")),
                str(entry.get("zone", "") or normalized_zone),
                str(entry.get("name", "")),
                str(entry.get("value", "")),
                str(entry.get("comment", "")),
                record_json,
            )
        )

    try:
        with connect_search_cache_db() as conn:
            conn.execute(
                """
                INSERT OR REPLACE INTO zone_record_cache
                    (cache_key, server, wapi_version, view, zone, serial_number, updated_at)
                VALUES (?, ?, ?, ?, ?, ?, ?)
                """,
                (
                    cache_key,
                    client.server,
                    client.wapi_version,
                    client.view,
                    normalized_zone,
                    str(serial_number),
                    now,
                ),
            )
            conn.execute("DELETE FROM search_entries WHERE cache_key = ?", (cache_key,))
            conn.executemany(
                """
                INSERT OR REPLACE INTO search_entries
                    (cache_key, record_key, type, zone, name, value, comment, record_json)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                """,
                rows,
            )
    except (OSError, sqlite3.Error):
        return


def fetch_zone_serials(client: InfobloxClient) -> list[dict[str, Any]]:
    """Fetch zone serials directly from WAPI so foreground and background refresh paths agree."""
    return paged_query(
        client,
        ZONE_OBJECT,
        zone_query_params(client, return_fields=ZONE_SERIAL_RETURN_FIELDS),
    )


def query_zone_serials(client: InfobloxClient) -> list[dict[str, Any]]:
    """Return cached zone serials, refreshing synchronously only outside the SWR window."""
    cached_zones = read_zone_serial_cache(client)
    if cached_zones is not None:
        if cached_zones.should_revalidate:
            start_zone_serial_cache_revalidation()
        return cached_zones.zones

    zones = fetch_zone_serials(client)
    write_zone_serial_cache(client, zones)
    return zones


def search_zones(client: InfobloxClient, root_zone: str | None) -> list[dict[str, Any]]:
    """Select zones within the requested search scope so normal search stays zone-limited."""
    zones = query_zone_serials(client)
    if not root_zone:
        return sorted(
            [zone for zone in zones if not is_secondary_zone(zone)],
            key=lambda zone: str(zone.get("fqdn", "")).lower(),
        )

    filtered = []
    seen_names: set[str] = set()
    for zone in zones:
        zone_name = str(zone.get("fqdn", "")).strip()
        if not zone_name:
            continue
        try:
            normalized = normalize_zone_name(zone_name)
        except CliError:
            continue
        if is_zone_or_child(normalized, root_zone):
            seen_names.add(normalized)
            if is_secondary_zone(zone):
                continue
            filtered.append(zone)

    normalized_root = normalize_zone_name(root_zone)
    if normalized_root not in seen_names:
        filtered.append({"fqdn": normalized_root, "view": client.view})
    return sorted(filtered, key=lambda zone: str(zone.get("fqdn", "")).lower())


def allrecords_for_zone(client: InfobloxClient, zone_info: dict[str, Any]) -> list[dict[str, Any]]:
    """Fetch allrecords for one zone while skipping zones that cannot provide reliable records."""
    zone_name = normalize_zone_name(str(zone_info.get("fqdn", "")))
    serial_number = zone_serial(zone_info)
    cached_records = read_allrecords_cache(client, zone_name, serial_number)
    if cached_records is not None:
        return cached_records

    records = paged_query(client, ALLRECORDS_OBJECT, allrecords_query_params(client, zone_name))
    write_allrecords_cache(client, zone_name, serial_number, records)
    return records


def allrecords_search_entries_for_zone(
    client: InfobloxClient,
    zone_info: dict[str, Any],
) -> list[dict[str, Any]]:
    """Return cached or freshly queried search entries for a zone based on SOA serial checks."""
    zone_name = normalize_zone_name(str(zone_info.get("fqdn", "")))
    serial_number = zone_serial(zone_info)
    cached_entries = read_allrecords_search_cache(client, zone_name, serial_number)
    if cached_entries is not None:
        return cached_entries

    records = paged_query(client, ALLRECORDS_OBJECT, allrecords_query_params(client, zone_name))
    search_entries = allrecord_search_entries(records, zone_name)
    write_allrecords_cache(client, zone_name, serial_number, records, search_entries)
    return search_entries


def record_in_zone_scope(item: dict[str, Any], root_zone: str) -> bool:
    """Return whether a record belongs to a search root so cached global data can be filtered locally."""
    zone_name = str(item.get("zone", "")).strip()
    if zone_name:
        return is_zone_or_child(zone_name, root_zone)

    record_name = str(item.get("name", "")).strip()
    return bool(record_name) and is_zone_or_child(record_name, root_zone)


def decoded_allrecords_ref(item: dict[str, Any]) -> str:
    """Decode allrecords references so unsupported synthetic record types can be identified."""
    ref = str(item.get("_ref", ""))
    prefix = f"{ALLRECORDS_OBJECT}/"
    if not ref.startswith(prefix):
        return ""

    token = ref[len(prefix) :].split(":", 1)[0]
    if not token:
        return ""

    padding = "=" * (-len(token) % 4)
    try:
        return base64.urlsafe_b64decode(f"{token}{padding}".encode("ascii")).decode(
            "utf-8",
            errors="ignore",
        )
    except (binascii.Error, UnicodeEncodeError, ValueError):
        return ""


def unsupported_allrecord_type(item: dict[str, Any]) -> str:
    """Infer display labels for known unsupported allrecords records so search output is clearer."""
    reference_text = " ".join(
        str(value)
        for value in (
            decoded_allrecords_ref(item),
            item.get("_ref", ""),
            item.get("record", ""),
            nested_record(item).get("_ref", ""),
        )
        if value
    ).lower()
    if "fake_bind_ns" in reference_text or "bind_ns" in reference_text or "record:ns/" in reference_text:
        return "ns"
    if "bind_soa" in reference_text or "record:soa/" in reference_text:
        return "soa"
    return "unsupported"


def allrecord_type(item: dict[str, Any]) -> str:
    """Return the normalized record type from allrecords data, including unsupported inferred types."""
    raw_type = str(item.get("type", "")).lower()
    if raw_type == "unsupported":
        return unsupported_allrecord_type(item)
    if raw_type.startswith("record:"):
        record_type = raw_type.split(":", 1)[1]
        if record_type in {"host_ipv4addr", "host_ipv6addr"}:
            return "host"
        return record_type
    if raw_type.startswith("sharedrecord:"):
        return raw_type.replace("sharedrecord:", "shared-", 1)
    return raw_type or "record"


def nested_record(item: dict[str, Any]) -> dict[str, Any]:
    """Return the nested concrete record payload when allrecords wraps typed record details."""
    record = item.get("record")
    return record if isinstance(record, dict) else {}


def first_record_value(item: dict[str, Any], keys: tuple[str, ...]) -> str:
    """Return the first populated value field from a record so display logic can stay generic."""
    record = nested_record(item)
    for key in keys:
        value = record.get(key, item.get(key))
        if value not in (None, ""):
            return str(value)
    return ""


def allrecord_display_name(item: dict[str, Any]) -> str:
    """Return the best record name from allrecords data, including nested record payloads."""
    return first_record_value(item, ("name",)) or str(item.get("name", ""))


def allrecord_display_value(record_type: str, item: dict[str, Any]) -> str:
    """Return the best display value for an allrecords entry based on its record type."""
    if record_type in {"cname", "shared-cname"}:
        return first_record_value(item, ("canonical",))
    if record_type in {"txt", "shared-txt"}:
        return first_record_value(item, ("text",))
    if record_type in {"ns", "shared-ns"}:
        return first_record_value(item, ("nameserver", "nsdname"))
    if record_type in {"mx", "shared-mx"}:
        exchanger = first_record_value(item, ("mail_exchanger",))
        preference = first_record_value(item, ("preference",))
        return f"{preference} {exchanger}".strip() if exchanger else ""
    if record_type in {"srv", "shared-srv"}:
        priority = first_record_value(item, ("priority",))
        weight = first_record_value(item, ("weight",))
        port = first_record_value(item, ("port",))
        target = first_record_value(item, ("target",))
        values = [priority, weight, port, target]
        return " ".join(value for value in values if value)
    if record_type == "ptr":
        return first_record_value(item, ("ptrdname", "ipv4addr", "ipv6addr"))
    if record_type == "host":
        values = []
        record = nested_record(item)
        for key, nested_key in (("ipv4addrs", "ipv4addr"), ("ipv6addrs", "ipv6addr")):
            for address in record.get(key, item.get(key, [])) or []:
                if isinstance(address, dict) and address.get(nested_key):
                    values.append(str(address[nested_key]))
                elif isinstance(address, str):
                    values.append(address)
        if values:
            return ", ".join(values)
    if record_type in {"a", "shared-a"}:
        return first_record_value(item, ("ipv4addr", "address"))
    if record_type in {"aaaa", "shared-aaaa"}:
        return first_record_value(item, ("ipv6addr", "address"))
    if item.get("address"):
        return str(item["address"])
    record = item.get("record")
    if record in (None, ""):
        return ""
    if isinstance(record, str) and record.startswith(("record:", "allrecords/")):
        return ""
    if isinstance(record, dict) and set(record) <= {"_ref"}:
        return ""
    return str(record)


def unique_record_field_values(item: dict[str, Any], keys: tuple[str, ...]) -> list[str]:
    """Collect unique scalar values from allrecords top-level and nested record payloads."""
    values: list[str] = []
    seen: set[str] = set()
    record = nested_record(item)
    for key in keys:
        for source in (record, item):
            value = source.get(key)
            if value in (None, "") or isinstance(value, (dict, list, tuple)):
                continue
            text = str(value).strip()
            if not text or text in seen:
                continue
            seen.add(text)
            values.append(text)
    return values


def normalized_ip_address_text(value: str) -> str:
    """Return a normalized IP address string, or empty text when the value is not an IP address."""
    try:
        return str(ipaddress.ip_address(value.strip()))
    except ValueError:
        return ""


def ptr_address_value(item: dict[str, Any]) -> str:
    """Prefer explicit PTR address fields when Infoblox includes them in the record payload."""
    for value in unique_record_field_values(item, ("address", "ipv4addr", "ipv6addr")):
        address = normalized_ip_address_text(value)
        if address:
            return address
    return ""


def ptr_ipv4_from_cidr_zone(name: str, zone: str) -> str:
    """Rebuild an IPv4 PTR name from Infoblox CIDR-style reverse zones."""
    try:
        network = ipaddress.ip_network(zone.strip().rstrip("."), strict=False)
    except ValueError:
        return ""
    if network.version != 4 or network.prefixlen % 8 != 0:
        return ""

    prefix_octets = network.prefixlen // 8
    labels = [label for label in name.strip().rstrip(".").split(".") if label]
    if len(labels) != 4 - prefix_octets:
        return ""

    host_octets: list[str] = []
    for label in reversed(labels):
        if not label.isdigit():
            return ""
        value = int(label)
        if value < 0 or value > 255:
            return ""
        host_octets.append(str(value))

    base_octets = str(network.network_address).split(".")[:prefix_octets]
    try:
        return str(ipaddress.IPv4Address(".".join([*base_octets, *host_octets])))
    except ipaddress.AddressValueError:
        return ""


def ptr_ipv4_from_in_addr(name: str, zone: str) -> str:
    """Rebuild an IPv4 PTR name from in-addr.arpa labels."""
    suffix = "in-addr.arpa"
    name_text = name.strip().rstrip(".").lower()
    zone_text = zone.strip().rstrip(".").lower()

    if name_text.endswith(suffix):
        reverse_text = name_text[: -len(suffix)].rstrip(".")
    elif zone_text.endswith(suffix):
        zone_reverse = zone_text[: -len(suffix)].rstrip(".")
        if name_text == zone_reverse or name_text.endswith(f".{zone_reverse}"):
            reverse_text = name_text
        elif name_text:
            reverse_text = f"{name_text}.{zone_reverse}"
        else:
            reverse_text = zone_reverse
    else:
        return ""

    labels = [label for label in reverse_text.split(".") if label]
    if len(labels) != 4:
        return ""
    for label in labels:
        if not label.isdigit():
            return ""
        value = int(label)
        if value < 0 or value > 255:
            return ""

    return str(ipaddress.IPv4Address(".".join(reversed(labels))))


def ptr_display_name(item: dict[str, Any]) -> str:
    """Display PTR names as normal IP addresses when enough reverse-zone context exists."""
    fallback_name = allrecord_display_name(item)
    address = ptr_address_value(item)
    if address:
        return address

    name_address = normalized_ip_address_text(fallback_name)
    if name_address:
        return name_address

    zone_name = first_record_value(item, ("zone",))
    return (
        ptr_ipv4_from_cidr_zone(fallback_name, zone_name)
        or ptr_ipv4_from_in_addr(fallback_name, zone_name)
        or fallback_name
    )


def ptr_search_value(item: dict[str, Any]) -> str:
    """Index PTR target and address data so normal IP searches find reverse records."""
    values = unique_record_field_values(
        item,
        ("ptrdname", "ipv4addr", "ipv6addr", "address"),
    )
    return " ".join(values)


def allrecord_search_value(record_type: str, item: dict[str, Any]) -> str:
    """Return indexed search value text while keeping display formatting separate."""
    if record_type == "ptr":
        return ptr_search_value(item)
    return allrecord_display_value(record_type, item)


def allrecord_search_values(record_type: str, item: dict[str, Any]) -> list[str]:
    """Collect searchable text for one allrecords entry so search covers name, value, and comment."""
    return [
        allrecord_display_name(item),
        allrecord_search_value(record_type, item),
        str(item.get("comment", "")),
    ]


def normalized_search_text(value: str, case_sensitive: bool) -> str:
    """Normalize search text once so exact and fuzzy paths honor the same case setting."""
    text = str(value).strip()
    return text if case_sensitive else text.lower()


def search_value_exact_match(value: str, keyword: str, case_sensitive: bool) -> bool:
    """Return exact substring matches, preserving the historical search behavior."""
    needle = normalized_search_text(keyword, case_sensitive)
    haystack = normalized_search_text(value, case_sensitive)
    return needle in haystack


def fuzzy_search_threshold(keyword: str) -> float:
    """Use lower short-word thresholds so one-letter typos still match compact names."""
    if len(keyword) <= FUZZY_SEARCH_SHORT_KEYWORD_LENGTH:
        return FUZZY_SEARCH_SHORT_RATIO
    if len(keyword) <= FUZZY_SEARCH_MEDIUM_KEYWORD_LENGTH:
        return FUZZY_SEARCH_MEDIUM_RATIO
    return FUZZY_SEARCH_RATIO


def fuzzy_search_length_is_close(keyword: str, candidate: str) -> bool:
    """Reject very different lengths early so fuzzy search stays typo-oriented."""
    max_difference = fuzzy_search_max_length_difference(keyword)
    return abs(len(candidate) - len(keyword)) <= max_difference


def fuzzy_search_max_length_difference(keyword: str) -> int:
    """Return the permitted length drift used by direct and sliding fuzzy comparisons."""
    if len(keyword) <= FUZZY_SEARCH_SHORT_KEYWORD_LENGTH:
        return 1
    return max(2, len(keyword) // 3)


def fuzzy_search_candidates(value: str) -> list[str]:
    """Return full fields and useful tokens so typos can match DNS labels and words."""
    text = str(value).strip()
    if not text:
        return []

    candidates = [text]
    for token in re.split(r"[^A-Za-z0-9]+", text):
        if not token:
            continue
        candidates.append(token)
        without_trailing_digits = re.sub(r"\d+$", "", token)
        if without_trailing_digits and without_trailing_digits != token:
            candidates.append(without_trailing_digits)

    deduplicated: list[str] = []
    seen: set[str] = set()
    for candidate in candidates:
        if candidate not in seen:
            seen.add(candidate)
            deduplicated.append(candidate)
    return deduplicated


def fuzzy_search_windows(candidate: str, keyword: str) -> list[str]:
    """Split long alphanumeric tokens into near-keyword windows for embedded-name typos."""
    if not candidate.isalnum() or len(candidate) <= len(keyword):
        return []

    max_difference = fuzzy_search_max_length_difference(keyword)
    min_size = max(FUZZY_SEARCH_MIN_KEYWORD_LENGTH, len(keyword) - max_difference)
    max_size = min(len(candidate), len(keyword) + max_difference)
    windows: list[str] = []
    for size in range(min_size, max_size + 1):
        for start in range(0, len(candidate) - size + 1):
            windows.append(candidate[start : start + size])
    return windows


def fuzzy_search_comparison_candidates(
    candidate: str,
    keyword: str,
    case_sensitive: bool,
) -> list[str]:
    """Return the direct token or sliding windows worth comparing."""
    normalized_candidate = normalized_search_text(candidate, case_sensitive)
    if not normalized_candidate:
        return []
    if fuzzy_search_length_is_close(keyword, normalized_candidate):
        return [normalized_candidate]
    return [
        normalized_search_text(window, case_sensitive)
        for window in fuzzy_search_windows(candidate, keyword)
    ]


def fuzzy_search_candidate_matches(
    keyword: str,
    candidate: str,
    threshold: float,
) -> bool:
    """Compare one normalized candidate after the length guard."""
    if not fuzzy_search_length_is_close(keyword, candidate):
        return False
    return difflib.SequenceMatcher(None, keyword, candidate).ratio() >= threshold


def search_value_fuzzy_match(value: str, keyword: str, case_sensitive: bool) -> bool:
    """Return typo-tolerant matches against useful tokens without making search too broad."""
    needle = normalized_search_text(keyword, case_sensitive)
    if len(needle) < FUZZY_SEARCH_MIN_KEYWORD_LENGTH:
        return False

    threshold = fuzzy_search_threshold(needle)
    for candidate in fuzzy_search_candidates(value):
        comparison_candidates = fuzzy_search_comparison_candidates(
            candidate,
            needle,
            case_sensitive,
        )
        for comparison_candidate in comparison_candidates:
            if fuzzy_search_candidate_matches(needle, comparison_candidate, threshold):
                return True
    return False


def search_value_matches_keyword(
    value: str,
    keyword: str,
    case_sensitive: bool,
    fuzzy_search: bool = False,
) -> bool:
    """Match one field exactly first, then by typo-tolerant fuzzy logic when enabled."""
    if search_value_exact_match(value, keyword, case_sensitive):
        return True
    return fuzzy_search and search_value_fuzzy_match(value, keyword, case_sensitive)


def allrecord_matches_keyword(
    item: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
    fuzzy_search: bool = False,
) -> bool:
    """Return whether one allrecords entry matches the keyword by exact or fuzzy text."""
    record_type = allrecord_type(item)
    for value in allrecord_search_values(record_type, item):
        if search_value_matches_keyword(value, keyword, case_sensitive, fuzzy_search):
            return True
    return False


def allrecord_search_entry_matches_keyword(
    entry: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
    fuzzy_search: bool = False,
) -> bool:
    """Apply exact or fuzzy matching to cached search entries so paths agree."""
    for key in ("name", "value", "comment"):
        value = str(entry.get(key, ""))
        if search_value_matches_keyword(value, keyword, case_sensitive, fuzzy_search):
            return True
    return False


def allrecord_search_entry_matches_exact_keyword(
    entry: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
) -> bool:
    """Return exact substring matches for exclusions and normal search mode."""
    return allrecord_search_entry_matches_keyword(
        entry,
        keyword,
        case_sensitive,
        fuzzy_search=False,
    )


def normalize_search_exclude_keywords(exclude_keywords: tuple[str, ...]) -> tuple[str, ...]:
    """Normalize repeated search exclusions while ignoring empty option values."""
    return tuple(keyword.strip() for keyword in exclude_keywords if keyword.strip())


def normalize_search_record_types(record_types: str | tuple[str, ...] | None) -> tuple[str, ...]:
    """Normalize comma-separated DNS search type filters while preserving user order."""
    if record_types is None:
        return ()
    if isinstance(record_types, str):
        raw_types = tuple(record_types.split(","))
    else:
        raw_types = tuple(
            part
            for record_type in record_types
            for part in str(record_type).split(",")
        )

    normalized: list[str] = []
    seen: set[str] = set()
    for raw_type in raw_types:
        record_type = str(raw_type).strip().lower()
        if not record_type:
            raise click.BadParameter("record types must be comma-separated non-empty values")
        if record_type not in RECORD_TYPES:
            supported = ", ".join(SEARCH_RECORD_TYPES)
            raise click.BadParameter(
                f"unsupported record type '{record_type}'. Supported: {supported}"
            )
        if record_type not in seen:
            normalized.append(record_type)
            seen.add(record_type)
    return tuple(normalized)


def parse_search_record_type_option(
    ctx: click.Context,
    param: click.Parameter,
    value: str | None,
) -> tuple[str, ...]:
    """Convert the search type option into normalized type filters for downstream code."""
    return normalize_search_record_types(value)


def complete_search_record_types(
    ctx: click.Context,
    param: click.Parameter,
    incomplete: str,
) -> list[CompletionItem]:
    """Complete comma-separated DNS record types for search filtering."""
    prefix, _separator, current = incomplete.rpartition(",")
    current = current.strip().lower()
    selected = {
        record_type.strip().lower()
        for record_type in prefix.split(",")
        if record_type.strip()
    }
    completion_prefix = f"{prefix}," if prefix else ""
    return [
        CompletionItem(f"{completion_prefix}{record_type}", help="DNS record type")
        for record_type in SEARCH_RECORD_TYPES
        if record_type not in selected and record_type.startswith(current)
    ]


def search_record_type_matches_filter(
    record_type: str,
    record_type_filter: frozenset[str],
) -> bool:
    """Return whether a result type should remain visible for the requested search filters."""
    if not record_type_filter:
        return True
    normalized_type = record_type.lower()
    if normalized_type.startswith("shared-"):
        normalized_type = normalized_type.removeprefix("shared-")
    return normalized_type in record_type_filter


def allrecord_search_entry_matches_any_keyword(
    entry: dict[str, Any],
    keywords: tuple[str, ...],
    case_sensitive: bool,
) -> bool:
    """Return whether a search entry exactly matches any exclusion keyword."""
    for keyword in keywords:
        if allrecord_search_entry_matches_exact_keyword(entry, keyword, case_sensitive):
            return True
    return False


def allrecord_search_entry_record(entry: dict[str, Any]) -> dict[str, Any]:
    """Return the record payload from a cached search entry for table/output rendering."""
    record = entry.get("record")
    return record if isinstance(record, dict) else {}


def allrecord_search_entry_type(entry: dict[str, Any]) -> str:
    """Return the cached record type in normalized form for display and sorting."""
    record = allrecord_search_entry_record(entry)
    entry_type = str(entry.get("type") or "")
    if entry_type.lower() == "unsupported":
        return allrecord_type(record)
    return entry_type or allrecord_type(record)


def allrecord_search_entry_sort_key(entry: dict[str, Any]) -> tuple[str, str, str, str, str]:
    """Build a stable sort key so DNS search and list output are predictable."""
    record = allrecord_search_entry_record(entry)
    record_type = allrecord_search_entry_type(entry)
    zone_name = str(entry.get("zone") or record.get("zone", ""))
    name = str(entry.get("name") or record_name(record))
    value = str(entry.get("value") or record_value(record_type, record))
    return (
        zone_name.lower(),
        name.lower(),
        record_type.lower(),
        value.lower(),
        record_result_key(record),
    )


def clone_infoblox_client(client: InfobloxClient) -> InfobloxClient:
    """Create a per-thread client that shares the WAPI connection pool safely."""
    attrs = (
        "server",
        "wapi_version",
        "username",
        "password",
        "view",
        "timeout",
        "verify_ssl",
    )
    if not all(hasattr(client, attr) for attr in attrs):
        return client

    return InfobloxClient(
        {
            "server": client.server,
            "wapi_version": client.wapi_version,
            "username": client.username,
            "password": client.password,
            "dns_view": client.view,
            "timeout": str(client.timeout),
            "verify_ssl": "true" if client.verify_ssl else "false",
        },
        connection_pool=getattr(client, "_connection_pool", None),
    )


def load_search_entries_for_zone(
    client: InfobloxClient,
    zone_info: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
    fuzzy_search: bool = False,
) -> list[dict[str, Any]]:
    """Load normalized search entries for one zone, preferring valid cache rows."""
    zone_name = normalize_zone_name(str(zone_info.get("fqdn", "")))
    serial_number = zone_serial(zone_info)
    entries = search_sqlite_allrecords_cache(
        client,
        zone_name,
        serial_number,
        keyword,
        case_sensitive,
        fuzzy_search,
    )
    if entries is None:
        entries = read_allrecords_search_cache(client, zone_name, serial_number)
    if entries is None:
        records = paged_query(
            client,
            ALLRECORDS_OBJECT,
            allrecords_query_params(client, zone_name),
        )
        entries = allrecord_search_entries(records, zone_name)
        write_allrecords_cache(client, zone_name, serial_number, records, entries)
    return entries


def search_entry_matches_request(
    entry: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
    root_zone: str | None,
    exclude_keywords: tuple[str, ...],
    fuzzy_search: bool,
) -> bool:
    """Apply keyword, root-zone, and exclusion filters to one search entry."""
    if not allrecord_search_entry_matches_keyword(
        entry,
        keyword,
        case_sensitive,
        fuzzy_search,
    ):
        return False

    record = allrecord_search_entry_record(entry)
    if root_zone and not record_in_zone_scope(record, root_zone):
        return False
    if exclude_keywords and allrecord_search_entry_matches_any_keyword(
        entry,
        exclude_keywords,
        case_sensitive,
    ):
        return False
    return True


def matching_search_entries_for_zone(
    client: InfobloxClient,
    zone_info: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
    root_zone: str | None,
    exclude_keywords: tuple[str, ...] = (),
    fuzzy_search: bool = False,
) -> list[dict[str, Any]]:
    """Return entries in one zone that satisfy the requested search filters."""
    exclude_keywords = normalize_search_exclude_keywords(exclude_keywords)
    entries = load_search_entries_for_zone(
        client,
        zone_info,
        keyword,
        case_sensitive,
        fuzzy_search,
    )
    return [
        entry
        for entry in entries
        if search_entry_matches_request(
            entry,
            keyword,
            case_sensitive,
            root_zone,
            exclude_keywords,
            fuzzy_search,
        )
    ]


def collect_dns_search_results(
    client: InfobloxClient,
    keyword: str,
    case_sensitive: bool,
    root_zone: str | None,
    exclude_keywords: tuple[str, ...] = (),
    fuzzy_search: bool = False,
    record_types: tuple[str, ...] = (),
    *,
    zone_filter: Callable[[dict[str, Any]], bool] | None = None,
) -> list[tuple[str, dict[str, Any]]]:
    """Collect search results across scoped zones concurrently while deduplicating records."""
    exclude_keywords = normalize_search_exclude_keywords(exclude_keywords)
    record_types = normalize_search_record_types(record_types)
    record_type_filter = frozenset(record_types)
    seen: set[str] = set()
    records: list[tuple[str, dict[str, Any]]] = []
    zones = search_zones(client, root_zone)
    if zone_filter is not None:
        zones = [zone for zone in zones if zone_filter(zone)]

    def collect_zone_entries(zone_info: dict[str, Any]) -> list[dict[str, Any]]:
        """Collect search entries for one zone inside the worker pool so failures stay local to that zone."""
        worker_client = clone_infoblox_client(client)
        return matching_search_entries_for_zone(
            worker_client,
            zone_info,
            keyword,
            case_sensitive,
            root_zone,
            exclude_keywords,
            fuzzy_search,
        )

    search_entries: list[dict[str, Any]] = []
    if len(zones) > 1:
        worker_count = min(DNS_SEARCH_WORKERS, len(zones))
        with ThreadPoolExecutor(max_workers=worker_count) as executor:
            for zone_entries in executor.map(collect_zone_entries, zones):
                search_entries.extend(zone_entries)
    elif zones:
        search_entries.extend(collect_zone_entries(zones[0]))

    for entry in sorted(search_entries, key=allrecord_search_entry_sort_key):
        record = allrecord_search_entry_record(entry)
        if not record:
            continue
        record_type = allrecord_search_entry_type(entry)
        if not search_record_type_matches_filter(record_type, record_type_filter):
            continue
        key = record_result_key(record)
        if key in seen:
            continue
        seen.add(key)
        records.append((record_type, record))
    return records


def search_cache_prewarm_lock_is_stale(lock_file: Path) -> bool:
    """Detect stale prewarm locks so abandoned background jobs do not block future warming."""
    try:
        return time.time() - lock_file.stat().st_mtime > PREWARM_LOCK_STALE_SECONDS
    except OSError:
        return True


def write_search_cache_prewarm_lock(lock_file: Path) -> tuple[int, str]:
    """Write a lock file with process identity so cache warmers coordinate without a daemon."""
    token = f"{os.getpid()}:{time.time()}"
    fd = os.open(lock_file, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o600)
    try:
        os.write(fd, f"{token}\n".encode("ascii"))
    except OSError:
        os.close(fd)
        raise
    return fd, token


def acquire_search_cache_prewarm_lock() -> tuple[int, str] | None:
    """Acquire the background prewarm lock, removing stale locks when safe."""
    try:
        ensure_allrecords_cache_dir()
        lock_file = search_cache_prewarm_lock_file()
        try:
            return write_search_cache_prewarm_lock(lock_file)
        except FileExistsError:
            if not search_cache_prewarm_lock_is_stale(lock_file):
                return None
            try:
                lock_file.unlink()
            except FileNotFoundError:
                pass
            except OSError:
                return None
            try:
                return write_search_cache_prewarm_lock(lock_file)
            except FileExistsError:
                return None
    except OSError:
        return None


def release_search_cache_prewarm_lock(lock: tuple[int, str]) -> None:
    """Release the prewarm lock only when this process still owns it."""
    lock_fd, token = lock
    try:
        os.close(lock_fd)
    except OSError:
        pass

    lock_file = search_cache_prewarm_lock_file()
    try:
        if lock_file.read_text(encoding="utf-8").strip() == token:
            lock_file.unlink()
    except (FileNotFoundError, OSError):
        pass


def acquire_zone_serial_cache_revalidate_lock(client: InfobloxClient) -> tuple[int, str] | None:
    """Acquire a per-view serial refresh lock so SWR starts at most one live refresh."""
    try:
        ensure_allrecords_cache_dir()
        lock_file = zone_serial_cache_revalidate_lock_file(client)
        try:
            return write_search_cache_prewarm_lock(lock_file)
        except FileExistsError:
            if not search_cache_prewarm_lock_is_stale(lock_file):
                return None
            try:
                lock_file.unlink()
            except FileNotFoundError:
                pass
            except OSError:
                return None
            try:
                return write_search_cache_prewarm_lock(lock_file)
            except FileExistsError:
                return None
    except OSError:
        return None


def release_zone_serial_cache_revalidate_lock(
    client: InfobloxClient,
    lock: tuple[int, str],
) -> None:
    """Release the serial refresh lock only when the hidden process still owns it."""
    lock_fd, token = lock
    try:
        os.close(lock_fd)
    except OSError:
        pass

    lock_file = zone_serial_cache_revalidate_lock_file(client)
    try:
        if lock_file.read_text(encoding="utf-8").strip() == token:
            lock_file.unlink()
    except (FileNotFoundError, OSError):
        pass


def acquire_zone_completion_cache_revalidate_lock(view: str) -> tuple[int, str] | None:
    """Acquire a per-view completion refresh lock so SWR starts at most one live refresh."""
    try:
        ensure_config_dir()
        lock_file = zone_completion_cache_revalidate_lock_file(view)
        try:
            return write_search_cache_prewarm_lock(lock_file)
        except FileExistsError:
            if not search_cache_prewarm_lock_is_stale(lock_file):
                return None
            try:
                lock_file.unlink()
            except FileNotFoundError:
                pass
            except OSError:
                return None
            try:
                return write_search_cache_prewarm_lock(lock_file)
            except FileExistsError:
                return None
    except (CliError, OSError):
        return None


def release_zone_completion_cache_revalidate_lock(
    view: str,
    lock: tuple[int, str],
) -> None:
    """Release the completion refresh lock only when the hidden process still owns it."""
    lock_fd, token = lock
    try:
        os.close(lock_fd)
    except OSError:
        pass

    lock_file = zone_completion_cache_revalidate_lock_file(view)
    try:
        if lock_file.read_text(encoding="utf-8").strip() == token:
            lock_file.unlink()
    except (CliError, FileNotFoundError, OSError):
        pass


def warm_search_cache(client: InfobloxClient, root_zone: str | None = None) -> None:
    """Warm search cache for all zones or for one zone scope when a root is supplied."""
    zones = search_zones(client, root_zone)

    def warm_zone(zone_info: dict[str, Any]) -> None:
        """Warm cache for one zone in the background prewarm pool so later completions/searches are faster."""
        try:
            allrecords_search_entries_for_zone(clone_infoblox_client(client), zone_info)
        except (CliError, WapiError, OSError, sqlite3.Error, ValueError):
            return

    if len(zones) > 1:
        worker_count = min(DNS_SEARCH_WORKERS, len(zones))
        with ThreadPoolExecutor(max_workers=worker_count) as executor:
            list(executor.map(warm_zone, zones))
    elif zones:
        warm_zone(zones[0])


def warm_global_search_cache(client: InfobloxClient) -> None:
    """Warm search cache for all zones so later search and completion are responsive."""
    warm_search_cache(client)


def warm_zone_search_cache(client: InfobloxClient, zone_name: str) -> None:
    """Warm search cache for one selected zone and its child authoritative zones."""
    warm_search_cache(client, normalize_zone_name(zone_name))


def prewarm_search_zone_from_env() -> str | None:
    """Read the hidden prewarm scope used by detached zone-use cache warmers."""
    zone_name = os.environ.get(PREWARM_SEARCH_ZONE_ENV, "").strip()
    return normalize_zone_name(zone_name) if zone_name else None


def carry_session_view_for_prewarm(env: dict[str, str]) -> None:
    """Pass the caller's session view to detached prewarmers whose parent PID changes."""
    if env.get(DEFAULT_VIEW_ENV):
        return
    session_view = read_session_view()
    if session_view:
        env[DEFAULT_VIEW_ENV] = session_view


def run_search_cache_prewarm() -> None:
    """Run the background prewarm entrypoint with lock handling and best-effort config loading."""
    lock: tuple[int, str] | None = None
    try:
        config = load_config(required=False)
        if not config:
            return
        client = InfobloxClient(config)
        root_zone = prewarm_search_zone_from_env()
        lock = acquire_search_cache_prewarm_lock()
        if lock is None:
            return
        if root_zone:
            warm_zone_search_cache(client, root_zone)
        else:
            warm_global_search_cache(client)
    except (CliError, WapiError, OSError, sqlite3.Error, ValueError):
        return
    finally:
        if lock is not None:
            release_search_cache_prewarm_lock(lock)


def start_search_cache_prewarm(zone_name: str | None = None) -> None:
    """Start a detached cache warmer so foreground DNS writes are not delayed."""
    env = os.environ.copy()
    env.pop("_IB_COMPLETE", None)
    env.pop(PREWARM_SEARCH_ZONE_ENV, None)
    carry_session_view_for_prewarm(env)
    try:
        if zone_name:
            env[PREWARM_SEARCH_ZONE_ENV] = normalize_zone_name(zone_name)
        subprocess.Popen(
            [sys.executable, str(Path(__file__).resolve()), "_prewarm-search-cache"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            close_fds=True,
            env=env,
        )
    except (CliError, OSError, ValueError):
        return


def run_zone_serial_cache_revalidation() -> None:
    """Refresh only the zone serial cache behind SWR without rebuilding record caches."""
    lock: tuple[int, str] | None = None
    client: InfobloxClient | None = None
    try:
        config = load_config(required=False)
        if not config:
            return
        client = InfobloxClient(config)
        lock = acquire_zone_serial_cache_revalidate_lock(client)
        if lock is None:
            return
        write_zone_serial_cache(client, fetch_zone_serials(client))
    except (CliError, WapiError, OSError, sqlite3.Error, ValueError):
        return
    finally:
        if lock is not None and client is not None:
            release_zone_serial_cache_revalidate_lock(client, lock)


def start_zone_serial_cache_revalidation() -> None:
