@click.option("-c", "--comment", callback=validate_record_comment_option, help="Record comment.")
def create(
    record_type: str,
    args: tuple[str, ...],
    name_option: str | None,
    zone: str | None,
    ttl: int | None,
    noptr: bool,
    comment: str | None,
) -> None:
    """Create a DNS record.

    Record names are relative to the active zone unless already fully qualified.
    Use `@` as the name for the zone apex. Supported record types are A, AAAA,
    CNAME, TXT, MX, PTR, SRV, and HOST.

    \b
    Examples:
      Setup: ib dns zone use example.com
      Command: ib dns create host app 192.0.2.10 -t 300 -c "Application host"
      Creates: HOST app.example.com with IPv4 address 192.0.2.10, TTL 300, and comment "Application host"
      Command: ib dns create host host1.example-dns.com 192.0.2.10
      Creates: HOST host1.example-dns.com with IPv4 address 192.0.2.10 in zone example-dns.com when that forward zone exists
      Command: ib dns create cname www app.example.com
      Creates: CNAME www.example.com -> app.example.com
      Command: ib dns create txt _spf "v=spf1 include:example.net -all"
      Creates: TXT _spf.example.com = "v=spf1 include:example.net -all"
      Command: ib dns create mx @ "10 mail.example.com"
      Creates: MX example.com -> mail.example.com with preference 10
      Command: ib dns create srv _sip._tcp "10 20 5060 sip.example.com"
      Creates: SRV _sip._tcp.example.com -> sip.example.com with priority 10, weight 20, and port 5060
      Command: ib dns create ptr 192.0.2.10 host.example.com
      Creates: PTR 192.0.2.10 -> host.example.com
    """
    name, value = parse_dns_create_name_value(args, name_option)
    run_dns_create(record_type, value, name, zone, ttl, noptr, comment)


