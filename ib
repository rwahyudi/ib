                ]
            )
        elif item == "fish":
            console.rule("[bold cyan]Fish[/bold cyan]")
            console.print("[bold]Current shell only[/bold]")
            print_command_block(["_IB_COMPLETE=fish_source ib | source"])
            console.print("[bold]Persistent setup[/bold]")
            print_command_block(
                [
                    "mkdir -p ~/.config/fish/completions",
                    "_IB_COMPLETE=fish_source ib > ~/.config/fish/completions/ib.fish",
                    "exec fish",
                ]
            )
    console.rule("[bold cyan]Verify[/bold cyan]")
    print_command_block(["ib <TAB><TAB>", "ib dns create <TAB><TAB>"])


@cli.group(cls=DnsGroup)
def dns() -> None:
    """Manage Infoblox DNS records.

    Record commands use the active zone unless you pass `--zone`. The active
    zone is resolved from `ib dns zone use`, then IB_ZONE, then the default zone
    saved by `ib configure`.

    \b
    Examples:
      ib dns list
      ib dns list example.com
      ib dns search app
      ib dns search -g app
      ib dns create host app 192.0.2.10 -t 300 -c "Application host"
      ib dns edit app host 192.0.2.20 -t 300 -c "Application host"
      ib dns create cname www app.example.com
      ib dns delete app
    """


@dns.group()
