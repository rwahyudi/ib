def prompt_dns_view_from_infoblox(
    config_values: dict[str, str],
    default_view: str = "default",
) -> str:
    """Prompt for a DNS view, preferring live Infoblox choices while keeping manual setup possible."""
    try:
        with infoblox_wait_spinner():
            view_names = query_dns_view_names_for_config(config_values)
    except (CliError, OSError, ValueError) as exc:
        print_warning(f"WARNING: could not load DNS views from Infoblox: {exc}")
