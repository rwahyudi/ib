def normalize_server(value: str) -> str:
    """Normalize server input into an HTTPS base URL so WAPI requests have one expected shape."""
    server = value.strip().rstrip("/")
    if not server:
        raise CliError("ERROR: Infoblox server is required.")
    if "://" not in server:
        server = f"https://{server}"
    server = re.sub(r"/wapi/v[0-9][^/]*$", "", server)
    return server.rstrip("/")


def parse_bool(value: str, default: bool = True) -> bool:
    """Parse config booleans from text so saved values can remain INI-compatible."""
    if not value:
        return default
    normalized = value.strip().lower()
    if normalized in {"1", "true", "yes", "y", "on"}:
        return True
    if normalized in {"0", "false", "no", "n", "off"}:
        return False
    raise CliError(f"ERROR: invalid boolean value: {value}")


def prompt_text(label: str, default: str | None = None) -> str:
    """Read a Rich prompt and trim whitespace so interactive config stores clean values."""
    if default is None:
        return Prompt.ask(label)
    return Prompt.ask(label, default=default)


def ensure_config_dir() -> None:
    """Create the private config directory with strict permissions before secrets are written."""
    CONFIG_DIR.mkdir(mode=0o700, exist_ok=True)
    os.chmod(CONFIG_DIR, 0o700)


def read_config_key() -> bytes:
    """Read the Fernet key from disk so encrypted config passwords can be decrypted."""
    if not CONFIG_KEY_FILE.exists():
        raise CliError(f"ERROR: missing encryption key file at {CONFIG_KEY_FILE}. Run: ib configure")
    try:
        key = CONFIG_KEY_FILE.read_bytes().strip()
        Fernet(key)
        os.chmod(CONFIG_KEY_FILE, 0o600)
        return key
    except (OSError, ValueError):
        raise CliError(f"ERROR: invalid encryption key file at {CONFIG_KEY_FILE}. Run: ib configure")


def get_or_create_config_key() -> bytes:
    """Return the existing encryption key or create one with private permissions for first-time setup."""
    ensure_config_dir()
    if CONFIG_KEY_FILE.exists():
        return read_config_key()

    key = Fernet.generate_key()
    try:
        with CONFIG_KEY_FILE.open("xb") as handle:
            handle.write(key)
            handle.write(b"\n")
        os.chmod(CONFIG_KEY_FILE, 0o600)
    except FileExistsError:
        return read_config_key()
    except OSError:
        raise CliError(f"ERROR: cannot write encryption key file at {CONFIG_KEY_FILE}. Run: ib configure")
    return key


def encrypt_password(password: str) -> str:
    """Encrypt a password before writing config so credentials are not stored as plaintext."""
    token = Fernet(get_or_create_config_key()).encrypt(password.encode("utf-8")).decode("ascii")
    return f"{ENCRYPTED_PASSWORD_PREFIX}{token}"


def decrypt_password(password: str) -> str:
    """Decrypt an encrypted config password and surface config problems as CLI errors."""
    if not password.startswith(ENCRYPTED_PASSWORD_PREFIX):
        return password

    token = password[len(ENCRYPTED_PASSWORD_PREFIX) :].encode("ascii")
    try:
        return Fernet(read_config_key()).decrypt(token).decode("utf-8")
    except (InvalidToken, OSError, UnicodeEncodeError, UnicodeDecodeError, ValueError):
        raise CliError(f"ERROR: cannot decrypt password in {CONFIG_FILE}. Run: ib configure")


def is_encrypted_password(password: str) -> bool:
    """Detect encrypted password values so legacy plaintext configs can be migrated safely."""
    return password.startswith(ENCRYPTED_PASSWORD_PREFIX)


def write_config_values(config_values: dict[str, str]) -> None:
    """Persist config through one path so file permissions and password encryption stay consistent."""
    ensure_config_dir()
    config = configparser.ConfigParser()
    config["default"] = {
        **config_values,
        "password": encrypt_password(config_values["password"]),
    }
    with CONFIG_FILE.open("w", encoding="utf-8") as handle:
        config.write(handle)
    os.chmod(CONFIG_FILE, 0o600)


def load_config_for_prompt() -> dict[str, str]:
    """Load existing config values for interactive defaults without requiring a complete config."""
    if not CONFIG_FILE.exists():
        return {}

    parser = configparser.ConfigParser()
    parser.read(CONFIG_FILE)
    if "default" not in parser:
        raise CliError(f"ERROR: missing [default] section in {CONFIG_FILE}")

    cfg = dict(parser["default"])
    if cfg.get("server"):
        cfg["server"] = normalize_server(cfg["server"])
    if cfg.get("password"):
        try:
            cfg["password"] = decrypt_password(cfg["password"])
        except CliError as exc:
            print_warning(str(exc))
            cfg.pop("password", None)
    return cfg


def save_config_interactive() -> None:
    """Collect and save configuration interactively so first-run setup is guided and repeatable."""
    current = load_config_for_prompt()
    console.print(
        Panel.fit(
            f"Configuration will be saved to [bold]{CONFIG_FILE}[/bold].\n"
            "You can run this multiple times; existing values are shown as defaults.\n"
            "Press Enter to keep a value, or leave the password blank to keep it unchanged.",
            title="Infoblox Configuration",
            border_style="cyan",
        )
    )

    server = normalize_server(prompt_text("Infoblox server", current.get("server")))
    username = prompt_text("Username", current.get("username"))
    if current.get("password"):
        password = Prompt.ask(
            "Password (leave blank to keep current)",
            default="",
            password=True,
            show_default=False,
        ) or current["password"]
    else:
        password = Prompt.ask("Password", password=True)
    if not username or not password:
        raise CliError("ERROR: username and password are required.")

    wapi_version = Prompt.ask(
        "WAPI version", default=current.get("wapi_version", DEFAULT_WAPI_VERSION)
    )
    dns_view = Prompt.ask("DNS view", default=current.get("dns_view", "default"))
    default_zone = Prompt.ask(
        "Default DNS zone (optional)",
        default=current.get("default_zone", ""),
    ).strip()
    if default_zone:
        default_zone = normalize_zone_name(default_zone)
    verify_ssl = Confirm.ask(
        "Verify SSL certificates",
        default=parse_bool(current.get("verify_ssl", "true")),
    )

    default_config = {
        "server": server,
        "username": username,
        "password": password,
        "wapi_version": wapi_version,
        "dns_view": dns_view,
        "default_zone": default_zone,
        "verify_ssl": "true" if verify_ssl else "false",
        "timeout": str(current.get("timeout", DEFAULT_TIMEOUT)),
    }
    write_config_values(default_config)

    print_success("SUCCESS: configuration saved.")


def maybe_prompt_configure() -> None:
    """Offer configuration setup when required config is missing so users get a clear next step."""
    if not sys.stdin.isatty():
        raise CliError("ERROR: no configuration file found. Run: ib configure")
    print_warning(f"No configuration file found at {CONFIG_FILE}.")
    if not Confirm.ask("Run 'ib configure' now?", default=False):
        raise CliError("ERROR: no configuration file found. Run: ib configure")
    save_config_interactive()


def load_config(required: bool = True) -> dict[str, str] | None:
    """Load validated config and decrypt credentials so command workflows start with usable settings."""
    if not CONFIG_FILE.exists():
        if required:
            maybe_prompt_configure()
        else:
            return None

    parser = configparser.ConfigParser()
    parser.read(CONFIG_FILE)
    if "default" not in parser:
        raise CliError(f"ERROR: missing [default] section in {CONFIG_FILE}")

    cfg = dict(parser["default"])
    for key in ("server", "username", "password"):
        if not cfg.get(key):
            raise CliError(f"ERROR: missing '{key}' in {CONFIG_FILE}")

    raw_password = cfg["password"]
    cfg["password"] = decrypt_password(raw_password)
    cfg["server"] = normalize_server(cfg["server"])
    cfg.setdefault("wapi_version", DEFAULT_WAPI_VERSION)
    cfg.setdefault("dns_view", "default")
    cfg.setdefault("default_zone", "")
    cfg.setdefault("verify_ssl", "true")
    cfg.setdefault("timeout", str(DEFAULT_TIMEOUT))
    if not is_encrypted_password(raw_password):
        write_config_values(cfg)
    return cfg


class InfobloxClient:
    """Wrap Infoblox WAPI HTTPS calls so command logic stays focused on DNS behavior."""
    def __init__(self, config: dict[str, str]) -> None:
        """Initialize the instance with state used by the surrounding class methods."""
        self.server = normalize_server(config["server"])
        self.wapi_version = config.get("wapi_version", DEFAULT_WAPI_VERSION).strip().lstrip("/")
        self.username = config["username"]
        self.password = config["password"]
        self.view = config.get("dns_view", "default")
        self.timeout = int(config.get("timeout", DEFAULT_TIMEOUT))
        self.verify_ssl = parse_bool(config.get("verify_ssl", "true"))
        self._server_url = urllib.parse.urlsplit(self.server)
        if self._server_url.scheme not in {"http", "https"} or not self._server_url.hostname:
            raise CliError(f"ERROR: invalid Infoblox server URL: {self.server}")
        try:
            self._server_port = self._server_url.port
        except ValueError as exc:
            raise CliError(f"ERROR: invalid Infoblox server URL: {self.server}") from exc
        self._server_path = self._server_url.path.rstrip("/")
        self._connection: http.client.HTTPConnection | None = None

    def close(self) -> None:
        """Close the cached HTTPS connection so callers can release network resources explicitly."""
        if self._connection is None:
            return
        try:
            self._connection.close()
        finally:
            self._connection = None

    def connection(self) -> http.client.HTTPConnection:
        """Return an HTTPS connection, reusing it so repeated WAPI requests avoid reconnect overhead."""
        if self._connection is not None:
            return self._connection
        if self._server_url.scheme == "https":
            context = None if self.verify_ssl else ssl._create_unverified_context()
            self._connection = http.client.HTTPSConnection(
                self._server_url.hostname,
                port=self._server_port,
                timeout=self.timeout,
                context=context,
            )
        else:
            self._connection = http.client.HTTPConnection(
                self._server_url.hostname,
                port=self._server_port,
                timeout=self.timeout,
            )
        return self._connection

    def request_path(self, path: str, params: dict[str, Any] | None = None) -> str:
        """Build the WAPI request path with query parameters encoded once for consistent requests."""
        query = f"?{urllib.parse.urlencode(params)}" if params else ""
        quoted_path = urllib.parse.quote(path.lstrip("/"), safe="/:")
        return f"{self._server_path}/wapi/{self.wapi_version}/{quoted_path}{query}"

    def connection_error(self, exc: BaseException) -> WapiError:
        """Convert low-level connection failures into CLI errors with operator-facing context."""
        reason = getattr(exc, "reason", None) or getattr(exc, "strerror", None) or str(exc)
        return WapiError(f"ERROR: cannot reach Infoblox: {reason or exc.__class__.__name__}")

    def request(
        self,
        method: str,
        path: str,
        params: dict[str, Any] | None = None,
        payload: dict[str, Any] | None = None,
    ) -> Any:
        """Execute one WAPI request and retry once after connection resets to handle stale keep-alive sockets."""
        had_connection = self._connection is not None
        try:
            return self.request_once(method, path, params, payload)
        except (OSError, http.client.HTTPException) as exc:
            self.close()
            if method.upper() != "GET" or not had_connection:
                raise self.connection_error(exc) from exc
            try:
                return self.request_once(method, path, params, payload)
            except (OSError, http.client.HTTPException) as retry_exc:
                self.close()
                raise self.connection_error(retry_exc) from retry_exc

    def request_once(
        self,
        method: str,
        path: str,
        params: dict[str, Any] | None = None,
        payload: dict[str, Any] | None = None,
    ) -> Any:
        """Perform a single WAPI HTTP exchange and translate the response into Python data or WAPI errors."""
        body = None
        headers = {
            "Accept": "application/json",
            "Authorization": "Basic "
            + base64.b64encode(f"{self.username}:{self.password}".encode()).decode(),
        }
        if payload is not None:
            body = json.dumps(payload).encode("utf-8")
            headers["Content-Type"] = "application/json"

        conn = self.connection()
        conn.request(method, self.request_path(path, params), body=body, headers=headers)
        response = conn.getresponse()
        raw_bytes = response.read()
        if response.status >= 400:
            raw_error = raw_bytes.decode("utf-8", errors="replace")
            raise WapiError(
                f"ERROR: Infoblox WAPI {response.status}: {format_wapi_error(raw_error)}",
                status=response.status,
            )

        raw = raw_bytes.decode("utf-8")
        if not raw:
            return None
        return json.loads(raw)


def format_wapi_error(raw: str) -> str:
    """Extract useful WAPI error text so operators see the Infoblox reason instead of raw JSON."""
    try:
        parsed = json.loads(raw)
    except json.JSONDecodeError:
        return raw.strip() or "empty error response"
    return parsed.get("text") or parsed.get("Error") or json.dumps(parsed)


def fqdn(record_name: str, zone: str) -> str:
    """Combine a record name and zone into a fully qualified name while preserving already-qualified names."""
    name = record_name.strip().rstrip(".")
    zone_name = zone.strip().rstrip(".")
    if not name:
        raise CliError("ERROR: record name is required.")
    if not zone_name:
        raise CliError("ERROR: zone is required.")
    if name == "@":
        return zone_name
    if name == zone_name or name.endswith(f".{zone_name}"):
        return name
    return f"{name}.{zone_name}"


def normalize_zone_name(zone_name: str) -> str:
    """Normalize zone names for comparison and WAPI payloads so trailing dots/case do not diverge."""
    normalized = zone_name.strip().rstrip(".")
    if not normalized:
        raise CliError("ERROR: zone is required.")
    return normalized


def default_zone_from_env() -> str | None:
    """Read IB_ZONE as a normalized zone so shell-scoped overrides use the same validation as config."""
    zone_name = os.environ.get(DEFAULT_ZONE_ENV, "").strip()
    return normalize_zone_name(zone_name) if zone_name else None


def default_config_values() -> dict[str, str]:
    """Read non-secret config values for help/completion without forcing a full command setup path."""
    parser = configparser.ConfigParser()
    try:
        parser.read(CONFIG_FILE)
    except (OSError, configparser.Error):
        return {}
    if "default" not in parser:
        return {}
    return dict(parser["default"])


def session_zone_dir() -> Path:
    """Return the session-zone directory path so transient zone state stays outside persistent config."""
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    if runtime_dir and os.access(runtime_dir, os.W_OK):
        return Path(runtime_dir) / "ib" / "active-zones"
    user_id = str(os.getuid()) if hasattr(os, "getuid") else "user"
    return Path(tempfile.gettempdir()) / f"ib-{user_id}" / "active-zones"


def session_zone_file() -> Path:
    """Return the session-zone file for this shell so ib dns zone use remains session scoped."""
    return session_zone_dir() / f"{SESSION_ZONE_FILE_PREFIX}-{os.getppid()}.json"


def read_session_zone() -> str | None:
    """Read the active session zone when present so commands can honor ib dns zone use."""
    try:
        with session_zone_file().open("r", encoding="utf-8") as handle:
            payload = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(payload, dict) or payload.get("parent_pid") != os.getppid():
        return None
    zone_name = str(payload.get("zone", "")).strip()
    if not zone_name:
        return None
    try:
        return normalize_zone_name(zone_name)
    except CliError:
        return None


def write_session_zone(zone_name: str) -> None:
    """Write the active zone to session state instead of config so zone use remains transient."""
    path = session_zone_file()
    payload = {
        "zone": normalize_zone_name(zone_name),
        "parent_pid": os.getppid(),
        "created_at": time.time(),
    }
    try:
        path.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
        os.chmod(path.parent, 0o700)
        with path.open("w", encoding="utf-8") as handle:
            json.dump(payload, handle)
        os.chmod(path, 0o600)
    except OSError:
        raise CliError(f"ERROR: cannot write session active zone at {path}")


def resolve_dns_zone(config: dict[str, str], zone_name: str | None = None) -> str:
    """Resolve the target zone through CLI, session, environment, then config to keep precedence explicit."""
    if zone_name:
        return normalize_zone_name(zone_name)

    session_zone = read_session_zone()
    if session_zone:
        return session_zone

    env_zone = default_zone_from_env()
    if env_zone:
        return env_zone

    if config.get("default_zone"):
        return normalize_zone_name(config["default_zone"])

    raise CliError(
        f"ERROR: DNS zone is required. Use --zone, ib dns zone use, export {DEFAULT_ZONE_ENV}, "
        "or set a default zone with: ib configure"
    )


def forward_zone_candidates_from_record_name(record_name: str) -> list[str]:
    """Build candidate parent zones from an FQDN so create can infer the most specific zone."""
    normalized = record_name.strip().rstrip(".")
    if not normalized or normalized == "@" or "." not in normalized:
        return []
    labels = [label for label in normalized.split(".") if label]
    if len(labels) != len(normalized.split(".")):
        return []
    return [".".join(labels[index:]) for index in range(len(labels))]


def matching_forward_zone_for_record_name(client: InfobloxClient, record_name: str) -> str | None:
    """Find an existing forward zone for an FQDN so create can avoid requiring --zone."""
    for candidate in forward_zone_candidates_from_record_name(record_name):
        matches = safe_query(
            client,
            ZONE_OBJECT,
            zone_query_params(client, {"fqdn": candidate}, return_fields=ZONE_RETURN_FIELDS),
        )
        for zone_info in matches:
            zone_format = str(zone_info.get("zone_format", "FORWARD")).upper()
            if zone_format != "FORWARD":
                continue
            return normalize_zone_name(str(zone_info.get("fqdn") or candidate))
    return None


def resolve_dns_create_zone(
    config: dict[str, str],
    client: InfobloxClient,
    record_type: str,
    record_name: str,
    zone_name: str | None = None,
) -> str:
    """Resolve create target zones with FQDN inference before falling back to the active/default zone."""
    if zone_name:
        return resolve_dns_zone(config, zone_name)

    if record_type.lower() in FORWARD_RECORD_TYPES:
        matched_zone = matching_forward_zone_for_record_name(client, record_name)
        if matched_zone:
            return matched_zone

    return resolve_dns_zone(config)


def default_zone_from_config_file() -> str | None:
    """Read the configured default zone for context display while ignoring invalid stale values."""
    zone_name = default_config_values().get("default_zone", "").strip()
    if not zone_name:
        return None
    try:
        return normalize_zone_name(zone_name)
    except CliError:
        return None


def current_view_status() -> tuple[str, str]:
    """Return display text for the active DNS view so help can show useful context without full config loading."""
    config_values = default_config_values()
    if not config_values:
        return "not configured", "run ib configure"

    dns_view = config_values.get("dns_view", "").strip()
    if dns_view:
        return dns_view, "configured"
    return "default", "implicit default"


def active_zone_status() -> tuple[str | None, str]:
    """Return the active zone and source so help and completion can explain command targeting."""
    session_zone = read_session_zone()
    if session_zone:
        return session_zone, "shell session"

    try:
        env_zone = default_zone_from_env()
    except CliError:
        env_zone = None
    if env_zone:
        return env_zone, DEFAULT_ZONE_ENV

    config_zone = default_zone_from_config_file()
    if config_zone:
        return config_zone, "configured default"

    return None, "not set"


def active_zone_completion_help() -> str:
