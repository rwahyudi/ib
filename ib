        parser.read(CONFIG_FILE)
    except (OSError, configparser.Error):
        return {}
    if "default" not in parser:
        return {}
    return dict(parser["default"])


def session_zone_dir() -> Path:
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    if runtime_dir and os.access(runtime_dir, os.W_OK):
        return Path(runtime_dir) / "ib" / "active-zones"
    user_id = str(os.getuid()) if hasattr(os, "getuid") else "user"
    return Path(tempfile.gettempdir()) / f"ib-{user_id}" / "active-zones"


def session_zone_file() -> Path:
    return session_zone_dir() / f"{SESSION_ZONE_FILE_PREFIX}-{os.getppid()}.json"


def read_session_zone() -> str | None:
    try:
        with session_zone_file().open("r", encoding="utf-8") as handle:
            payload = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(payload, dict) or payload.get("parent_pid") != os.getppid():
        return None
    zone_name = str(payload.get("zone", "")).strip()
    if not zone_name:
        return None
    try:
        return normalize_zone_name(zone_name)
    except CliError:
        return None


def write_session_zone(zone_name: str) -> None:
    path = session_zone_file()
    payload = {
        "zone": normalize_zone_name(zone_name),
        "parent_pid": os.getppid(),
        "created_at": time.time(),
    }
    try:
        path.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
        os.chmod(path.parent, 0o700)
        with path.open("w", encoding="utf-8") as handle:
            json.dump(payload, handle)
        os.chmod(path, 0o600)
    except OSError:
        raise CliError(f"ERROR: cannot write session active zone at {path}")


def resolve_dns_zone(config: dict[str, str], zone_name: str | None = None) -> str:
    if zone_name:
        return normalize_zone_name(zone_name)

    session_zone = read_session_zone()
    if session_zone:
        return session_zone

    env_zone = default_zone_from_env()
    if env_zone:
        return env_zone

    if config.get("default_zone"):
        return normalize_zone_name(config["default_zone"])

    raise CliError(
        f"ERROR: DNS zone is required. Use --zone, ib dns zone use, export {DEFAULT_ZONE_ENV}, "
        "or set a default zone with: ib configure"
    )


def default_zone_from_config_file() -> str | None:
    zone_name = default_config_values().get("default_zone", "").strip()
    if not zone_name:
        return None
    try:
        return normalize_zone_name(zone_name)
    except CliError:
        return None


def current_view_status() -> tuple[str, str]:
    config_values = default_config_values()
    if not config_values:
        return "not configured", "run ib configure"

    dns_view = config_values.get("dns_view", "").strip()
    if dns_view:
        return dns_view, "configured"
    return "default", "implicit default"


def active_zone_status() -> tuple[str | None, str]:
    session_zone = read_session_zone()
    if session_zone:
        return session_zone, "shell session"

    try:
        env_zone = default_zone_from_env()
    except CliError:
        env_zone = None
    if env_zone:
        return env_zone, DEFAULT_ZONE_ENV

    config_zone = default_zone_from_config_file()
    if config_zone:
        return config_zone, "configured default"

    return None, "not set"


def active_zone_completion_help() -> str:
    zone_name, source = active_zone_status()
    if zone_name:
        return f"Active zone: {zone_name} ({source})"
    return "Active zone: not set"


def active_zone_completion_value() -> str:
    zone_name, _source = active_zone_status()
    return f"active-zone={zone_name or 'not-set'}"


def dns_context_panel(title: str = "DNS Context") -> Panel:
    view_name, view_source = current_view_status()
    zone_name, zone_source = active_zone_status()
    active_zone = zone_name or "not set"
    background_style = "white on #0f172a"
    label_style = "bold cyan on #0f172a"
    source_style = "dim white on #0f172a"
    view_style = (
        "bold magenta on #0f172a" if view_name != "not configured" else "bold yellow on #0f172a"
    )
    zone_style = "bold green on #0f172a" if zone_name else "bold yellow on #0f172a"

    context = Text()
    context.append("View: ", style=label_style)
    context.append(view_name, style=view_style)
    context.append(f" ({view_source})", style=source_style)
    context.append("  |  ", style=background_style)
    context.append("Active zone: ", style=label_style)
    context.append(active_zone, style=zone_style)
    context.append(f" ({zone_source})", style=source_style)

    return Panel(
        context,
        title=title,
        style=background_style,
        border_style="bright_cyan",
        padding=(0, 1),
    )


def usage_context_panel_text(ctx: click.Context) -> str:
    width = min(ctx.terminal_width or console.width or 80, 100)
    help_console = Console(
        color_system=console.color_system,
        force_terminal=ctx.color if ctx.color is not None else console.is_terminal,
        width=width,
    )
    with help_console.capture() as capture:
        help_console.print(dns_context_panel())
    return capture.get()


class UsageContextHelpMixin:
    def format_help(self, ctx: click.Context, formatter: click.HelpFormatter) -> None:
        self.format_usage(ctx, formatter)
        formatter.write("\n")
        formatter.write(usage_context_panel_text(ctx))
        formatter.write("\n")
        self.format_help_text(ctx, formatter)
        self.format_options(ctx, formatter)
        self.format_epilog(ctx, formatter)


class UsageContextCommand(UsageContextHelpMixin, click.Command):
    pass


class UsageContextGroup(UsageContextHelpMixin, click.Group):
    command_class = UsageContextCommand
    group_class = type


def is_bash_completion() -> bool:
    return os.environ.get("_IB_COMPLETE", "").startswith("bash_")


def append_active_zone_help(item_help: str | None, active_zone_help: str) -> str:
    if not item_help:
        return active_zone_help
    return f"{item_help} {active_zone_help}."


class DnsGroup(UsageContextGroup):
    def shell_complete(self, ctx: click.Context, incomplete: str) -> list[CompletionItem]:
        items = super().shell_complete(ctx, incomplete)

        zone_help = active_zone_completion_help()
        if is_bash_completion():
            if incomplete:
                return items
            return [CompletionItem(active_zone_completion_value(), help=zone_help), *items]

        for item in items:
            if item.type == "plain" and str(item.value) in self.commands:
                item.help = append_active_zone_help(item.help, zone_help)
        return items


def ttl_payload(ttl: int | None) -> dict[str, Any]:
    if ttl is None:
        return {}
    if ttl < 0:
        raise CliError("ERROR: ttl must be 0 or greater.")
    return {"ttl": ttl, "use_ttl": True}


def mx_payload(value: str) -> dict[str, Any]:
    parts = value.split()
    if len(parts) != 2 or not parts[0].isdigit():
        raise CliError("ERROR: MX value must be quoted as '<preference> <mail_exchanger>'.")
    return {"preference": int(parts[0]), "mail_exchanger": parts[1].rstrip(".")}


def ptr_payload(name: str, value: str) -> dict[str, Any]:
    field = "ipv6addr" if ":" in name else "ipv4addr"
    return {field: name, "ptrdname": value.rstrip(".")}


def create_payload(
    record_type: str,
    value: str,
    name: str,
    zone: str,
    ttl: int | None,
    comment: str | None,
    client: InfobloxClient,
) -> tuple[str, dict[str, Any]]:
    record_type = record_type.lower()
    spec = RECORD_TYPES.get(record_type)
    if not spec:
        supported = ", ".join(sorted(RECORD_TYPES))
        raise CliError(f"ERROR: unsupported record type '{record_type}'. Supported: {supported}")

    object_type = spec["object"]
    fqdn_name = fqdn(name, zone)
    payload: dict[str, Any] = {
        "name": fqdn_name,
        "view": client.view,
        **ttl_payload(ttl),
    }
    if comment:
        payload["comment"] = comment

    if record_type == "mx":
        payload.update(mx_payload(value))
    elif record_type == "ptr":
        payload = {
            **ptr_payload(name, value),
            "view": client.view,
            **ttl_payload(ttl),
        }
        if comment:
            payload["comment"] = comment
    else:
        value_field = spec["value_field"]
        payload[value_field] = value.rstrip(".") if record_type == "cname" else value

    return object_type, payload


def run_dns_create(
    record_type: str,
    value: str,
    name: str,
    zone: str | None,
    ttl: int | None,
    noptr: bool,
    comment: str | None,
) -> None:
    config = load_config()
    client = InfobloxClient(config)
    resolved_zone = resolve_dns_zone(config, zone)
    object_type, payload = create_payload(record_type, value, name, resolved_zone, ttl, comment, client)
    ref = client.request("POST", object_type, payload=payload)
    if noptr and record_type.lower() not in {"a", "aaaa"}:
        print_warning("WARNING: --noptr only applies to A/AAAA workflows and was ignored.")
    print_success(f"SUCCESS: created {record_type.upper()} record")
    print_note(f"Reference: {ref}")


def object_query_params(
    spec: dict[str, Any],
    client: InfobloxClient,
    extra: dict[str, Any],
) -> dict[str, Any]:
    return {
        "_return_fields": spec["return_fields"],
        "view": client.view,
        **extra,
    }


def zone_query_params(
    client: InfobloxClient,
    extra: dict[str, Any] | None = None,
    return_fields: str = ZONE_RETURN_FIELDS,
) -> dict[str, Any]:
    return {
        "_return_fields": return_fields,
        "view": client.view,
        **(extra or {}),
    }


def allrecords_query_params(client: InfobloxClient, zone_name: str) -> dict[str, Any]:
    return {
        "_return_fields": ALLRECORDS_RETURN_FIELDS,
        "view": client.view,
        "zone": normalize_zone_name(zone_name),
    }


def zone_search_params(
    client: InfobloxClient,
    field: str,
    search: str | None = None,
) -> dict[str, Any]:
    extra = {}
    if search:
        extra[f"{field}~"] = search_pattern(search, case_sensitive=False)
    return zone_query_params(client, extra)


def zone_result_key(zone: dict[str, Any]) -> str:
    if zone.get("_ref"):
        return str(zone["_ref"])
    return json.dumps(
        {
            "fqdn": zone.get("fqdn", ""),
            "view": zone.get("view", ""),
            "zone_format": zone.get("zone_format", ""),
        },
        sort_keys=True,
    )


def query_zones(client: InfobloxClient, search: str | None = None) -> list[dict[str, Any]]:
    if not search:
        return paged_query(client, ZONE_OBJECT, zone_query_params(client))

    zones: list[dict[str, Any]] = []
    seen: set[str] = set()
    for field in ("fqdn", "comment"):
        for zone in paged_query(client, ZONE_OBJECT, zone_search_params(client, field, search)):
            key = zone_result_key(zone)
            if key in seen:
                continue
            seen.add(key)
            zones.append(zone)
    return zones


def safe_query(client: InfobloxClient, object_type: str, params: dict[str, Any]) -> list[dict[str, Any]]:
    try:
        result = client.request("GET", object_type, params=params)
    except WapiError as exc:
        if exc.status in {400, 404} and "field" in str(exc).lower():
            print_warning(f"WARNING: skipping {object_type}: {exc}")
            return []
        raise
    return result if isinstance(result, list) else []


def paged_query(
    client: InfobloxClient,
    object_type: str,
    params: dict[str, Any],
    warn_on_skip: bool = True,
) -> list[dict[str, Any]]:
    page_params: dict[str, Any] = {
        **params,
        "_paging": 1,
        "_return_as_object": 1,
        "_max_results": WAPI_PAGE_SIZE,
    }
    results: list[dict[str, Any]] = []
    page_id = ""

    while True:
        request_params = dict(page_params)
        if page_id:
            request_params["_page_id"] = page_id

        try:
            response = client.request("GET", object_type, params=request_params)
        except WapiError as exc:
            if exc.status in {400, 404} and "field" in str(exc).lower():
                if warn_on_skip:
                    print_warning(f"WARNING: skipping {object_type}: {exc}")
                return []
            raise

        if isinstance(response, list):
            results.extend(response)
            return results
        if not isinstance(response, dict):
            return results

        page_result = response.get("result", [])
        if not isinstance(page_result, list):
            raise CliError(f"ERROR: unexpected WAPI result shape for {object_type}.")
        results.extend(page_result)

        page_id = str(response.get("next_page_id", "") or "")
        if not page_id:
            return results


def search_fields(spec: dict[str, Any]) -> tuple[str, ...]:
    return ("name", *spec.get("search_value_fields", ()), "comment")


def case_insensitive_literal_pattern(keyword: str) -> str:
    parts = []
    for char in keyword:
        if char.isascii() and char.isalpha():
            parts.append(f"[{char.lower()}{char.upper()}]")
        else:
            parts.append(re.escape(char))
    return "".join(parts)


def search_pattern(keyword: str, case_sensitive: bool) -> str:
    return re.escape(keyword) if case_sensitive else case_insensitive_literal_pattern(keyword)


def is_zone_or_child(zone_name: str, parent_zone: str) -> bool:
    zone = normalize_zone_name(zone_name)
    parent = normalize_zone_name(parent_zone)
    return zone == parent or zone.endswith(f".{parent}")


def zone_serial(zone_info: dict[str, Any]) -> str | None:
    serial = zone_info.get("soa_serial_number")
    return str(serial) if serial is not None else None


def is_secondary_zone(zone_info: dict[str, Any]) -> bool:
    primary_type = str(zone_info.get("primary_type", "")).strip().lower()
    return primary_type in {"external", "microsoft", "secondary"}


def search_root_zone(config: dict[str, str]) -> str | None:
    try:
        return resolve_dns_zone(config)
    except CliError:
        return None


def record_result_key(item: dict[str, Any]) -> str:
    return str(item.get("_ref") or json.dumps(item, sort_keys=True))


def allrecords_cache_file(client: InfobloxClient, zone_name: str) -> Path:
    cache_key = json.dumps(
        {
            "server": client.server,
            "wapi_version": client.wapi_version,
            "view": client.view,
            "zone": normalize_zone_name(zone_name),
        },
        sort_keys=True,
    )
    digest = hashlib.sha256(cache_key.encode("utf-8")).hexdigest()
    return ALLRECORDS_CACHE_DIR / f"{digest}.json"


def read_allrecords_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
) -> list[dict[str, Any]] | None:
    if serial_number is None:
        return None
    try:
        with allrecords_cache_file(client, zone_name).open("r", encoding="utf-8") as handle:
            cache = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(cache, dict):
        return None
    if cache.get("server") != client.server or cache.get("view") != client.view:
        return None
    if cache.get("zone") != normalize_zone_name(zone_name):
        return None
    if str(cache.get("soa_serial_number", "")) != serial_number:
        return None

    records = cache.get("records")
    if not isinstance(records, list) or not all(isinstance(item, dict) for item in records):
        return None
    return records


def write_allrecords_cache(
    client: InfobloxClient,
    zone_name: str,
    serial_number: str | None,
    records: list[dict[str, Any]],
) -> None:
    if serial_number is None:
        return
    try:
        ALLRECORDS_CACHE_DIR.parent.mkdir(mode=0o700, exist_ok=True)
        ALLRECORDS_CACHE_DIR.mkdir(mode=0o700, exist_ok=True)
        try:
            os.chmod(ALLRECORDS_CACHE_DIR.parent, 0o700)
            os.chmod(ALLRECORDS_CACHE_DIR, 0o700)
        except OSError:
            pass
        cache_file = allrecords_cache_file(client, zone_name)
        with cache_file.open("w", encoding="utf-8") as handle:
            json.dump(
                {
                    "created_at": time.time(),
                    "server": client.server,
                    "wapi_version": client.wapi_version,
                    "view": client.view,
                    "zone": normalize_zone_name(zone_name),
                    "soa_serial_number": serial_number,
                    "records": records,
                },
                handle,
            )
        try:
            os.chmod(cache_file, 0o600)
        except OSError:
            pass
    except OSError:
        return


def query_zone_serials(client: InfobloxClient) -> list[dict[str, Any]]:
    return paged_query(
        client,
        ZONE_OBJECT,
        zone_query_params(client, return_fields=ZONE_SERIAL_RETURN_FIELDS),
    )


def search_zones(client: InfobloxClient, root_zone: str | None) -> list[dict[str, Any]]:
    zones = query_zone_serials(client)
    if not root_zone:
        return sorted(
            [zone for zone in zones if not is_secondary_zone(zone)],
            key=lambda zone: str(zone.get("fqdn", "")).lower(),
        )

    filtered = []
    seen_names: set[str] = set()
    for zone in zones:
        zone_name = str(zone.get("fqdn", "")).strip()
        if not zone_name:
            continue
        try:
            normalized = normalize_zone_name(zone_name)
        except CliError:
            continue
        if is_zone_or_child(normalized, root_zone):
            seen_names.add(normalized)
            if is_secondary_zone(zone):
                continue
            filtered.append(zone)

    normalized_root = normalize_zone_name(root_zone)
    if normalized_root not in seen_names:
        filtered.append({"fqdn": normalized_root, "view": client.view})
    return sorted(filtered, key=lambda zone: str(zone.get("fqdn", "")).lower())


def allrecords_for_zone(client: InfobloxClient, zone_info: dict[str, Any]) -> list[dict[str, Any]]:
    zone_name = normalize_zone_name(str(zone_info.get("fqdn", "")))
    serial_number = zone_serial(zone_info)
    cached_records = read_allrecords_cache(client, zone_name, serial_number)
    if cached_records is not None:
        return cached_records

    records = paged_query(client, ALLRECORDS_OBJECT, allrecords_query_params(client, zone_name))
    write_allrecords_cache(client, zone_name, serial_number, records)
    return records


def record_in_zone_scope(item: dict[str, Any], root_zone: str) -> bool:
    zone_name = str(item.get("zone", "")).strip()
    if zone_name:
        return is_zone_or_child(zone_name, root_zone)

    record_name = str(item.get("name", "")).strip()
    return bool(record_name) and is_zone_or_child(record_name, root_zone)


def allrecord_type(item: dict[str, Any]) -> str:
    raw_type = str(item.get("type", "")).lower()
    if raw_type.startswith("record:"):
        record_type = raw_type.split(":", 1)[1]
        if record_type in {"host_ipv4addr", "host_ipv6addr"}:
            return "host"
        return record_type
    if raw_type.startswith("sharedrecord:"):
        return raw_type.replace("sharedrecord:", "shared-", 1)
    return raw_type or "record"


def nested_record(item: dict[str, Any]) -> dict[str, Any]:
    record = item.get("record")
    return record if isinstance(record, dict) else {}


def first_record_value(item: dict[str, Any], keys: tuple[str, ...]) -> str:
    record = nested_record(item)
    for key in keys:
        value = record.get(key, item.get(key))
        if value not in (None, ""):
            return str(value)
    return ""


def allrecord_display_name(item: dict[str, Any]) -> str:
    return first_record_value(item, ("name",)) or str(item.get("name", ""))


def allrecord_display_value(record_type: str, item: dict[str, Any]) -> str:
    if record_type in {"cname", "shared-cname"}:
        return first_record_value(item, ("canonical",))
    if record_type in {"txt", "shared-txt"}:
        return first_record_value(item, ("text",))
    if record_type in {"mx", "shared-mx"}:
        exchanger = first_record_value(item, ("mail_exchanger",))
        preference = first_record_value(item, ("preference",))
        return f"{preference} {exchanger}".strip() if exchanger else ""
    if record_type == "ptr":
        return first_record_value(item, ("ptrdname", "ipv4addr", "ipv6addr"))
    if record_type == "host":
        values = []
        record = nested_record(item)
        for key, nested_key in (("ipv4addrs", "ipv4addr"), ("ipv6addrs", "ipv6addr")):
            for address in record.get(key, item.get(key, [])) or []:
                if isinstance(address, dict) and address.get(nested_key):
                    values.append(str(address[nested_key]))
                elif isinstance(address, str):
                    values.append(address)
        if values:
            return ", ".join(values)
    if record_type in {"a", "shared-a"}:
        return first_record_value(item, ("ipv4addr", "address"))
    if record_type in {"aaaa", "shared-aaaa"}:
        return first_record_value(item, ("ipv6addr", "address"))
    if item.get("address"):
        return str(item["address"])
    record = item.get("record")
    return str(record) if record not in (None, "") else ""


def allrecord_search_values(record_type: str, item: dict[str, Any]) -> list[str]:
    return [
        allrecord_display_name(item),
        allrecord_display_value(record_type, item),
        str(item.get("comment", "")),
    ]


def allrecord_matches_keyword(
    item: dict[str, Any],
    keyword: str,
    case_sensitive: bool,
) -> bool:
    needle = keyword if case_sensitive else keyword.lower()
    record_type = allrecord_type(item)
    for value in allrecord_search_values(record_type, item):
        haystack = value if case_sensitive else value.lower()
        if needle in haystack:
            return True
    return False


def collect_dns_search_results(
    client: InfobloxClient,
    keyword: str,
    case_sensitive: bool,
    root_zone: str | None,
) -> list[tuple[str, dict[str, Any]]]:
    seen: set[str] = set()
    records: list[tuple[str, dict[str, Any]]] = []

    for zone_info in search_zones(client, root_zone):
        for item in allrecords_for_zone(client, zone_info):
            if not allrecord_matches_keyword(item, keyword, case_sensitive):
                continue
            if root_zone and not record_in_zone_scope(item, root_zone):
                continue
            key = record_result_key(item)
            if key in seen:
                continue
            seen.add(key)
            records.append((allrecord_type(item), item))
    return records


def run_dns_search(
    keyword: str,
    case_sensitive: bool = False,
    global_search: bool = False,
) -> None:
    config = load_config()
    client = InfobloxClient(config)
    root_zone = None if global_search else search_root_zone(config)
    if not global_search:
        console.print(dns_context_panel("Current DNS Context"))
    records = collect_dns_search_results(client, keyword, case_sensitive, root_zone)

    if not records:
        print_warning("No records found.")
        return

    console.print(record_table(records))


def run_dns_delete(record_name: str, zone: str | None) -> None:
    config = load_config()
    client = InfobloxClient(config)
    target = fqdn(record_name, resolve_dns_zone(config, zone))
    matches: list[tuple[str, dict[str, Any]]] = []

    for record_type, spec in RECORD_TYPES.items():
        params = object_query_params(spec, client, {"name": target})
        matches.extend((record_type, item) for item in safe_query(client, spec["object"], params))

    if not matches:
        raise CliError(f"ERROR: no DNS record found for {target} in view {client.view}")
    if len(matches) > 1:
        print_error(f"ERROR: multiple records found for {target}. Delete one of these _ref values manually:")
        err_console.print(record_table(matches, include_ref=True))
        raise CliError("ERROR: delete target is ambiguous.")

    record_type, item = matches[0]
    ref = item.get("_ref")
    if not ref:
        raise CliError("ERROR: matched record does not include an _ref.")
    client.request("DELETE", ref)
    print_success(f"SUCCESS: deleted {record_type.upper()} record {target}")


