    zone_style = (
        "bold green on #0f172a" if context["has_active_zone"] else "bold yellow on #0f172a"
    )
    return dns_context_value_text(
        context["active_zone"],
        context["active_zone_source"] if context["has_active_zone"] else None,
        zone_style,
        include_source,
    )


def dns_context_line_text(status: dict[str, Any] | None = None) -> Text:
    context = status or dns_context_status()
    text = Text(no_wrap=True, overflow="ellipsis")
    text.append("Current view: ", style=DNS_CONTEXT_LABEL_STYLE)
    text.append_text(current_view_context_text(context, include_source=False))
    text.append("  |  ", style=DNS_CONTEXT_BACKGROUND_STYLE)
    text.append("Active zone: ", style=DNS_CONTEXT_LABEL_STYLE)
    text.append_text(active_zone_context_text(context, include_source=False))
    return text


