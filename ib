def terminal_supports_masked_password() -> bool:
    """Return whether password input can use raw terminal reads with visible mask feedback."""
    if not sys.stdin.isatty() or not console.is_terminal:
        return False
    try:
        import termios  # noqa: F401
        import tty  # noqa: F401
    except ImportError:
        return False
    return True


def read_masked_password(label: str) -> str:
    """Read a password from a real terminal while echoing stars instead of the typed characters."""
    import termios
    import tty

    stdin_fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(stdin_fd)
    password_chars: list[str] = []
    console.print(f"{label}: ", end="")
    try:
        tty.setcbreak(stdin_fd)
        while True:
            raw = os.read(stdin_fd, 1)
            if not raw:
                raise EOFError
            char = raw.decode(errors="ignore")
            if char in {"\r", "\n"}:
                return "".join(password_chars)
            if char == "\x03":
                raise KeyboardInterrupt
            if char == "\x04" and not password_chars:
                raise EOFError
            if char in {"\x7f", "\b"}:
                if password_chars:
                    password_chars.pop()
                    console.file.write("\b \b")
                    console.file.flush()
                continue
            if len(char) == 1 and char.isprintable():
                password_chars.append(char)
                console.file.write("*")
                console.file.flush()
    finally:
        termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_settings)
        console.file.write("\n")
        console.file.flush()


def prompt_password(label: str, allow_blank: bool = False) -> str:
    """Prompt for a password with masked feedback when possible and quiet fallback otherwise."""
    if terminal_supports_masked_password():
        return read_masked_password(label)
    if allow_blank:
        return Prompt.ask(label, default="", password=True, show_default=False)
    return Prompt.ask(label, password=True)


def ensure_config_dir() -> None:
    """Create the private config directory with strict permissions before secrets are written."""
    CONFIG_DIR.mkdir(mode=0o700, exist_ok=True)
    os.chmod(CONFIG_DIR, 0o700)


def read_config_key() -> bytes:
    """Read the Fernet key from disk so encrypted config passwords can be decrypted."""
    if not CONFIG_KEY_FILE.exists():
        raise CliError(f"ERROR: missing encryption key file at {CONFIG_KEY_FILE}. Run: ib configure")
    try:
        key = CONFIG_KEY_FILE.read_bytes().strip()
        Fernet(key)
    except (OSError, ValueError):
        raise CliError(f"ERROR: invalid encryption key file at {CONFIG_KEY_FILE}. Run: ib configure")
    try:
        os.chmod(CONFIG_KEY_FILE, 0o600)
    except OSError:
        pass
    return key


def get_or_create_config_key() -> bytes:
    """Return the existing encryption key or create one with private permissions for first-time setup."""
    ensure_config_dir()
    if CONFIG_KEY_FILE.exists():
        return read_config_key()

    key = Fernet.generate_key()
    try:
        with CONFIG_KEY_FILE.open("xb") as handle:
            handle.write(key)
            handle.write(b"\n")
        os.chmod(CONFIG_KEY_FILE, 0o600)
    except FileExistsError:
        return read_config_key()
    except OSError:
        raise CliError(f"ERROR: cannot write encryption key file at {CONFIG_KEY_FILE}. Run: ib configure")
    return key


def encrypt_password(password: str) -> str:
    """Encrypt a password before writing config so credentials are not stored as plaintext."""
    token = Fernet(get_or_create_config_key()).encrypt(password.encode("utf-8")).decode("ascii")
    return f"{ENCRYPTED_PASSWORD_PREFIX}{token}"


def decrypt_password(password: str) -> str:
    """Decrypt an encrypted config password and surface config problems as CLI errors."""
    if not password.startswith(ENCRYPTED_PASSWORD_PREFIX):
        return password

    token = password[len(ENCRYPTED_PASSWORD_PREFIX) :].encode("ascii")
    try:
        return Fernet(read_config_key()).decrypt(token).decode("utf-8")
    except (InvalidToken, OSError, UnicodeEncodeError, UnicodeDecodeError, ValueError):
        raise CliError(f"ERROR: cannot decrypt password in {CONFIG_FILE}. Run: ib configure")


def is_encrypted_password(password: str) -> bool:
    """Detect encrypted password values so legacy plaintext configs can be migrated safely."""
    return password.startswith(ENCRYPTED_PASSWORD_PREFIX)


def normalize_profile_name(profile_name: str) -> str:
    """Normalize profile names so config sections and CLI arguments share one safe identifier format."""
    normalized = profile_name.strip()
    if not normalized:
        raise CliError("ERROR: profile name is required.")
    if not PROFILE_NAME_RE.fullmatch(normalized):
        raise CliError(
            "ERROR: profile name may only contain letters, numbers, dots, underscores, and dashes."
        )
    return normalized


def profile_section_name(profile_name: str) -> str:
    """Return the config section name for a profile so storage naming stays centralized."""
    return f"{PROFILE_SECTION_PREFIX}{normalize_profile_name(profile_name)}"


def profile_name_from_section(section_name: str) -> str:
    """Extract a profile name from a profile config section."""
    return section_name[len(PROFILE_SECTION_PREFIX) :]


def read_config_profiles(
    decrypt_passwords: bool = False,
) -> tuple[str, dict[str, dict[str, str]], bool]:
    """Read configured profiles, treating legacy [default] config as profile 'default'."""
    parser = configparser.ConfigParser()
    try:
        parser.read(CONFIG_FILE)
    except (OSError, configparser.Error) as exc:
        raise CliError(f"ERROR: cannot read {CONFIG_FILE}: {exc}") from exc

    profile_sections = [
        section for section in parser.sections() if section.startswith(PROFILE_SECTION_PREFIX)
    ]
    if profile_sections:
        profiles = {
            normalize_profile_name(profile_name_from_section(section)): dict(parser[section])
            for section in profile_sections
        }
        if CONFIG_META_SECTION not in parser:
            raise CliError(f"ERROR: missing [{CONFIG_META_SECTION}] section in {CONFIG_FILE}")
        default_profile = normalize_profile_name(
            parser[CONFIG_META_SECTION].get("default_profile", "")
        )
        if default_profile not in profiles:
            raise CliError(
                f"ERROR: default profile '{default_profile}' does not exist in {CONFIG_FILE}"
            )
        legacy = False
    elif "default" in parser:
        default_profile = DEFAULT_PROFILE_NAME
        profiles = {DEFAULT_PROFILE_NAME: dict(parser["default"])}
        legacy = True
    else:
        raise CliError(f"ERROR: no profiles configured in {CONFIG_FILE}. Run: ib configure")

    if decrypt_passwords:
        for profile_values in profiles.values():
            if profile_values.get("password"):
                profile_values["password"] = decrypt_password(profile_values["password"])
    return default_profile, profiles, legacy


def profile_config_values(config_values: dict[str, str]) -> dict[str, str]:
    """Return a complete profile config dict with defaults for optional fields."""
    return {
        "server": config_values.get("server", ""),
        "username": config_values.get("username", ""),
        "password": config_values.get("password", ""),
        "wapi_version": config_values.get("wapi_version", DEFAULT_WAPI_VERSION),
        "dns_view": config_values.get("dns_view", "default"),
        "default_zone": config_values.get("default_zone", ""),
        "verify_ssl": config_values.get("verify_ssl", "true"),
        "timeout": str(config_values.get("timeout", DEFAULT_TIMEOUT)),
    }


def write_config_profiles(
    default_profile: str,
    profiles: dict[str, dict[str, str]],
) -> None:
    """Persist all profiles with one default while preserving strict config permissions."""
    normalized_profiles = {
        normalize_profile_name(name): profile_config_values(values)
        for name, values in profiles.items()
    }
    normalized_default = normalize_profile_name(default_profile)
    if normalized_default not in normalized_profiles:
        raise CliError(f"ERROR: default profile '{normalized_default}' does not exist.")

    ensure_config_dir()
    config = configparser.ConfigParser()
    config[CONFIG_META_SECTION] = {"default_profile": normalized_default}
    for profile_name in sorted(normalized_profiles):
        values = dict(normalized_profiles[profile_name])
        password = values.get("password", "")
        values["password"] = password if is_encrypted_password(password) else encrypt_password(password)
        config[profile_section_name(profile_name)] = values

    with CONFIG_FILE.open("w", encoding="utf-8") as handle:
        config.write(handle)
    os.chmod(CONFIG_FILE, 0o600)


def write_config_values(config_values: dict[str, str]) -> None:
    """Persist one profile through the multi-profile writer for backward-compatible callers."""
    profile_name = normalize_profile_name(config_values.get("profile", DEFAULT_PROFILE_NAME))
    write_config_profiles(profile_name, {profile_name: config_values})


def load_config_for_prompt(profile_name: str | None = None) -> dict[str, str]:
    """Load one profile with decrypted password for interactive editing defaults."""
    if not CONFIG_FILE.exists():
        return {}

    default_profile, profiles, _legacy = read_config_profiles()
    selected_profile = normalize_profile_name(profile_name or default_profile)
    if selected_profile not in profiles:
        raise CliError(f"ERROR: profile '{selected_profile}' does not exist.")

    cfg = dict(profiles[selected_profile])
    cfg["profile"] = selected_profile
    if cfg.get("server"):
        cfg["server"] = normalize_server(cfg["server"])
    if cfg.get("password"):
        try:
            cfg["password"] = decrypt_password(cfg["password"])
        except CliError as exc:
            print_warning(str(exc))
            cfg.pop("password", None)
    return cfg


def dns_view_query_params() -> dict[str, Any]:
    """Build the unscoped WAPI query for DNS views used during profile creation."""
    return {"_return_fields": DNS_VIEW_RETURN_FIELDS}


def dns_view_names_from_records(view_records: list[dict[str, Any]]) -> list[str]:
    """Extract sorted unique DNS view names so the interactive prompt has stable choices."""
    names = {
        str(record.get("name", "")).strip()
        for record in view_records
        if str(record.get("name", "")).strip()
    }
    return sorted(names, key=str.lower)


def query_dns_view_records(client: InfobloxClient) -> list[dict[str, Any]]:
    """Query all DNS views through WAPI so configure and dns view commands share retrieval behavior."""
    return paged_query(
        client,
        DNS_VIEW_OBJECT,
        dns_view_query_params(),
        warn_on_skip=False,
    )


def query_dns_view_names(client: InfobloxClient) -> list[str]:
    """Return sorted DNS view names from Infoblox for listing, validation, and completion."""
    return dns_view_names_from_records(query_dns_view_records(client))


def query_dns_view_names_for_config(config_values: dict[str, str]) -> list[str]:
    """Connect with unsaved profile values and return DNS view names before the profile is persisted."""
    client = InfobloxClient(config_values)
