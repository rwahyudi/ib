def command_option_completion_items(
    command: click.Command,
    ctx: click.Context,
    incomplete: str,
) -> list[CompletionItem]:
    """Return visible option names for completions that land in free-form arguments."""
    prefix = incomplete or "-"
    excluded_options = command_excluded_completion_options(command, ctx)
    items: list[CompletionItem] = []
    for param in command.params:
        if not isinstance(param, click.Option) or param.hidden:
            continue
        help_text = param.help or None
        for opt in [*param.opts, *param.secondary_opts]:
            if opt in excluded_options:
                continue
            if opt.startswith(prefix):
                items.append(CompletionItem(opt, help=help_text))

    help_option = command.get_help_option(ctx)
    if help_option is not None:
        help_text = help_option.help or None
        for opt in [*help_option.opts, *help_option.secondary_opts]:
            if opt.startswith(prefix):
                items.append(CompletionItem(opt, help=help_text))
    return items


def command_excluded_completion_options(
    command: click.Command,
    ctx: click.Context,
) -> set[str]:
    """Return command-specific options to omit from context-aware completions."""
    excluded_options = getattr(command, "excluded_completion_options", None)
    if callable(excluded_options):
        return set(excluded_options(ctx))
    return set()


def option_completion_is_relevant(incomplete: str) -> bool:
    """Offer options for empty completion and for values already starting with a dash."""
    return not incomplete or incomplete.startswith("-")


def append_command_option_completion_items(
    command: click.Command,
    ctx: click.Context,
    incomplete: str,
    items: list[CompletionItem],
) -> list[CompletionItem]:
    """Append command options to completion results without duplicating values."""
    if not option_completion_is_relevant(incomplete):
        return items

    seen = {str(item.value) for item in items}
    for item in command_option_completion_items(command, ctx, incomplete):
        if str(item.value) not in seen:
            items.append(item)
            seen.add(str(item.value))
    return items


def normalize_completion_items(items: list[Any]) -> list[CompletionItem]:
    """Convert Click's legacy string completion results to CompletionItem objects."""
    if items and isinstance(items[0], str):
        return [CompletionItem(str(item)) for item in items]
    return items


def argument_completion_with_command_options(
    original_complete: Callable[[click.Context, click.Parameter, str], list[Any]] | None,
) -> Callable[[click.Context, click.Parameter, str], list[CompletionItem]]:
    """Wrap argument completion so command options remain visible at argument positions."""

    def complete(
        ctx: click.Context,
        param: click.Parameter,
        incomplete: str,
    ) -> list[CompletionItem]:
        if original_complete is not None:
            items = normalize_completion_items(original_complete(ctx, param, incomplete))
        else:
            items = param.type.shell_complete(ctx, param, incomplete)
        return append_command_option_completion_items(ctx.command, ctx, incomplete, items)

    return complete


def register_argument_option_completion(command: click.Command) -> None:
    """Wrap command arguments once so options complete consistently everywhere."""
    for param in command.params:
        if not isinstance(param, click.Argument):
            continue
        if getattr(param, "_ib_option_completion_registered", False):
            continue
        original_complete = param._custom_shell_complete
        param._ib_original_shell_complete = original_complete
        param._custom_shell_complete = argument_completion_with_command_options(original_complete)
        param._ib_option_completion_registered = True


def register_argument_option_completion_everywhere(command: click.Command) -> None:
    """Attach option-aware argument completion recursively to the command tree."""
    register_argument_option_completion(command)
    if isinstance(command, click.Group):
        for subcommand in command.commands.values():
            register_argument_option_completion_everywhere(subcommand)


