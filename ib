class CliError(Exception):
    """Expected CLI failure with a user-facing message."""


class WapiError(CliError):
    """Infoblox WAPI request failure."""

    def __init__(self, message: str, status: int | None = None) -> None:
        super().__init__(message)
        self.status = status


def print_success(message: str) -> None:
    console.print(Text(message, style="bold green"))


def print_warning(message: str) -> None:
    err_console.print(Text(message, style="bold yellow"))


def print_error(message: str) -> None:
    err_console.print(Text(str(message), style="bold red"))


def print_note(message: str) -> None:
    console.print(Text(message, style="cyan"))


def print_command_block(commands: list[str]) -> None:
    for command in commands:
        console.print(Text(f"  {command}", style="green"))
    console.print()


